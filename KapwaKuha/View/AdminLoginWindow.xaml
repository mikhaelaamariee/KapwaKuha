<Window x:Class="KapwaKuha.View.AdminLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Admin Login"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT — form -->
        <Grid Grid.Column="0" Background="White">
            <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.02"
                   Width="1980" Height="2808"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Button Command="{Binding BackCommand}"
                    Style="{StaticResource LinkBtn}"
                    Content="← Back"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="40,40,0,0" FontSize="14"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Width="400" Margin="20,0">

                <!-- Icon + heading -->
                <Border Width="72" Height="72" CornerRadius="36"
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0077B6" Offset="0"/>
                            <GradientStop Color="#00B4D8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🛡" FontSize="32"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="ADMIN LOGIN" FontSize="36" FontWeight="Black"
                           Foreground="#0077B6" HorizontalAlignment="Center"/>
                <TextBlock Text="Restricted access. Authorized personnel only."
                           FontSize="13" Foreground="#6B7280"
                           HorizontalAlignment="Center" Margin="0,8,0,36"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <!-- Admin ID -->
                <Border Background="#F4F6F8" CornerRadius="12" Height="50" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🆔" Foreground="#9CA3AF" FontSize="16"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="AdminIdEntry"
                                     Text="{Binding AdminId, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" FontSize="14"
                                     Padding="0,0,15,0" Panel.ZIndex="1"/>
                            <TextBlock IsHitTestVisible="False" Text="Admin ID  (e.g. A001)"
                                       VerticalAlignment="Center" Padding="5,0,0,0"
                                       Foreground="Gray" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=AdminIdEntry}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Password -->
                <Border Background="#F4F6F8" CornerRadius="12" Height="50" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔒" Foreground="#9CA3AF" FontSize="16"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBlock x:Name="PlaceholderText"
                                       Text="Enter your password"
                                       VerticalAlignment="Center" Foreground="Gray"
                                       FontSize="14" Margin="5,0,0,0"
                                       IsHitTestVisible="False" Visibility="Visible"/>
                            <PasswordBox x:Name="PwBox"
                                         PasswordChanged="PwBox_PasswordChanged"
                                         BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         FontSize="14" Padding="0,0,15,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Error banner -->
                <Border Background="#FEE2E2" CornerRadius="8" Padding="12,10" Margin="0,0,0,12"
                        Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                               FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </Border>

                <!-- Login button -->
                <Button x:Name="LoginBtn" Content="Login as Admin"
                        Style="{StaticResource GradientButton}"
                        Height="50" Margin="0,10,0,0"
                        Click="LoginBtn_Click"/>

                <TextBlock Text="Default: A001 / admin123"
                           FontSize="11" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>

        <!-- RIGHT — decorative panel -->
        <Border Grid.Column="1" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A2540" Offset="0"/>
                    <GradientStop Color="#0077B6" Offset="0.6"/>
                    <GradientStop Color="#00B4D8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Ellipse Width="600" Height="600" Fill="#1AFFFFFF"
                         Margin="-200,-200,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <Ellipse Width="800" Height="800" Fill="#0DFFFFFF"
                         Margin="0,0,-300,-300" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60,0">
                    <TextBlock Text="🛡️" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <TextBlock Text="Admin Control Panel" FontSize="28" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="#CCFFFFfF" FontSize="15" LineHeight="26">
                        Manage donation posts, approve beneficiary registrations,
                        review reports, and oversee the KapwaKuha platform.
                    </TextBlock>

                    <!-- KPI badges -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                        <Border CornerRadius="12" Background="#1AFFFFFF"
                                BorderBrush="#33FFFFFF" BorderThickness="1"
                                Padding="20,14" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Gatekeeper" Foreground="White" FontSize="12"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="✅" FontSize="28" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="12" Background="#1AFFFFFF"
                                BorderBrush="#33FFFFFF" BorderThickness="1"
                                Padding="20,14" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Moderation" Foreground="White" FontSize="12"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="🛡" FontSize="28" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="12" Background="#1AFFFFFF"
                                BorderBrush="#33FFFFFF" BorderThickness="1"
                                Padding="20,14">
                            <StackPanel>
                                <TextBlock Text="Analytics" Foreground="White" FontSize="12"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="📊" FontSize="28" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>