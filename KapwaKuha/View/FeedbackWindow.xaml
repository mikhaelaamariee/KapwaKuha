<Window x:Class="KapwaKuha.View.FeedbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Rate This Donation"
        Height="520" Width="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Geometry x:Key="StarIcon">M12,17.27 L18.18,21 L16.54,13.97 L22,9.24 L14.81,8.62 L12,2 L9.19,8.62 L2,9.24 L7.45,13.97 L5.82,21 Z</Geometry>
    </Window.Resources>

    <Border CornerRadius="20" Style="{StaticResource GlassCard}" Margin="0">
        <Grid Margin="40,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="⭐ Rate This Donation"
                       FontSize="24" FontWeight="Bold" Foreground="#0A2540"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Grid.Row="1" Text="{Binding DonorLabel}"
                       FontSize="13" Foreground="#6B7280"
                       HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,0,0,4">

                <Grid Width="36" Height="36" Margin="4,0">
                    <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Fill="#D1D5DB"/>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="1"
                            Width="18" HorizontalAlignment="Left" ClipToBounds="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Width="36" Height="36" HorizontalAlignment="Left">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half1Filled}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="2"
                            Width="18" HorizontalAlignment="Right" ClipToBounds="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Width="36" Height="36" HorizontalAlignment="Left" Margin="-18,0,0,0">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half2Filled}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                </Grid>

                <Grid Width="36" Height="36" Margin="4,0">
                    <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Fill="#D1D5DB"/>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="3"
                            Width="18" HorizontalAlignment="Left" ClipToBounds="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Width="36" Height="36" HorizontalAlignment="Left">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half3Filled}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="4"
                            Width="18" HorizontalAlignment="Right" ClipToBounds="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Width="36" Height="36" HorizontalAlignment="Left" Margin="-18,0,0,0">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half4Filled}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                </Grid>

                <Grid Width="36" Height="36" Margin="4,0">
                    <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Fill="#D1D5DB"/>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="5"
                            Width="18" HorizontalAlignment="Left" ClipToBounds="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Width="36" Height="36" HorizontalAlignment="Left">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half5Filled}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="6"
                            Width="18" HorizontalAlignment="Right" ClipToBounds="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Width="36" Height="36" HorizontalAlignment="Left" Margin="-18,0,0,0">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half6Filled}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                </Grid>

                <Grid Width="36" Height="36" Margin="4,0">
                    <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Fill="#D1D5DB"/>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="7"
                            Width="18" HorizontalAlignment="Left" ClipToBounds="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Width="36" Height="36" HorizontalAlignment="Left">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half7Filled}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="8"
                            Width="18" HorizontalAlignment="Right" ClipToBounds="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Width="36" Height="36" HorizontalAlignment="Left" Margin="-18,0,0,0">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half8Filled}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                </Grid>

                <Grid Width="36" Height="36" Margin="4,0">
                    <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Fill="#D1D5DB"/>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="9"
                            Width="18" HorizontalAlignment="Left" ClipToBounds="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Width="36" Height="36" HorizontalAlignment="Left">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half9Filled}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="10"
                            Width="18" HorizontalAlignment="Right" ClipToBounds="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="{StaticResource StarIcon}" Stretch="Uniform" Width="36" Height="36" HorizontalAlignment="Left" Margin="-18,0,0,0">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half10Filled}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                </Grid>
            </StackPanel>

            <TextBlock Grid.Row="3" Text="{Binding StarDisplayLabel}"
                       FontSize="14" FontWeight="SemiBold" Foreground="#F59E0B"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>

            <TextBlock Grid.Row="4" Text="Leave a comment (optional)"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,8"/>
            <Border Grid.Row="5" Style="{StaticResource GlassInputBorder}" CornerRadius="12">
                <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#0A2540" FontSize="13" Padding="14,10"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="80"/>
            </Border>

            <Border Grid.Row="5" Background="#FEE2E2" CornerRadius="8" Padding="12,8"
                    VerticalAlignment="Bottom" Margin="0,0,0,0"
                    Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                           FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <Grid Grid.Row="6" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel"
                        Style="{StaticResource OutlineBtn}"
                        Command="{Binding CancelCommand}" Height="46"/>
                <Button Grid.Column="2" Content="Submit Feedback"
                        Style="{StaticResource GradientButton}"
                        Command="{Binding SubmitCommand}" Height="46"/>
            </Grid>
        </Grid>
    </Border>
</Window>