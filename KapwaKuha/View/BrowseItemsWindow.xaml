<Window x:Class="KapwaKuha.View.BrowseItemsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Browse Items"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:BrowseItemsDesignViewModel, IsDesignTimeCreatable=True}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Ellipse Width="380" Height="380" Opacity="0.12"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.03" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Browse Items" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="⟳ Refresh" Background="Transparent" BorderThickness="0"
                            Foreground="#CAF0F8" FontSize="12" Cursor="Hand" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16,12">
                    <Border.Effect>
                        <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍  Filter by Category:" FontSize="13"
                                   Foreground="#03045E" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border CornerRadius="8" BorderBrush="#90E0EF" BorderThickness="1.5"
                                Background="#F0F8FB">
                            <ComboBox SelectedValue="{Binding FilterCategory}"
                                      SelectedValuePath="Content"
                                      Width="180" Height="34" Background="Transparent"
                                      BorderThickness="0" Padding="10,0" FontSize="12">
                                <ComboBoxItem Content="All" IsSelected="True"/>
                                <ComboBoxItem Content="Clothing"/>
                                <ComboBoxItem Content="Food"/>
                                <ComboBoxItem Content="Electronics"/>
                                <ComboBoxItem Content="Medicine"/>
                                <ComboBoxItem Content="School Supplies"/>
                            </ComboBox>
                        </Border>
                        <TextBlock Text="{Binding Items.Count, StringFormat='{}{0} item(s) available'}"
                                   Foreground="#5E7A8A" FontSize="12"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="Transparent"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Loading items..." FontSize="14" Foreground="#0077B6"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>

                    <ItemsControl ItemsSource="{Binding Items}" Margin="0,4,0,0">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="320" Margin="0,0,24,24" Background="White" CornerRadius="12" Cursor="Hand" BorderBrush="#E8ECF0" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00B4D8" BlurRadius="12" ShadowDepth="2" Opacity="0.10"/>
                                    </Border.Effect>

                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>

                                    <StackPanel>
                                        <Border Height="240" CornerRadius="12,12,0,0" ClipToBounds="True">
                                            <Grid>
                                                <Border>
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#EBF7FB" Offset="0"/>
                                                            <GradientStop Color="#CAF0F8" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>

                                                <TextBlock Text="📦" FontSize="72" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Image Source="{Binding Item_ImagePath}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>

                                                <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,10,10,0" 
                                                        CornerRadius="6" Padding="10,6" Background="{Binding StatusBadgeBackground}">
                                                    <TextBlock Text="{Binding Item_Status}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding StatusBadgeColor}"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <StackPanel Margin="16,16,16,18">
                                            <TextBlock Text="{Binding Item_Name}" FontSize="20" FontWeight="Bold" Foreground="#03045E" 
                                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Margin="0,0,0,4"/>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Donor_Name, StringFormat='Donated by {0}'}" 
               FontSize="13" Foreground="#5E7A8A" TextTrimming="CharacterEllipsis" 
               VerticalAlignment="Center"/>

                                                <Button Grid.Column="1" 
            Command="{Binding DataContext.OpenChatCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
            CommandParameter="{Binding}" 
            Cursor="Hand" ToolTip="Message Donor"
            Background="Transparent" BorderThickness="0" Margin="8,0,0,0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="14" Padding="6" x:Name="IconBorder">
                                                                <Path Data="M20,2H4C2.9,2,2,2.9,2,4v18l4-4h14c1.1,0,2-0.9,2-2V4C22,2.9,21.1,2,20,2z" 
                          Fill="#00B4D8" Width="16" Height="16" Stretch="Uniform" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="IconBorder" Property="Background" Value="#EBF7FB"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Background="#EBF7FB" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Category_Name}" FontSize="12" Foreground="#0077B6" FontWeight="SemiBold"/>
                                                </Border>
                                                <Border Background="#F5F5F5" CornerRadius="6" Padding="8,4">
                                                    <TextBlock Text="{Binding StorageDaysDisplay}" FontSize="12" Foreground="#666"/>
                                                </Border>
                                            </StackPanel>

                                            <Button Command="{Binding DataContext.SelectItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" Height="44" BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="8" Background="#00B4D8" x:Name="ClaimBtnBg">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ClaimBtnBg" Property="Background" Value="#0077B6"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <TextBlock Text="🤲 Claim Item" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>