<Window x:Class="KapwaKuha.View.ActiveListingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                                 xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
 mc:Ignorable="d"
d:DataContext="{d:DesignInstance Type=vm:ActiveListingsDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Active Listings"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.05"
               Width="1980" Height="2808"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Active Listings" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="⟳ Refresh" Background="Transparent" BorderThickness="0"
                            Foreground="#CAF0F8" FontSize="12" Cursor="Hand"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,14,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="16" BorderThickness="1.5" Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CCFFFFFF" Offset="0"/>
                            <GradientStop Color="#66FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="#33FFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="20,16,20,12">
                            <TextBlock Text="📋 My Posted Items" FontSize="15"
                                       FontWeight="Bold" Foreground="#03045E"/>
                            <TextBlock Text="All items you have donated. Select an item on the list to edit or delete it."
                                       FontSize="11" Foreground="#5E7A8A" Margin="0,3,0,0"/>
                        </StackPanel>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Items}"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EBF7FB"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F0F8FB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,12" BorderBrush="#EBF7FB" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Item_Name}" FontSize="14" FontWeight="Bold" 
                                                           Foreground="#03045E" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Item_ID, StringFormat='ID: {0}'}" 
                                                           FontSize="11" Foreground="#5E7A8A" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Category_Name}" FontSize="12" FontWeight="SemiBold" Foreground="#0077B6"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Item_Condition}" FontSize="11" Foreground="#5E7A8A"/>
                                                    <TextBlock Text=" • " FontSize="11" Foreground="#90E0EF"/>
                                                    <TextBlock Text="{Binding PostType}" FontSize="11" Foreground="#5E7A8A"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Border Grid.Column="2" CornerRadius="8" Padding="12,4" 
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Background="{Binding StatusBadgeBackground}">
                                                <TextBlock Text="{Binding Item_Status}" FontSize="11" FontWeight="Bold" 
                                                           Foreground="{Binding StatusBadgeColor}" HorizontalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="Posted" FontSize="10" Foreground="#5E7A8A" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding StorageDaysDisplay}" FontSize="12" FontWeight="SemiBold" 
                                                           Foreground="#03045E" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="2" CornerRadius="16" BorderThickness="1.5" Padding="24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CCFFFFFF" Offset="0"/>
                            <GradientStop Color="#66FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="#33FFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="⚙️ Manage Selected Item" FontSize="15"
                                   FontWeight="Bold" Foreground="#03045E" Margin="0,0,0,6"/>
                        <TextBlock Text="Edit details or remove the item from listings."
                                   FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,24"/>

                        <TextBlock Text="← Select an item to manage it"
                                   FontSize="13" Foreground="#90A4AE"
                                   HorizontalAlignment="Center" Margin="0,40,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsItemSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Visibility="{Binding IsItemSelected, Converter={StaticResource BoolToVis}}">

                            <TextBlock Text="Selected Item" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0A2540" Margin="4,0,0,8"/>

                            <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                    Padding="16,12" Background="#80FFFFFF" Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedItem.Item_Name}" FontSize="15" FontWeight="Bold" Foreground="#03045E" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedItem.Category_Name}" FontSize="13" Foreground="#0077B6" Margin="0,4,0,8"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Condition: " FontSize="12" Foreground="#5E7A8A"/>
                                        <TextBlock Text="{Binding SelectedItem.Item_Condition}" FontSize="12" FontWeight="SemiBold" Foreground="#0A2540"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Status: " FontSize="12" Foreground="#5E7A8A"/>
                                        <TextBlock Text="{Binding SelectedItem.Item_Status}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SelectedItem.StatusBadgeColor}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Button Command="{Binding EditPostCommand}"
                                    IsEnabled="{Binding CanEditSelected}"
                                    Height="44" FontSize="13" FontWeight="Bold"
                                    Foreground="White" BorderThickness="0"
                                    Cursor="Hand" Margin="0,0,0,12">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="EditBorder" CornerRadius="10" Background="#00B4D8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="EditBorder" Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="EditBorder" Property="Background" Value="#B0BEC5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00B4D8" Offset="0"/>
                                        <GradientStop Color="#0077B6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <TextBlock Text="✏️  Edit Details"/>
                            </Button>

                            <Button Command="{Binding DeleteItemCommand}"
                                    Height="44" FontSize="13" FontWeight="Bold"
                                    Foreground="White" Background="#C0304A"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="🗑️  Delete This Item"/>
                            </Button>

                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="EditPanel"
                    Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                    CornerRadius="16,16,0,0" Padding="24,20"
                    BorderThickness="1,1,1,0" BorderBrush="#90E0EF"
                    Visibility="{Binding IsEditPanelOpen, Converter={StaticResource BoolToVis}}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0F8FF" Offset="0"/>
                        <GradientStop Color="#FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#0077B6" BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="✏️ Edit Post" FontSize="15" FontWeight="Bold"
                                   Foreground="#03045E" Margin="0,0,0,14"/>

                        <TextBlock Text="Item Name" FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#90E0EF" BorderThickness="1"
                                Padding="10,0" Background="White" Margin="0,0,0,10">
                            <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Background="Transparent" BorderThickness="0"
                                     FontSize="13" Foreground="#03045E" VerticalContentAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Description" FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#90E0EF" BorderThickness="1"
                                Padding="10,8" Background="White" Margin="0,0,0,10">
                            <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Height="56" Background="Transparent" BorderThickness="0"
                                     FontSize="13" Foreground="#03045E" TextWrapping="Wrap"
                                     AcceptsReturn="True"/>
                        </Border>

                        <TextBlock Text="Condition" FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#90E0EF" BorderThickness="1"
                                Background="White" Margin="0,0,0,14">
                            <ComboBox ItemsSource="{Binding Conditions}"
                                      SelectedItem="{Binding EditCondition}"
                                      Height="36" Background="Transparent" BorderThickness="0"
                                      FontSize="13" Padding="10,0"/>
                        </Border>

                        <TextBlock Text="Photo" FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="8" BorderBrush="#90E0EF"
                                    BorderThickness="1" Padding="10,0" Background="White">
                                <TextBox Text="{Binding EditImagePath}" Height="36"
                                         Background="Transparent" BorderThickness="0"
                                         FontSize="11" Foreground="#5E7A8A" IsReadOnly="True"
                                         VerticalContentAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="2" Command="{Binding BrowseEditImageCommand}"
                                    Height="36" Padding="12,0" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="8" Background="#0077B6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="📷 Browse" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Button>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Command="{Binding SaveEditCommand}" Height="40" Padding="20,0"
                                    Margin="0,0,10,0" FontSize="12" FontWeight="SemiBold"
                                    Foreground="White" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00B4D8" Offset="0"/>
                                        <GradientStop Color="#0077B6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <TextBlock Text="💾 Save Changes"/>
                            </Button>
                            <Button Command="{Binding CancelEditCommand}" Height="40" Padding="16,0"
                                    FontSize="12" Foreground="#5E7A8A"
                                    Background="Transparent" BorderBrush="#90E0EF" BorderThickness="1"
                                    Cursor="Hand">
                                <TextBlock Text="✕ Cancel"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="2" CornerRadius="12" ClipToBounds="True"
                            Visibility="{Binding HasEditImage, Converter={StaticResource BoolToVis}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasEditImage}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Image Source="{Binding EditImagePath}" Stretch="UniformToFill"
                               MaxHeight="200"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="#03045E" Padding="20,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#90E0EF" FontSize="11" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>