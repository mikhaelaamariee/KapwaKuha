<Window x:Class="KapwaKuha.View.MyImpactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                                                 xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
 mc:Ignorable="d"
d:DataContext="{d:DesignInstance Type=vm:MyImpactDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — My Impact"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.05"
               Width="1980" Height="2808" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="My Impact Dashboard" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="⟳ Refresh" Background="Transparent" BorderThickness="0"
                            Foreground="#CAF0F8" FontSize="12" Cursor="Hand" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">

                    <!-- Donor label -->
                    <Border Background="White" CornerRadius="14" Padding="20,16" Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💙 " FontSize="22" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding DonorName}" FontSize="16" FontWeight="Bold"
                                           Foreground="#03045E"/>
                                <TextBlock Text="Your community impact at a glance."
                                           FontSize="12" Foreground="#5E7A8A"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Top 3 metric cards -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,20">

                        <Border CornerRadius="16" Margin="0,0,14,0" BorderThickness="1.5" Padding="22,38">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#33FFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="🤲" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Total Donated" FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TotalDonated}" FontSize="32"
                                           FontWeight="Bold" Foreground="#00B4D8"/>
                                <TextBlock Text="items posted" FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="16" Margin="0,0,14,0" BorderThickness="1.5" Padding="22,38">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#33FFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="✅" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Successfully Claimed" FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TotalClaimed}" FontSize="32"
                                           FontWeight="Bold" Foreground="#2DC653"/>
                                <TextBlock Text="items confirm received" FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="16" BorderThickness="1.5" Padding="22,38">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#33FFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="📦" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Still Available" FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ActiveItems}" FontSize="32"
                                           FontWeight="Bold" Foreground="#0077B6"/>
                                <TextBlock Text="awaiting claim" FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                        </Border>

                    </UniformGrid>

                    <!-- Bottom 2 new metric cards + Kapwa message -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Fulfilled Needs -->
                        <Border Grid.Column="0" CornerRadius="16" BorderThickness="1.5" Padding="22,32">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#33FFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="🚨" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Needs Fulfilled" FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding FulfilledNeeds}" FontSize="32"
                                           FontWeight="Bold" Foreground="#C0304A"/>
                                <TextBlock Text="priority needs resolved" FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                        </Border>

                        <!-- Active Beneficiaries -->
                        <Border Grid.Column="2" CornerRadius="16" BorderThickness="1.5" Padding="22,32">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#33FFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="👥" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Active Beneficiaries" FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ActiveBeneficiaries}" FontSize="32"
                                           FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Text="people in the system" FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                        </Border>

                        <!-- Kapwa Impact message -->
                        <Border Grid.Column="4" Background="#EBF7FB" CornerRadius="16" Padding="22,18">
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="💙 Kapwa Impact" FontSize="14" FontWeight="Bold"
                                           Foreground="#0077B6" Margin="0,0,0,8"/>
                                <TextBlock Text="Every item you donate is a connection. You're not just giving things — you're giving hope and dignity to your community."
                                           FontSize="12" Foreground="#5E7A8A" TextWrapping="Wrap" LineHeight="18"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>