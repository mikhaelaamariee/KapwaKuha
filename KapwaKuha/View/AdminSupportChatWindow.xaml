<Window x:Class="KapwaKuha.View.AdminSupportChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Admin Support"
        Height="680" Width="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0F8FF" Offset="0"/>
                <GradientStop Color="#E8F4FD" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOPBAR -->
        <!-- Replace the header content in AdminSupportChatWindow.xaml TopBar -->
        <Border Grid.Row="0" Background="#0077B6">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="BackBtn"
                Content="← Back" Background="Transparent" BorderThickness="0"
                Foreground="White" FontSize="13" Cursor="Hand"
                VerticalAlignment="Center" Click="BackBtn_Click"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Support icon -->
                    <Border Width="32" Height="32" CornerRadius="16"
                    Background="#CAF0F8" Margin="0,0,10,0">
                        <TextBlock Text="💬" FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="KapwaKuha Support"
                           FontSize="15" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Official support channel"
                           FontSize="10" Foreground="#CAF0F8"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CHAT AREA — only the user's own thread -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Messages -->
            <ScrollViewer Grid.Row="0" x:Name="ScrollView"
                          VerticalScrollBarVisibility="Auto" Padding="16,12">
                <ItemsControl x:Name="MessagesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4">
                                <!-- Sender badge — shown ABOVE the bubble, opposite the alignment -->
                                <TextBlock FontSize="10" FontWeight="SemiBold" Margin="4,0,4,2"
                       Opacity="0.55">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="KapwaKuha Support"/>
                                            <Setter Property="Foreground"  Value="#0077B6"/>
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                    <Setter Property="Text"       Value="You"/>
                                                    <Setter Property="Foreground"  Value="#6B7280"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Bubble -->
                                <Border MaxWidth="420" Padding="12,8" CornerRadius="12"
                    HorizontalAlignment="{Binding HAlignment}"
                    Margin="0,0,0,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                    <Setter Property="Background" Value="#0077B6"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00B4D8" BlurRadius="8" ShadowDepth="0" Opacity="0.10"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#0A2540"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding TimeLabel}" FontSize="10" Opacity="0.6"
                               HorizontalAlignment="Right" Margin="0,4,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#6B7280"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                            <Setter Property="Foreground" Value="#CAF0F8"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input bar -->
            <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="0,1,0,0" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="24" BorderBrush="#D1D5DB"
                            BorderThickness="1" Background="#F9FAFB" Padding="16,0"
                            Margin="0,0,10,0">
                        <TextBox x:Name="InputBox" Background="Transparent"
                                 BorderThickness="0" FontSize="13"
                                 VerticalContentAlignment="Center" Height="40"
                                 KeyDown="InputBox_KeyDown"
                                 />
                    </Border>
                    <Button Grid.Column="1" x:Name="SendBtn"
                            Width="44" Height="44" BorderThickness="0"
                            Cursor="Hand" Click="SendBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="22">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00B4D8" Offset="0"/>
                                            <GradientStop Color="#0077B6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="➤" FontSize="16" Foreground="White"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>