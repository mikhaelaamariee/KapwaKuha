<Window x:Class="KapwaKuha.View.BeneficiaryDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:BeneficiaryDashboardDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Beneficiary Dashboard"
        Height="920" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" ResizeMode="CanResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <!-- Background gradient -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.05"
               Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808"/>
        <Ellipse Width="380" Height="380" Opacity="0.13"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════ SIDEBAR ═══════════════════════════ -->
            <Border Grid.Column="0"
                    Style="{StaticResource AnimatedSidebarStyle}"
                    BorderThickness="0,0,1.5,0">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="#4D0077B6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Brand header -->
                    <StackPanel Grid.Row="0" Margin="20,24,20,16">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="38" Height="38" Margin="0,0,4,0">
                                <Image Source="https://i.imgur.com/FHFRQxB.png" Width="60" Height="60"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                                <Run Foreground="#FF03045E" Text="Kapwa"/>
                                <Run Foreground="#FF00B4D8" Text="Kuha"/>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="Beneficiary Portal" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#0077B6" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding UserLabel}" FontSize="11"
                                   Foreground="#5E7A8A" Margin="0,4,0,0"/>
                        <Rectangle Height="1.2" Margin="0,16,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#330077B6" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>

                    <!-- Nav buttons — Claim History REMOVED per spec -->
                    <StackPanel Grid.Row="1" Margin="12,0">

                        <Button Command="{Binding ClaimTrackerCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Claim Tracker" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding BrowseItemsCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛍️" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Browse Items" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding NeedsWishlistCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Needs Wishlist" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding EditNeedsPostsCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✏️" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Edit My Needs" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding ChatCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💬" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Messages" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                    </StackPanel>

                    <!-- Logout -->
                    <StackPanel Grid.Row="2" Margin="12,0,12,24">
                        <Rectangle Height="1.2" Margin="8,0,8,16">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A0077B6" Offset="0"/>
                                    <GradientStop Color="#330077B6" Offset="0.5"/>
                                    <GradientStop Color="#1A0077B6" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Button Command="{Binding LogoutCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0">
                            <Border CornerRadius="12" Padding="12,12" Background="#1AC0304A">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬅" Margin="0,0,12,0" Foreground="#C0304A" FontSize="14"/>
                                    <TextBlock Text="Log Out" Foreground="#C0304A"
                                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════ MAIN CONTENT ═══════════════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top bar -->
                <Border Grid.Row="0" Background="#AAFFFFFF">
                    <Border.Effect>
                        <DropShadowEffect Color="#0077B6" BlurRadius="10" ShadowDepth="0" Opacity="0.10"/>
                    </Border.Effect>
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding HamburgerCommand}"
                                Content="☰" Foreground="#03045E" Background="Transparent"
                                BorderThickness="0" FontSize="22" Cursor="Hand" VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1" Text="{Binding WelcomeText}"
                                   Foreground="#03045E" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="14,0,0,0" TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Profile chip -->
                        <Border Grid.Column="2" CornerRadius="20" Padding="4,4,12,4"
                                VerticalAlignment="Center"
                                Background="#E6FFFFFF" BorderBrush="#B390E0EF" BorderThickness="1"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding MyBAccountCommand}"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="18" ClipToBounds="True"
                                        Cursor="Hand" Margin="0,0,8,0">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding MyBAccountCommand}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Border Background="#EBF7FB" CornerRadius="18"/>
                                        <TextBlock Text="👤" FontSize="20"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Image Source="{Binding ProfilePicturePath}" Stretch="UniformToFill">
                                            <Image.Clip>
                                                <EllipseGeometry RadiusX="18" RadiusY="18" Center="18,18"/>
                                            </Image.Clip>
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding UserLabel}" FontSize="12"
                                           Foreground="#03045E" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text=" ▼" FontSize="9" Foreground="#5E7A8A"
                                           VerticalAlignment="Center" Margin="6,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Scrollable body -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20,16,0">
                    <StackPanel>

                        <!-- ══ ROW A: Hero banner + Messages panel ══ -->
                        <Grid Margin="0,0,0,-10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>

                            <!-- Hero + Categories (left column) -->
                            <StackPanel Grid.Column="0">

                                <!-- Hero banner card — fixed layout so it never squishes -->
                                <Border CornerRadius="16" Margin="0,0,0,16" Padding="18,16,18,8"
                                        BorderThickness="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                            <GradientStop Color="#AAEAF8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.12"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="What would you like to do today?"
                                                       FontSize="19" FontWeight="Bold" Foreground="#03045E"
                                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                                            <TextBlock Text="Browse items, track your claims, or post your organization's needs."
                                                       FontSize="12" Foreground="#5E7A8A" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Kapwa Impact card — fixed width, no squish -->
                                        <Border Grid.Column="2" Background="#EBF7FB" CornerRadius="14"
                                                Padding="16,14" VerticalAlignment="Center">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#00B4D8" BlurRadius="10" ShadowDepth="0" Opacity="0.10"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <TextBlock Text="💙 Kapwa Impact" FontSize="13" FontWeight="Bold"
                                                           Foreground="#0077B6" Margin="0,0,0,6"/>
                                                <TextBlock FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap"
                                                           Text="Every item you claim is a connection. You're not just receiving things — you're receiving hope and dignity from your community."/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- ══ ITEM CATEGORIES — floating tall cards, no harsh outer border ══ -->
                                <Border CornerRadius="16" Margin="0,0,0,0" Padding="18,16"
                                        BorderThickness="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                            <GradientStop Color="#66FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                                    </Border.Effect>

                                    <StackPanel>
                                        <TextBlock Text="Item Categories" FontSize="15" FontWeight="Bold"
                                                   Foreground="#03045E" Margin="0,0,0,14"/>

                                        <!-- 6 columns: Clothing, Food, Electronics, Medicine, School, Others -->
                                        <UniformGrid Rows="1" Columns="6">

                                            <Button Command="{Binding BrowseByCategoryCommand}"
                                                    CommandParameter="Clothing"
                                                    Style="{StaticResource CardHoverBtn}" Margin="0,0,6,0">
                                                <Border CornerRadius="14" Background="White"
                                                        BorderThickness="0" Padding="4,18" MinHeight="100">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.06"/>
                                                    </Border.Effect>
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Border Width="46" Height="46" CornerRadius="23"
                                                                Background="#E8F4FD" Margin="0,0,0,10">
                                                            <TextBlock Text="👕" FontSize="22"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Clothing" FontSize="12" FontWeight="Bold"
                                                                   Foreground="#03045E" HorizontalAlignment="Center"
                                                                   TextWrapping="Wrap" TextAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Button>

                                            <Button Command="{Binding BrowseByCategoryCommand}"
                                                    CommandParameter="Food"
                                                    Style="{StaticResource CardHoverBtn}" Margin="3,0,3,0">
                                                <Border CornerRadius="14" Background="White"
                                                        BorderThickness="0" Padding="4,18" MinHeight="100">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.06"/>
                                                    </Border.Effect>
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Border Width="46" Height="46" CornerRadius="23"
                                                                Background="#FDE8E8" Margin="0,0,0,10">
                                                            <TextBlock Text="🍽️" FontSize="22"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Food" FontSize="12" FontWeight="Bold"
                                                                   Foreground="#03045E" HorizontalAlignment="Center"
                                                                   TextWrapping="Wrap" TextAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Button>

                                            <Button Command="{Binding BrowseByCategoryCommand}"
                                                    CommandParameter="Electronics"
                                                    Style="{StaticResource CardHoverBtn}" Margin="3,0,3,0">
                                                <Border CornerRadius="14" Background="White"
                                                        BorderThickness="0" Padding="4,18" MinHeight="100">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.06"/>
                                                    </Border.Effect>
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Border Width="46" Height="46" CornerRadius="23"
                                                                Background="#F4E8FD" Margin="0,0,0,10">
                                                            <TextBlock Text="💻" FontSize="22"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Electronics" FontSize="11" FontWeight="Bold"
                                                                   Foreground="#03045E" HorizontalAlignment="Center"
                                                                   TextWrapping="Wrap" TextAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Button>

                                            <Button Command="{Binding BrowseByCategoryCommand}"
                                                    CommandParameter="Medicine"
                                                    Style="{StaticResource CardHoverBtn}" Margin="3,0,3,0">
                                                <Border CornerRadius="14" Background="White"
                                                        BorderThickness="0" Padding="4,18" MinHeight="100">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.06"/>
                                                    </Border.Effect>
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Border Width="46" Height="46" CornerRadius="23"
                                                                Background="#E8FDF4" Margin="0,0,0,10">
                                                            <TextBlock Text="💊" FontSize="22"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Medicine" FontSize="12" FontWeight="Bold"
                                                                   Foreground="#03045E" HorizontalAlignment="Center"
                                                                   TextWrapping="Wrap" TextAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Button>

                                            <Button Command="{Binding BrowseByCategoryCommand}"
                                                    CommandParameter="School Supplies"
                                                    Style="{StaticResource CardHoverBtn}" Margin="3,0,3,0">
                                                <Border CornerRadius="14" Background="White"
                                                        BorderThickness="0" Padding="4,18" MinHeight="100">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.06"/>
                                                    </Border.Effect>
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Border Width="46" Height="46" CornerRadius="23"
                                                                Background="#FDF4E8" Margin="0,0,0,10">
                                                            <TextBlock Text="🎒" FontSize="22"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="School" FontSize="12" FontWeight="Bold"
                                                                   Foreground="#03045E" HorizontalAlignment="Center"
                                                                   TextWrapping="Wrap" TextAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Button>

                                            <!-- NEW: Others category -->
                                            <Button Command="{Binding BrowseByCategoryCommand}"
                                                    CommandParameter="Others"
                                                    Style="{StaticResource CardHoverBtn}" Margin="6,0,0,0">
                                                <Border CornerRadius="14" Background="White"
                                                        BorderThickness="0" Padding="4,18" MinHeight="100">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.06"/>
                                                    </Border.Effect>
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Border Width="46" Height="46" CornerRadius="23"
                                                                Background="#F0F0F0" Margin="0,0,0,10">
                                                            <TextBlock Text="📦" FontSize="22"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Others" FontSize="12" FontWeight="Bold"
                                                                   Foreground="#03045E" HorizontalAlignment="Center"
                                                                   TextWrapping="Wrap" TextAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Button>

                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                                <!-- ── END ITEM CATEGORIES ── -->

                            </StackPanel>
                            <!-- end left column -->

                            <!-- ══ RIGHT COLUMN — MESSAGES (maximized, no fixed height) ══ -->
                            <Border Grid.Column="2" CornerRadius="16" BorderThickness="0" Margin=" 0,0,0,20"
                                    VerticalAlignment="Stretch">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                                </Border.Effect>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <StackPanel Grid.Row="0" Margin="16,14,16,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Messages" FontSize="14" FontWeight="Bold"
                                                       Foreground="#03045E" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Command="{Binding ChatCommand}"
                                                    Content="See All →" Background="Transparent"
                                                    BorderThickness="0" Foreground="#0077B6" FontSize="11"
                                                    Cursor="Hand" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Height="1" Margin="0,10,0,0">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#33CAF0F8" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                    </StackPanel>

                                    <!-- Chat user list with PROFILE PICTURES -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="260">
                                        <ItemsControl ItemsSource="{Binding RecentChats}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="14,10" Cursor="Hand" Background="Transparent">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.OpenChatWithCommand,
                                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#0F00B4D8"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="42"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Avatar: profile pic or default -->
                                                            <Border Width="38" Height="38" CornerRadius="19"
                                                                    ClipToBounds="True" Background="#EBF7FB">
                                                                <Grid>
                                                                    <!-- Default avatar -->
                                                                    <TextBlock Text="👤" FontSize="18"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasProfilePic}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <!-- Profile picture -->
                                                                    <Image Source="{Binding ProfilePicturePath}"
                                                                           Stretch="UniformToFill">
                                                                        <Image.Clip>
                                                                            <EllipseGeometry RadiusX="19" RadiusY="19" Center="19,19"/>
                                                                        </Image.Clip>
                                                                        <Image.Style>
                                                                            <Style TargetType="Image">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasProfilePic}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Image.Style>
                                                                    </Image>
                                                                </Grid>
                                                            </Border>

                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                                        Margin="10,0,8,0">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontSize="13" FontWeight="SemiBold"
                                                                           Foreground="#03045E"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding LastMessage}"
                                                                           FontSize="11" Foreground="#5E7A8A"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,2,0,0"/>
                                                            </StackPanel>

                                                            <Border Grid.Column="2" CornerRadius="10"
                                                                    Background="#00B4D8" Padding="6,2"
                                                                    VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasUnread}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding UnreadCount}"
                                                                           FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Empty state -->
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Margin="16,20">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasNoChats}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="💬" FontSize="32" HorizontalAlignment="Center"
                                                   Opacity="0.5" Margin="0,0,0,8"/>
                                        <TextBlock Text="No messages yet" FontSize="12"
                                                   Foreground="#5E7A8A" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Open Messages button -->
                                    <Button Grid.Row="2" Command="{Binding ChatCommand}"
                                            Margin="14,8,14,14" Height="36"
                                            BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="10" Background="#EBF7FB">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="Open Messages" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#0077B6"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <!-- ── END RIGHT COLUMN ── -->

                        </Grid>
                        <!-- ── END ROW A ── -->

                        <!-- ══ ROW B: NEEDS WISHLIST carousel ══ -->
                        <StackPanel Margin="0,4,0,20">
                            <TextBlock Text="Needs Wishlist" FontSize="16" FontWeight="Bold"
                                       Foreground="#03045E" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left arrow — fully clickable -->
                                <Button Grid.Column="0"
                                        Command="{Binding CarouselLeftCommand}"
                                        Width="36" Height="36" Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="18" Background="#CCF0FAFF"
                                                    BorderBrush="#9090E0EF" BorderThickness="1"
                                                    x:Name="LeftBd">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="LeftBd" Property="Background" Value="#AA90E0EF"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="LeftBd" Property="Background" Value="#7700B4D8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="‹" FontSize="22" FontWeight="Bold"
                                               Foreground="#0077B6" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Margin="0,-3,1,0"/>
                                </Button>

                                <!-- Carousel scroll host — named for code-behind wiring -->
                                <ScrollViewer Grid.Column="1"
                                              x:Name="NeedsCarouselScroller"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Disabled">
                                    <StackPanel Orientation="Horizontal">

                                        <ItemsControl ItemsSource="{Binding MyNeedsPosts}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="220" Margin="0,0,14,0" CornerRadius="16"
                                                            ClipToBounds="True" BorderThickness="1">
                                                        <Border.BorderBrush>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="White" Offset="0"/>
                                                                <GradientStop Color="#33FFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.BorderBrush>
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                                                <GradientStop Color="#AAFFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#00B4D8" BlurRadius="12" ShadowDepth="0" Opacity="0.12"/>
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <!-- Image area -->
                                                            <Border Height="140" ClipToBounds="True">
                                                                <Grid>
                                                                    <Border Background="#EBF7FB"/>
                                                                    <TextBlock Text="📝" FontSize="40"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center" Opacity="0.5">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <Image Source="{Binding ImagePath}" Stretch="UniformToFill">
                                                                        <Image.Style>
                                                                            <Style TargetType="Image">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Image.Style>
                                                                    </Image>
                                                                    <!-- Urgency badge -->
                                                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                            Margin="0,8,8,0" CornerRadius="8" Padding="8,3">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="#0077B6"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Urgency}" Value="High">
                                                                                        <Setter Property="Background" Value="#C0304A"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Urgency}" Value="Medium">
                                                                                        <Setter Property="Background" Value="#B8860B"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Urgency}" Value="Low">
                                                                                        <Setter Property="Background" Value="#185FA5"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding Urgency}"
                                                                                   FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>

                                                            <!-- Card info -->
                                                            <StackPanel Margin="10,8,10,10">
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontSize="12" FontWeight="Bold"
                                                                           Foreground="#03045E"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBlock Text="{Binding Org_Name}"
                                                                           FontSize="10" Foreground="#0077B6"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBlock Text="{Binding Description}"
                                                                           FontSize="10" Foreground="#5E7A8A"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,0,0,10"/>
                                                                <!-- Approval status badge -->
                                                                <Border CornerRadius="8" Padding="8,3" HorizontalAlignment="Left"
        Margin="0,4,0,8"
        Background="{Binding ApprovalBadgeBackground}">
                                                                    <TextBlock Text="{Binding ApprovalBadgeText}"
               FontSize="10" FontWeight="SemiBold"
               Foreground="{Binding ApprovalBadgeTextColor}"/>
                                                                </Border>

                                                                <!-- Rejection reason — only when rejected -->
                                                                <Border CornerRadius="6" Padding="8,4" Margin="0,0,0,6"
        Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasRejectionNote}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock FontSize="10" Foreground="#991B1B" TextWrapping="Wrap">
        <Run Text="Reason: " FontWeight="SemiBold"/>
        <Run Text="{Binding RejectionNote}"/>
                                                                    </TextBlock>
                                                                </Border>

                                                                <!-- Edit Needs button — passes the NeedsPostModel as param -->
                                                                <Button Height="30" BorderThickness="0" Cursor="Hand"
                                                                        Command="{Binding DataContext.EditNeedsPostCommand,
                                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="Bd" CornerRadius="8">
                                                                                <Border.Background>
                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                        <GradientStop Color="#00A8E8" Offset="0"/>
                                                                                        <GradientStop Color="#0077B6" Offset="1"/>
                                                                                    </LinearGradientBrush>
                                                                                </Border.Background>
                                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                                  VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                    <TextBlock Text="✏️ Edit Needs"
                                                                               FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Add Needs button -->
                                        <Button Command="{Binding NeedsWishlistCommand}"
                                                Width="220" Margin="0,0,0,0"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="16" Background="#18CAF0F8"
                                                            BorderBrush="#7090E0EF" BorderThickness="2">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.9"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="+" FontSize="42" FontWeight="Light"
                                                           Foreground="#0077B6" HorizontalAlignment="Center" Opacity="0.7"/>
                                                <TextBlock Text="Add Needs Post" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#0077B6" HorizontalAlignment="Center"
                                                           Opacity="0.8" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Button>

                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Right arrow -->
                                <Button Grid.Column="2"
                                        Command="{Binding CarouselRightCommand}"
                                        Width="36" Height="36" Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="18" Background="#CCF0FAFF"
                                                    BorderBrush="#9090E0EF" BorderThickness="1"
                                                    x:Name="RightBd">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RightBd" Property="Background" Value="#AA90E0EF"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="RightBd" Property="Background" Value="#7700B4D8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="›" FontSize="22" FontWeight="Bold"
                                               Foreground="#0077B6" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Margin="1,-3,0,0"/>
                                </Button>

                            </Grid>
                        </StackPanel>
                        <!-- ── END NEEDS WISHLIST ── -->

                        <!-- ══ ROW C: TRANSACTION HISTORY ══ -->
                        <Border CornerRadius="16" Margin="0,0,0,24" BorderThickness="1.5" Padding="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#33FFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="20,16,20,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="📋 Transaction History" FontSize="15" FontWeight="Bold"
                                               Foreground="#03045E" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TransactionStatus}"
                                               FontSize="11" Foreground="#5E7A8A" VerticalAlignment="Center"/>
                                </Grid>
                                <Rectangle Height="1" Margin="20,0,20,12">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#33CAF0F8" Offset="0"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <!-- Table header -->
                                <Border Background="#F0FAFF" Margin="12,0,12,0" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Item"         FontSize="11" FontWeight="Bold" Foreground="#0077B6"/>
                                        <TextBlock Grid.Column="1" Text="Donor"        FontSize="11" FontWeight="Bold" Foreground="#0077B6"/>
                                        <TextBlock Grid.Column="2" Text="Organization" FontSize="11" FontWeight="Bold" Foreground="#0077B6"/>
                                        <TextBlock Grid.Column="3" Text="Handoff"      FontSize="11" FontWeight="Bold" Foreground="#0077B6"/>
                                        <TextBlock Grid.Column="4" Text="Date"         FontSize="11" FontWeight="Bold" Foreground="#0077B6"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <!-- Transaction rows -->
                                <ItemsControl ItemsSource="{Binding Transactions}" Margin="12,0,12,12">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,10" BorderBrush="#EBF7FB" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Item_Name}" FontSize="13"
                                                                   FontWeight="SemiBold" Foreground="#03045E"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Category_Name}" FontSize="11" Foreground="#0077B6"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Beneficiary_Name}"
                                                               FontSize="12" Foreground="#03045E" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Organization_Name}"
                                                               FontSize="12" Foreground="#5E7A8A" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Handoff_Type}"
                                                               FontSize="12" Foreground="#5E7A8A" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding Claim_Date, StringFormat='MMM d, yyyy'}"
                                                               FontSize="11" Foreground="#5E7A8A" VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty state -->
                                <StackPanel HorizontalAlignment="Center" Margin="16,20,16,20">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasNoTransactions}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="📜" FontSize="28" HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8"/>
                                    <TextBlock Text="No received donations yet." FontSize="12"
                                               Foreground="#5E7A8A" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- ── END TRANSACTION HISTORY ── -->

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>