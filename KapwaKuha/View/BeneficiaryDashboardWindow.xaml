<Window x:Class="KapwaKuha.View.BeneficiaryDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:BeneficiaryDashboardDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Beneficiary Dashboard"
        Height="920" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" ResizeMode="CanResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.05"
               Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center"
               Height="2808"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="0"
                    Style="{StaticResource AnimatedSidebarStyle}"
                    BorderThickness="0,0,1,0">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="#4D0077B6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,24,20,16">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="38" Height="38" Margin="0,0,4,0">
                                <Image Source="https://i.imgur.com/FHFRQxB.png"
                                       Width="60" Height="60"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                                <Run Foreground="#FF03045E" Text="Kapwa"/>
                                <Run Foreground="#FF00B4D8" Text="Kuha"/>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="Beneficiary Portal" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#0077B6" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding UserLabel}" FontSize="11"
                                   Foreground="#5E7A8A" Margin="0,4,0,0"/>
                        <Rectangle Height="1" Margin="0,16,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#330077B6" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="12,0">
                        <Button Command="{Binding ClaimTrackerCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Claim Tracker" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <Button Command="{Binding ClaimHistoryCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Claim History" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <Button Command="{Binding BrowseItemsCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛍️" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Browse Items" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <Button Command="{Binding NeedsWishlistCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Needs Wishlist" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <Button Command="{Binding EditNeedsPostsCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✏️" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Edit My Needs" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <Button Command="{Binding ChatCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💬" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Messages" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="12,0,12,24">
                        <Rectangle Height="1" Margin="8,0,8,16">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A0077B6" Offset="0"/>
                                    <GradientStop Color="#330077B6" Offset="0.5"/>
                                    <GradientStop Color="#1A0077B6" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Button Command="{Binding LogoutCommand}"
                                Style="{StaticResource CardHoverBtn}" Padding="0">
                            <Border CornerRadius="12" Padding="12,12" Background="#1AC0304A">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬅" Margin="0,0,12,0" Foreground="#C0304A" FontSize="14"/>
                                    <TextBlock Text="Log Out" Foreground="#C0304A"
                                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#AAFFFFFF">
                    <Border.Effect>
                        <DropShadowEffect Color="#0077B6" BlurRadius="10" ShadowDepth="0" Opacity="0.10"/>
                    </Border.Effect>
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding HamburgerCommand}"
                                Content="☰" Foreground="#03045E" Background="Transparent"
                                BorderThickness="0" FontSize="22" Cursor="Hand"
                                VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1" Text="{Binding WelcomeText}"
                                   Foreground="#03045E" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="14,0,0,0"/>

                        <Border Grid.Column="2" CornerRadius="20" Padding="4,4,12,4" VerticalAlignment="Center"
                                Background="#E6FFFFFF" BorderBrush="#B390E0EF" BorderThickness="1"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding MyBAccountCommand}"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal">

                                <!-- Circular profile picture — top-right of both dashboards -->
                                <Border Width="36" Height="36" CornerRadius="18" ClipToBounds="True" Cursor="Hand" Margin="0,0,8,0">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding MyAccountCommand}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Border Background="#EBF7FB" CornerRadius="18"/>

                                        <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Image Source="{Binding ProfilePicturePath}" Stretch="UniformToFill">

                                            <Image.Clip>
                                                <EllipseGeometry RadiusX="18" RadiusY="18" Center="18,18" />
                                            </Image.Clip>

                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Grid>
                                </Border>

                                <TextBlock Text="{Binding UserLabel}" FontSize="12"
                                           Foreground="#03045E" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text=" ▼" FontSize="9" Foreground="#5E7A8A" VerticalAlignment="Center" Margin="6,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="28,28,28,0">
                    <StackPanel>

                        <TextBlock Text="How can we help you today?"
                                   FontSize="20" FontWeight="Bold" Foreground="#03045E"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Browse items, track your claims, or post your organization's needs."
                                   FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,24"/>

                        <UniformGrid Rows="3" Columns="2" Margin="0,0,0,28">
                            <Button Command="{Binding ClaimTrackerCommand}"
                                    Style="{StaticResource CardHoverBtn}" Margin="0,0,14,14">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="📦" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Claim Tracker" FontSize="15"
                                                   FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Track your received donations"
                                                   FontSize="11" Foreground="#5E7A8A"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding BrowseItemsCommand}"
                                    Style="{StaticResource CardHoverBtn}" Margin="0,0,0,14">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="🛍️" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Browse Items" FontSize="15"
                                                   FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Explore available donations"
                                                   FontSize="11" Foreground="#5E7A8A"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding NeedsWishlistCommand}"
                                    Style="{StaticResource CardHoverBtn}" Margin="0,0,14,14">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="📝" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Needs Wishlist" FontSize="15"
                                                   FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Post urgent needs for your org"
                                                   FontSize="11" Foreground="#5E7A8A"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding ChatCommand}"
                                    Style="{StaticResource CardHoverBtn}" Margin="0,0,0,14">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="💬" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Messages" FontSize="15"
                                                   FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Chat with donors"
                                                   FontSize="11" Foreground="#5E7A8A"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding ClaimHistoryCommand}"
                                    Style="{StaticResource CardHoverBtn}" Margin="0,0,14,0">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="📋" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Claim History" FontSize="15"
                                                   FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="View your past received items"
                                                   FontSize="11" Foreground="#5E7A8A"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding EditNeedsPostsCommand}"
                                    Style="{StaticResource CardHoverBtn}" Margin="0,0,0,0">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="✏️" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Edit My Needs" FontSize="15"
                                                   FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Manage your requested items"
                                                   FontSize="11" Foreground="#5E7A8A"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </UniformGrid>

                        <Border CornerRadius="16" Margin="0,0,0,28" BorderThickness="1" MinHeight="250">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#33FFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="20,16,20,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋 " FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="My Received Donations" FontSize="16"
                           FontWeight="Bold" Foreground="#03045E"
                           VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TransactionStatus}"
                       FontSize="11" Foreground="#5E7A8A" Margin="0,3,0,0"/>
                                </StackPanel>

                                <Grid Grid.Row="1">

                                    <DataGrid x:Name="DonationsGrid" ItemsSource="{Binding Transactions}"
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      CanUserDeleteRows="False" IsReadOnly="True"
                      SelectionMode="Single" Background="Transparent"
                      BorderThickness="0" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EBF7FB"
                      RowBackground="White" AlternatingRowBackground="#F7FBFD"
                      AlternationCount="2"
                      ColumnHeaderHeight="36" RowHeight="56" FontSize="12"
                      MaxHeight="260" Margin="0,0,0,8">

                                        <DataGrid.Style>
                                            <Style TargetType="DataGrid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Style>

                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                                <Setter Property="Background" Value="#EBF7FB"/>
                                                <Setter Property="Foreground" Value="#0077B6"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="12,0"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>

                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Photo" Width="60" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Width="44" Height="44" CornerRadius="8" ClipToBounds="True" Margin="4,4">
                                                            <Grid>
                                                                <Border Background="#EBF7FB"/>
                                                                <TextBlock Text="📦" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <Image Source="{Binding Item_ImagePath}" Stretch="UniformToFill">
                                                                    <Image.Style>
                                                                        <Style TargetType="Image">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Image.Style>
                                                                </Image>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="Claim ID" 
                    Binding="{Binding Claim_ID}" 
                    Width="90" 
                    IsReadOnly="True">
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="DataGridCell">
                                                                    <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                                                                        <ContentPresenter VerticalAlignment="Center" Margin=" -20,0,0,0"
                                              HorizontalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Item Received" Binding="{Binding Item_Name}" Width="*" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Category" Binding="{Binding Category_Name}" Width="110" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="Foreground" Value="#0077B6"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="From Donor" Binding="{Binding Donor_FullName}" Width="130" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Received On" Binding="{Binding ClaimDateDisplay}" Width="150" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="Foreground" Value="#5E7A8A"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30,0,50">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Items.Count, ElementName=DonationsGrid}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <TextBlock Text="📭" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.8"/>
                                        <TextBlock Text="No donations yet." FontSize="14" Foreground="#03045E" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Items you receive will appear here once released." FontSize="12" Foreground="#5E7A8A" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>

                                </Grid>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>