<Window x:Class="KapwaKuha.View.BannedAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Account Suspended" Height="380" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" FontFamily="Segoe UI"
        Background="#F4F8FA">

    <Grid>
        <Border Margin="20" CornerRadius="16" Background="White" 
                BorderBrush="#B390E0EF" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#0077B6" BlurRadius="12" ShadowDepth="0" Opacity="0.10"/>
            </Border.Effect>

            <Grid Margin="24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Width="48" Height="48" CornerRadius="24" 
                        Background="#FEE2E2" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Path Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z" 
                          Fill="#EF4444" Stretch="Uniform" Width="22" Height="22" 
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="1" Text="Account Access Restricted"
                           FontSize="18" FontWeight="Bold" Foreground="#03045E"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="2" Text="{Binding StrikesText}"
                           FontSize="13" FontWeight="SemiBold" Foreground="#EF4444"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Text="{Binding BanStatus}"
                           FontSize="12" Foreground="#DC2626"
                           HorizontalAlignment="Center" Margin="0,20,0,12"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <Border Grid.Row="3" Background="#F0F8FB" CornerRadius="10" Padding="14,10" Margin="0,0,0,12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Text="{Binding Reason}" FontSize="13" Foreground="#03045E" LineHeight="18"
                                   TextWrapping="Wrap" TextAlignment="Center" FontWeight="Medium" 
                                   VerticalAlignment="Center"/>
                    </ScrollViewer>
                </Border>

                <TextBlock Grid.Row="4" Text="If you believe this restriction is an error, please contact our support desk via support@kapwakuha.ph"
                           FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="10,0,10,16"/>

                <Button Grid.Row="5" Content="Return to Login" Click="Close_Click" Height="38" Width="160"
                        Background="#03045E" Foreground="White" FontWeight="Bold" FontSize="12"
                        BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" CornerRadius="19" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#0077B6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>
        </Border>
    </Grid>
</Window>