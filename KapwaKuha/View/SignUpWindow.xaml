<Window x:Class="KapwaKuha.View.SignUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Create Account"
        Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.10"
               Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center"
               Height="2808" RenderTransformOrigin="0.5,0.5"/>

        <Ellipse Width="380" Height="380" Opacity="0.13"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Border Width="1080" Height="Auto" MaxHeight="720"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                CornerRadius="22" Style="{StaticResource GlassCard}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL: Picture + label -->
                <Grid Grid.Column="0" Margin="32,36,32,36">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Command="{Binding BackCommand}"
                            Style="{StaticResource LinkBtn}"
                            Content="← Back to Login"
                            HorizontalAlignment="Left"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid Width="120" Height="120" HorizontalAlignment="Center" Margin="0,0,0,16"
                              Cursor="Hand" ToolTip="Click to upload photo">
                            <Grid.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding BrowsePictureCommand}"/>
                            </Grid.InputBindings>

                            <Border Width="120" Height="120" CornerRadius="60" ClipToBounds="True"
                                    Background="#EBF7FB" BorderBrush="#B390E0EF" BorderThickness="2">
                                <Grid>
                                    <TextBlock Text="👤" FontSize="54" HorizontalAlignment="Center"
                                               VerticalAlignment="Top" Margin="0,16,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Ellipse>
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding ProfilePicturePath}" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </Border>

                            <Border Width="36" Height="36" CornerRadius="18" Background="White"
                                    BorderBrush="#0077B6" BorderThickness="1.5"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,0">
                                <TextBlock Text="📷" FontSize="16" HorizontalAlignment="Center"
                                           VerticalAlignment="Top" Margin="0,4,0,0"/>
                            </Border>
                        </Grid>

                        <TextBlock Text="Profile Picture" FontSize="15" FontWeight="Bold"
                                   Foreground="#03045E" HorizontalAlignment="Center"/>
                        <TextBlock Text="(Optional)" FontSize="13" Foreground="#5E7A8A"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding RoleLabel}" FontSize="28" FontWeight="Bold"
                                   Foreground="#03045E" TextWrapping="Wrap" LineHeight="34"/>
                        <TextBlock Text="Fill in your details to create a secure account."
                                   FontSize="14" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Column="1" BorderBrush="#1A03045E" BorderThickness="1,0,0,0" HorizontalAlignment="Left"/>

                <!-- RIGHT PANEL: Form fields -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="40,36,40,36">

                        <!-- Error banner -->
                        <Border Background="#4DFFF0F5" CornerRadius="8" Margin="0,0,0,24" Padding="14,10"
                                Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0304A"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Row 1: First Name + Last Name -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="First Name" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding FName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Last Name" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding LName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: Username + Contact -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Username" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Contact Number" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding Contact, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Email row -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Email Address" FontSize="13" FontWeight="SemiBold"
                   Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}" Height="44">
                                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent" BorderThickness="0"
                     FontSize="14" Padding="12,0" VerticalContentAlignment="Center"
                     Foreground="#0A2540"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Row 3 (DONOR ONLY): Address -->
                        <Grid Margin="0,0,0,20"
                              Visibility="{Binding IsDonor, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Home / Delivery Address" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding DonorAddress, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Row 3 (BENEFICIARY ONLY): Sex + Org Name -->
                        <Grid Margin="0,0,0,20"
                              Visibility="{Binding IsBeneficiary, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Sex" FontSize="13" FontWeight="SemiBold"
               Foreground="#03045E" Margin="0,0,0,8"/>
                                <ComboBox SelectedValue="{Binding SelectedSex, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
          SelectedValuePath="Content"
          Height="39">
                                    <ComboBoxItem Content="Select Sex" IsEnabled="False" Visibility="Collapsed"/>
                                    <ComboBoxItem Content="Male" IsSelected="True"/>
                                    <ComboBoxItem Content="Female"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Organization Name" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding SelectedOrgName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Row 4 (BENEFICIARY ONLY): Org Location + Org Contact -->
                        <Grid Margin="0,0,0,20"
                              Visibility="{Binding IsBeneficiary, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Organization Location" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding OrgAddress, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Organization Contact" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding OrgContact, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Row 5: Password + Confirm (with Show toggle) -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Password" FontSize="13" FontWeight="SemiBold"
                   Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}" Height="44">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <PasswordBox x:Name="PwBox" Height="44" Background="Transparent"
                             BorderThickness="0" Foreground="#03045E"
                             FontSize="14" Padding="14,12,4,0"
                             Panel.ZIndex="1"/>
                                        <TextBox x:Name="PwTextBox" Height="44" Background="Transparent"
                         BorderThickness="0" Foreground="#03045E"
                         FontSize="14" Padding="14,0,4,0"
                         VerticalContentAlignment="Center"
                         Visibility="Collapsed"/>
                                        <Button Grid.Column="1" x:Name="ShowPwBtn"
                                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Width="32" Height="32"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" ToolTip="Show/Hide password"
                                                Click="ShowPwBtn_Click">
                                            <TextBlock x:Name="ShowPwIcon" Text="👁" FontSize="13"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Confirm Password" FontSize="13" FontWeight="SemiBold"
                   Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}" Height="44">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <PasswordBox x:Name="ConfirmPwBox" Height="44" Background="Transparent"
                             BorderThickness="0" Foreground="#03045E"
                             FontSize="14" Padding="14,12,4,0"
                             Panel.ZIndex="1"/>
                                        <TextBox x:Name="ConfirmPwTextBox" Height="44" Background="Transparent"
                         BorderThickness="0" Foreground="#03045E"
                         FontSize="14" Padding="14,0,4,0"
                         VerticalContentAlignment="Center"
                         Visibility="Collapsed"/>
                                        <Button Grid.Column="1" x:Name="ShowConfirmPwBtn"
                                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Width="32" Height="32"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" ToolTip="Show/Hide password"
                                                Click="ShowConfirmPwBtn_Click">
                                            <TextBlock x:Name="ShowConfirmPwIcon" Text="👁" FontSize="13"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Row 6: Security Question + Answer -->
                        <Grid Margin="0,0,0,36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Security Question" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <ComboBox SelectedValue="{Binding SecurityQuestion}" SelectedValuePath="Content"
                                              Height="44" Background="Transparent" BorderThickness="0"
                                              Foreground="#03045E" FontSize="14" Padding="14,0"
                                              VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="What is your pet name?" IsSelected="True"/>
                                        <ComboBoxItem Content="What city were you born in?"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Security Answer" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding SecurityAnswer, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="RegisterBtn" Style="{StaticResource GradientButton}"
                                Height="48" Click="RegisterBtn_Click">
                            <TextBlock Text="Create Account →" FontSize="15" FontWeight="Bold"/>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>