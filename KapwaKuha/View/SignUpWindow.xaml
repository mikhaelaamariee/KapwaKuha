<Window x:Class="KapwaKuha.View.SignUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Create Account"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" FontFamily="Segoe UI">
    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White"        Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.10"
               Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center"
               Height="2808" RenderTransformOrigin="0.5,0.5"/>
        <Ellipse Width="380" Height="380" Opacity="0.13"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="280" Height="280" Opacity="0.10"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-60,0,0,-60">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0077B6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Width="560" Margin="0,32,0,32" CornerRadius="22" Padding="36,30"
                    Style="{StaticResource GlassCard}">

                <StackPanel>
                    <Button Command="{Binding BackCommand}"
                            Style="{StaticResource LinkBtn}"
                            Content="← Back to Login"
                            HorizontalAlignment="Left" Margin="0,0,0,14"/>

                    <TextBlock Text="{Binding RoleLabel}" FontSize="24" FontWeight="Bold"
                               Foreground="#03045E" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Fill in all fields to register your account."
                               FontSize="12" Foreground="#5E7A8A"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <Border Background="#4DFFF0F5" CornerRadius="8" Padding="12,8" Margin="0,0,0,14"
                            Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0304A"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="Profile Picture (optional)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#03045E" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <Grid Width="72" Height="72" HorizontalAlignment="Center" Cursor="Hand" ToolTip="Click to upload photo">
                            <Grid.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding BrowsePictureCommand}"/>
                            </Grid.InputBindings>

                            <Border Width="72" Height="72" CornerRadius="36" ClipToBounds="True" 
        Background="#EBF7FB" BorderBrush="#B390E0EF" BorderThickness="1.5">
                                <Grid>
                                    <TextBlock Text="👤" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Image Source="{Binding ProfilePicturePath}" Stretch="UniformToFill">
                                        <Image.Clip>
                                            <EllipseGeometry RadiusX="34.5" RadiusY="34.5" Center="34.5,34.5" />
                                        </Image.Clip>

                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </Border>

                            <Border Width="28" Height="28" CornerRadius="14" Background="White" 
            BorderBrush="#0077B6" BorderThickness="1.5"
            HorizontalAlignment="Right" VerticalAlignment="Bottom" 
            Margin="0,0,-4,-4">
                                <TextBlock Text="📷" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1"/>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First Name" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border Style="{StaticResource GlassInputBorder}" Margin="0">
                                <TextBox Text="{Binding FName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" Background="Transparent" BorderThickness="0"
                                         Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last Name" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border Style="{StaticResource GlassInputBorder}" Margin="0">
                                <TextBox Text="{Binding LName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" Background="Transparent" BorderThickness="0"
                                         Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,12"
                                Visibility="{Binding IsDonor, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Username" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#03045E" Margin="0,0,0,5"/>
                        <Border Style="{StaticResource GlassInputBorder}" Margin="0">
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" Background="Transparent" BorderThickness="0"
                                     Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <Grid Margin="0,0,0,12"
                          Visibility="{Binding IsBeneficiary, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sex" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>

                            <ComboBox SelectedValue="{Binding Sex}" Height="34"
                                          Background="Transparent" BorderThickness="0"
                                          Foreground="#03045E" FontSize="12" Padding="10,0">
                                <ComboBoxItem Content="Male"   IsSelected="True"/>
                                <ComboBoxItem Content="Female"/>
                            </ComboBox>

                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Organization" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>

                            <ComboBox
                                  ItemsSource="{Binding Organizations}"
                                  Height="34" Background="Transparent" BorderThickness="0"
                                  Foreground="#03045E" FontSize="12" Padding="10,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Item2}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Contact Number" FontSize="11" FontWeight="SemiBold"
                               Foreground="#03045E" Margin="0,0,0,5"/>
                    <Border Style="{StaticResource GlassInputBorder}">
                        <TextBox Text="{Binding Contact, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34" Background="Transparent" BorderThickness="0"
                                 Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                    </Border>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Password" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border Style="{StaticResource GlassInputBorder}" Margin="0">
                                <PasswordBox x:Name="PwBox" Height="34" Background="Transparent"
                                             BorderThickness="0" Foreground="#03045E"
                                             FontSize="12" Padding="0,8,0,0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Confirm Password" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border Style="{StaticResource GlassInputBorder}" Margin="0">
                                <PasswordBox x:Name="ConfirmPwBox" Height="34" Background="Transparent"
                                             BorderThickness="0" Foreground="#03045E"
                                             FontSize="12" Padding="0,8,0,0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Security Question" FontSize="11" FontWeight="SemiBold"
                               Foreground="#03045E" Margin="0,0,0,5"/>
                    <Border Style="{StaticResource GlassInputBorder}">
                        <ComboBox SelectedValue="{Binding SecurityQuestion}"
                                  SelectedValuePath="Content"
                                  Height="34" Background="Transparent" BorderThickness="0"
                                  Foreground="#03045E" FontSize="12" Padding="10,0">
                            <ComboBoxItem Content="What is your pet name?"  IsSelected="True"/>
                            <ComboBoxItem Content="What city were you born in?"/>
                        </ComboBox>
                    </Border>

                    <TextBlock Text="Security Answer" FontSize="11" FontWeight="SemiBold"
                               Foreground="#03045E" Margin="0,0,0,5"/>
                    <Border Style="{StaticResource GlassInputBorder}" Margin="0,0,0,24">
                        <TextBox Text="{Binding SecurityAnswer, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34" Background="Transparent" BorderThickness="0"
                                 Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                    </Border>

                    <Button x:Name="RegisterBtn"
                            Style="{StaticResource GradientButton}"
                            Click="RegisterBtn_Click">
                        <TextBlock Text="Create Account →"/>
                    </Button>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>