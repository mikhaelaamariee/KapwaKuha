<Window x:Class="KapwaKuha.View.IndependentBeneficiaryLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Independent Beneficiary Login"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="White">
            <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.02"
                   Width="1980" Height="2808"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Button Command="{Binding BackCommand}"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Style="{StaticResource LinkBtn}"
                    Content="← Back" Margin="40,40,0,0" FontSize="14"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Width="400" Margin="20,0">

                <TextBlock Text="INDEPENDENT LOGIN" FontSize="32" FontWeight="Black"
                           Foreground="#48CAE4" HorizontalAlignment="Center"/>
                <TextBlock Text="Sign in to your KapwaKuha account."
                           FontSize="14" Foreground="#6B7280"
                           HorizontalAlignment="Center" Margin="0,4,0,10"/>

                <!-- Username -->
                <Border Background="#F4F6F8" CornerRadius="12" Height="50" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="👤" Foreground="#9CA3AF" FontSize="16"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="UserEntry"
                                     Text="{Binding CurrentUser.UserID, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" FontSize="14"
                                     Padding="0,0,15,0" Panel.ZIndex="1"/>
                            <TextBlock IsHitTestVisible="False"
                                       Text="Enter your username"
                                       VerticalAlignment="Center" Padding="5,0,0,0"
                                       Foreground="Gray" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=UserEntry}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Password with Show toggle -->
                <Border Background="#F4F6F8" CornerRadius="12" Height="50" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔒" Foreground="#9CA3AF" FontSize="16"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBlock x:Name="PlaceholderText"
                                       Text="Enter your password" FontSize="14"
                                       Foreground="Gray" VerticalAlignment="Center"
                                       IsHitTestVisible="False" Margin="5,0,0,0"
                                       Visibility="Visible"/>
                            <PasswordBox x:Name="PwBox"
                                         BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" FontSize="14"
                                         Padding="0,0,5,0"
                                         PasswordChanged="PwBox_PasswordChanged"
                                         Panel.ZIndex="1"/>
                            <TextBox x:Name="PwTextBox"
                                     Text="{Binding PlainPassword, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" FontSize="14"
                                     Padding="0,0,5,0" Visibility="Collapsed"/>
                        </Grid>
                        <Button Grid.Column="2" x:Name="ShowPwBtn"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Width="36" Height="36"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="Show/Hide password"
                                Click="ShowPwBtn_Click">
                            <TextBlock x:Name="ShowPwIcon" Text="👁" FontSize="15"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Error banner -->
                <Border Background="#FEE2E2" CornerRadius="8" Padding="12,10" Margin="0,0,0,12"
                        Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                               FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </Border>

                <Button Content="Login Now"
                        Style="{StaticResource GradientButton}"
                        Margin="0,10,0,30" Height="50"
                        Click="LoginBtn_Click">
                    <Button.Background>
                        <LinearGradientBrush EndPoint="1,0">
                            <GradientStop Color="#FF00B4D8"/>
                            <GradientStop Color="#FF48CAE4" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Separator Grid.Column="0" Background="#E5E7EB" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="1" Text="Account Actions"
                               FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    <Separator Grid.Column="2" Background="#E5E7EB" Margin="12,0,0,0"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource OutlineBtn}"
                            Command="{Binding ForgotPasswordCommand}" Height="45">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔑" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Forgot Password" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource OutlineBtn}"
                            Command="{Binding SignUpCommand}" Height="45">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✨" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Create Account" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- OR divider -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Separator Grid.Column="0" Background="#E5E7EB" Margin="0,12,12,0"/>
                    <TextBlock Grid.Column="1" Text="or" FontSize="12" Margin=" 0,12,1,0"
       Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    <Separator Grid.Column="2" Background="#E5E7EB" Margin="10,12,0,0"/>
                </Grid>

                <!-- Google Sign-In button -->
                <Button Command="{Binding GoogleLoginCommand}"
Height="50" Margin="0,0,0,24"
Background="White" BorderBrush="#DADCE0" BorderThickness="1"
Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F8F9FA"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#E8EAED"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Viewbox Width="20" Height="20" Margin="0,0,12,0">
                            <Canvas Width="48" Height="48">
                                <Path Fill="#4285F4" Data="M44.5 20H24v8.5h11.8C34.7 33.9 30.1 37 24 37c-7.2 0-13-5.8-13-13s5.8-13 13-13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 5.1 29.6 3 24 3 12.4 3 3 12.4 3 24s9.4 21 21 21c10.5 0 20-7.8 20-21 0-1.4-.1-2.7-.5-4z"/>
                                <Path Fill="#34A853" Data="M6.3 14.7l7 5.1C15.2 16.4 19.2 14 24 14c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 5.1 29.6 3 24 3 16.3 3 9.7 7.9 6.3 14.7z"/>
                                <Path Fill="#FBBC05" Data="M24 45c5.8 0 10.8-1.9 14.4-5.2l-6.7-5.5C29.6 35.8 27 37 24 37c-6 0-11.1-4-12.9-9.5L4.1 33c3.5 6.8 10.2 12 19.9 12z"/>
                                <Path Fill="#EA4335" Data="M44.5 20H24v8.5h11.8c-1 3-3.3 5.5-6.3 7l6.7 5.5C40.2 37.3 44.5 31.1 44.5 20z"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Sign in with Google"
           FontSize="14" FontWeight="SemiBold"
           Foreground="#3C4043" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>

        <Border Grid.Column="1" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="#48CAE4" Offset="0.5"/>
                    <GradientStop Color="#0A2540" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Border Width="420" Height="550" CornerRadius="24"
                Background="#1AFFFFFF" BorderBrush="#4DFFFFFF" BorderThickness="1.5"
                HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.25" ShadowDepth="10"/>
                    </Border.Effect>

                    <Border CornerRadius="20" Margin="-64,-38,-64,0" Height="587" VerticalAlignment="Top">
                        <Border.Background>
                            <ImageBrush ImageSource="https://i.imgur.com/TQuDxg7.png" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                </Border>

                <Border Width="60" Height="60" Background="White" CornerRadius="30"
                HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-450,200,0,0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.15" ShadowDepth="5"/>
                    </Border.Effect>
                    <TextBlock Text="💙" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>