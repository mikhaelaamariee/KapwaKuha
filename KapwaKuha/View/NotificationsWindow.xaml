<Window x:Class="KapwaKuha.View.NotificationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Notifications"
        Height="720" Width="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0F8FF" Offset="0"/>
                <GradientStop Color="#E8F4FD" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Padding="20,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"
                Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔔" FontSize="22" Margin="0,0,10,0"/>
                    <TextBlock Text="Notifications" FontSize="20" FontWeight="Bold" Foreground="#0A2540"/>
                    <!-- Unread badge -->
                    <Border Background="#EF4444" CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                            Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding UnreadCount}" Foreground="White"
                                   FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Mark all read"
                            Style="{StaticResource LinkBtn}"
                            Command="{Binding MarkAllReadCommand}"
                            FontSize="12" Foreground="#0077B6" Margin="0,0,16,0"
                            Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="🔄"
                            Style="{StaticResource LinkBtn}"
                            Command="{Binding RefreshCommand}"
                            FontSize="14" Foreground="#6B7280"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1" Margin="16,16,16,16">
            <!-- Loading -->
            <TextBlock Text="Loading notifications..." FontSize="14" Foreground="#9CA3AF"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNoNotifications}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="🔕" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="No notifications yet" FontSize="16" FontWeight="SemiBold"
                           Foreground="#374151" HorizontalAlignment="Center"/>
                <TextBlock Text="You're all caught up! Check back later."
                           FontSize="13" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Notification list -->
            <ListView ItemsSource="{Binding Notifications}"
                      Background="Transparent" BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.Style>
                    <Style TargetType="ListView">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNoNotifications}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0,4"/>
                        <EventSetter Event="MouseLeftButtonUp"
                                     Handler="NotifItem_Clicked"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12" Padding="16,12" Margin="0,0,0,2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <!-- Unread: highlighted -->
                                        <DataTrigger Binding="{Binding IsRead}" Value="False">
                                            <Setter Property="Background" Value="#EFF6FF"/>
                                            <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding TypeIcon}"
                                           FontSize="22" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Message}"
                                               FontSize="13" Foreground="#0A2540"
                                               TextWrapping="Wrap" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Setter Property="Foreground" Value="#374151"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding TimeAgo}"
                                               FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                                </StackPanel>
                                <!-- Unread dot -->
                                <Ellipse Grid.Column="2" Width="8" Height="8"
                                         Fill="#3B82F6" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>