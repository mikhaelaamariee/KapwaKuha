<Window x:Class="KapwaKuha.View.NotificationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Notifications"
        Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border CornerRadius="20" Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="50" Opacity="0.3" ShadowDepth="10"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="20,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="SkyBlue" Offset="0"/>
                        <GradientStop Color="#0077B6" Offset="0.6"/>
                        <GradientStop Color="#00B4D8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid Margin="40,60,40,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Border Width="80" Height="80" CornerRadius="40" Background="#33FFFFFF" 
                                HorizontalAlignment="Left" Margin="0,0,0,24">
                            <TextBlock Text="🔔" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Notification Center" FontSize="32" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                        <TextBlock Text="Stay updated with your community hand-offs and system alerts." 
                                   FontSize="15" Foreground="#BAE6FD" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <Border Background="#1AFFFFFF" CornerRadius="16" Padding="24" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Unread Alerts" FontSize="14" Foreground="#E0F2FE" FontWeight="SemiBold"/>
                                    <TextBlock Text="Requires your attention" FontSize="12" Foreground="#93C5FD" Margin="0,4,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="#EF4444" CornerRadius="12" Padding="16,8"
                                        Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding UnreadCount}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                </Border>

                                <Border Grid.Column="1" Background="#10B981" CornerRadius="12" Padding="16,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasUnread}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="0" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <Button Command="{Binding MarkAllReadCommand}" Height="48" Margin="0,0,0,12" Cursor="Hand"
                                Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="10" Background="White" x:Name="bg">
                                        <TextBlock Text="✓ Mark All as Read" Foreground="#0A2540" FontSize="15" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Command="{Binding RefreshCommand}" Height="48" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="10" Background="#1AFFFFFF" BorderBrush="#4DFFFFFF" BorderThickness="1" x:Name="bg">
                                        <TextBlock Text="🔄 Refresh Feed" Foreground="White" FontSize="15" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="40,32,40,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="Recent Activity" FontSize="24" FontWeight="Bold" Foreground="#0A2540" VerticalAlignment="Center"/>

                    <Button Command="{Binding CloseCommand}" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Border Background="#E2E8F0" CornerRadius="20" Padding="16,8">
                            <TextBlock Text="✕ CLOSE" FontSize="13" FontWeight="Bold" Foreground="#475569"/>
                        </Border>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <Grid Grid.Row="1">
                    <TextBlock Text="⏳ Fetching latest updates..." FontSize="16" Foreground="#0077B6" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasNoNotifications}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="📭" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                        <TextBlock Text="No notifications yet" FontSize="20" FontWeight="Bold"
                                   Foreground="#0A2540" HorizontalAlignment="Center"/>
                        <TextBlock Text="You're all caught up! Check back later."
                                   FontSize="15" Foreground="#6B7280"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <ListView ItemsSource="{Binding Notifications}"
                              Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.Style>
                            <Style TargetType="ListView">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasNoNotifications}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Style>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,16,16"/>
                                <EventSetter Event="MouseLeftButtonUp" Handler="NotifItem_Clicked"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="20,16">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                            <Setter Property="BorderThickness" Value="1"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                    <Setter Property="Background" Value="#F0F9FF"/>
                                                    <Setter Property="BorderBrush" Value="#BAE6FD"/>
                                                    <Setter Property="BorderThickness" Value="4,1,1,1"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" 
                                                Background="#E0F2FE" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TypeIcon}" FontSize="20" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="8,0,24,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Message}" FontSize="15" Foreground="#0A2540"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                <Setter Property="Foreground" Value="#374151"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding TimeAgo}" FontSize="12" Foreground="#64748B" Margin="0,6,0,0"/>
                                        </StackPanel>

                                        <Ellipse Grid.Column="2" Width="10" Height="10" Fill="#3B82F6" 
                                                 VerticalAlignment="Center" Margin="0,0,8,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>