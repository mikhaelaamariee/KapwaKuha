<Window x:Class="KapwaKuha.View.IndependentBeneficiarySignUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Register as Independent Beneficiary"
        Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">
    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.10"
               Width="1980" Height="2808"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Border Width="1080" VerticalAlignment="Center" HorizontalAlignment="Center"
                CornerRadius="22" Style="{StaticResource GlassCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL -->
                <Grid Grid.Column="0" Margin="32,36,32,36">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Command="{Binding BackCommand}"
                            Style="{StaticResource LinkBtn}"
                            Content="← Back"
                            HorizontalAlignment="Left"/>

                    <!-- Profile picture uploader -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid Width="120" Height="120" HorizontalAlignment="Center"
                              Margin="0,0,0,16" Cursor="Hand" ToolTip="Click to upload photo">
                            <Grid.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding BrowsePictureCommand}"/>
                            </Grid.InputBindings>
                            <Border Width="120" Height="120" CornerRadius="60" ClipToBounds="True"
                                    Background="#EBF7FB" BorderBrush="#B390E0EF" BorderThickness="2">
                                <Grid>
                                    <TextBlock Text="👤" FontSize="54"
                                               HorizontalAlignment="Center" VerticalAlignment="Top"
                                               Margin="0,16,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Ellipse>
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding ProfilePicturePath}"
                                                        Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </Border>
                            <Border Width="36" Height="36" CornerRadius="18" Background="White"
                                    BorderBrush="#0077B6" BorderThickness="1.5"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,0">
                                <TextBlock Text="📷" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Top"
                                           Margin="0,4,0,0"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Profile Picture" FontSize="15" FontWeight="Bold"
                                   Foreground="#03045E" HorizontalAlignment="Center"/>
                        <TextBlock Text="(Optional)" FontSize="13" Foreground="#5E7A8A"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                        <TextBlock Text="Independent Beneficiary" FontSize="22" FontWeight="Bold"
                                   Foreground="#03045E" TextWrapping="Wrap" LineHeight="30"/>
                        <TextBlock Text="Register as an individual citizen seeking donation assistance."
                                   FontSize="13" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        <Border Background="#FEF3C7" CornerRadius="8" Padding="10,8" Margin="0,16,0,0">
                            <TextBlock Text="⏳ Your account will be reviewed by an Admin before activation."
                                       FontSize="12" Foreground="#92400E" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Column="1" BorderBrush="#1A03045E" BorderThickness="1,0,0,0"
                        HorizontalAlignment="Left"/>

                <!-- RIGHT PANEL: Form -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="40,36,40,36">

                        <!-- Error banner -->
                        <Border Background="#4DFFF0F5" CornerRadius="8" Margin="0,0,0,20" Padding="14,10"
                                Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0304A"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Row 1: First + Last Name -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="First Name" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding FName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Last Name" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding LName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: Username + Contact -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Username" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Contact Number" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding Contact, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Row 3: Sex + Address -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Sex" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}" Height="44">
                                    <ComboBox SelectedValue="{Binding SelectedSex}"
                                              Background="Transparent" BorderThickness="0"
                                              FontSize="14" Padding="10,0" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="Male"/>
                                        <ComboBoxItem Content="Female"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Address" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Row 4: Password + Confirm -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Password" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}" Height="44">
                                    <PasswordBox x:Name="PwBox"
                                                 Background="Transparent" BorderThickness="0"
                                                 FontSize="14" Padding="14,0"
                                                 VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Confirm Password" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}" Height="44">
                                    <PasswordBox x:Name="ConfirmPwBox"
                                                 Background="Transparent" BorderThickness="0"
                                                 FontSize="14" Padding="14,0"
                                                 VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Row 5: Security Question + Answer -->
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Security Question" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}" Height="44">
                                    <ComboBox SelectedValue="{Binding SecurityQuestion}"
                                              Background="Transparent" BorderThickness="0"
                                              FontSize="13" Padding="10,0" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="What is your pet name?"/>
                                        <ComboBoxItem Content="What is your mother's maiden name?"/>
                                        <ComboBoxItem Content="What city were you born in?"/>
                                        <ComboBoxItem Content="What is your favorite food?"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Security Answer" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource GlassInputBorder}">
                                    <TextBox Text="{Binding SecurityAnswer, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#03045E" FontSize="14" Padding="14,0"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Register button -->
                        <Button x:Name="RegisterBtn" Content="✨ Submit Registration"
                                Style="{StaticResource GradientButton}"
                                Height="52" FontSize="15" FontWeight="SemiBold"
                                Click="RegisterBtn_Click"/>

                        <!-- Loading indicator -->
                        <TextBlock Text="⏳ Submitting your registration..."
                                   FontSize="13" Foreground="#0077B6"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>