<Window x:Class="KapwaKuha.View.ChatListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Messages"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ChatListDesignViewModel, IsDesignTimeCreatable=True}"
        FontFamily="Segoe UI">

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.07" Width="1980"
               HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="💬 " FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Messages" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" CornerRadius="16" Margin="20,14,20,20" BorderThickness="1.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="#33FFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,16,20,10">
                        <TextBlock Text="Conversations" FontSize="15" FontWeight="Bold"
                                   Foreground="#03045E"/>
                        <TextBlock Text="Search beneficiaries by name or username, then click to chat."
                                   FontSize="11" Foreground="#5E7A8A" Margin="0,3,0,10"/>
                        <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                Background="White" Padding="10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center"
                                           FontSize="13" Margin="0,0,6,0" Foreground="#5E7A8A"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="36" Background="Transparent" BorderThickness="0"
                                         Foreground="#0A2540" FontSize="13" VerticalContentAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ChatUsers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,1" Cursor="Hand" Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenChatCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F0F8FB"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid Margin="16,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="46"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Clickable avatar -->
                                            <Button Grid.Column="0"
        Command="{Binding DataContext.ViewProfileCommand,
            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
        CommandParameter="{Binding}"
        Background="Transparent" BorderThickness="0" Cursor="Hand"
        ToolTip="View profile" Width="46" Height="46">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid Width="46" Height="46">
                                                            <Border CornerRadius="23">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                        <GradientStop Color="#00B4D8" Offset="0"/>
                                                                        <GradientStop Color="#0077B6" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                                <TextBlock Text="👤" FontSize="22" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Border CornerRadius="23">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Border.Background>
                                                                    <ImageBrush ImageSource="{Binding ProfilePicturePath}" Stretch="UniformToFill"/>
                                                                </Border.Background>
                                                            </Border>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- Name + last message — clicking name opens profile -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,2,0,2">
                                                <Button Background="Transparent" BorderThickness="0"
            HorizontalAlignment="Left" Cursor="Hand"
            Command="{Binding DataContext.ViewProfileCommand,
                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
            CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <TextBlock x:Name="nameLnk"
                           Text="{Binding DisplayName}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#03045E"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="nameLnk" Property="Foreground" Value="#0077B6"/>
                                                                    <Setter TargetName="nameLnk" Property="TextDecorations" Value="Underline"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <TextBlock Text="{Binding SubText}"
               FontSize="10" Foreground="#0077B6"
               Margin="0,1,0,2"
               TextWrapping="NoWrap"
               TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding LastMessage}"
               FontSize="11" Foreground="#5E7A8A"
               TextTrimming="CharacterEllipsis"
               TextWrapping="NoWrap"
               MaxWidth="260"/>
                                            </StackPanel>

                                            <Border Grid.Column="3" Width="22" Height="22"
                                                    CornerRadius="11" Background="#C0304A"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding HasUnread}">
                                                <TextBlock Text="{Binding UnreadCount}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>