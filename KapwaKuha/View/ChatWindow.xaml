<Window x:Class="KapwaKuha.View.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Chat"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.07"
               Width="1980" Height="2808"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Border Margin="20" CornerRadius="20" BorderThickness="1.5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="#33FFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect Color="#00B4D8" BlurRadius="30" ShadowDepth="0" Opacity="0.16"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="68"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#0077B6" CornerRadius="20,20,0,0">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding BackCommand}"
                                Content="←" Background="Transparent" BorderThickness="0"
                                Foreground="White" FontSize="18" Cursor="Hand"
                                VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#2DC653"
                                         Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding OtherName}" FontSize="15"
                                           FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="KapwaKuha Chat" FontSize="11" Foreground="#90E0EF"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Messages -->
                <ScrollViewer Grid.Row="1" x:Name="MessagesScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,12">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <StackPanel HorizontalAlignment="{Binding Alignment}">

                                        <!-- Regular text bubble -->
                                        <Border CornerRadius="14" Padding="13,9" MaxWidth="340">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#EBF7FB"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                            <Setter Property="Background" Value="#00B4D8"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#00B4D8" BlurRadius="8"
                                                                  ShadowDepth="1" Opacity="0.12"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <!-- Item image if available -->
                                                <Border CornerRadius="8" ClipToBounds="True"
                                                 Height="120" Margin="0,0,0,8">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <!-- Only show when BOTH the preview flag AND a real path exist -->
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding ShowItemPreview}" Value="True"/>
                                                                        <Condition Binding="{Binding HasLinkedImage}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Border Background="#EBF7FB"/>
                                                        <Image Source="{Binding LinkedItemPath, TargetNullValue={x:Null}}"
                                                        Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>

                                                <!-- In the text bubble StackPanel, the TextBlock needs explicit VerticalAlignment: -->
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                             FontSize="13" LineHeight="19"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#03045E"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBlock Text="{Binding Time}" FontSize="9"
                                                           HorizontalAlignment="Right" Margin="0,3,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#5E7A8A"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                                    <Setter Property="Foreground" Value="#CAF0F8"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- Accept / Decline buttons — only on DirectTarget system messages, receiver side -->
                                       <StackPanel Orientation="Horizontal" Margin="4,6,0,0"
             Visibility="{Binding ShowActionButtons, Converter={StaticResource BoolToVis}}">
                                            <Button Content="✅ Accept"
                                                    FontSize="12" FontWeight="SemiBold"
                                                    Foreground="White" BorderThickness="0"
                                                    Cursor="Hand" Margin="0,0,8,0"
                                                    Command="{Binding DataContext.AcceptCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="10" Background="#2E7D52" Padding="12,6">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="❌ Decline"
                                                    FontSize="12" FontWeight="SemiBold"
                                                    Foreground="White" BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.DeclineCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="10" Background="#C0304A" Padding="12,6">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>

                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Input bar -->
                <Border Grid.Row="2" Background="White" Padding="14,12"
                        BorderBrush="#EBF7FB" BorderThickness="0,1,0,0"
                        CornerRadius="0,0,20,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="20" BorderBrush="#90E0EF"
                                BorderThickness="1.5" Background="#F0F8FB" Padding="14,0">
                            <TextBox x:Name="MsgBox"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="40" Background="Transparent" BorderThickness="0"
                                     Foreground="#03045E" FontSize="13"
                                     VerticalContentAlignment="Center"
                                     KeyDown="MsgBox_KeyDown"/>
                        </Border>
                        <Button Grid.Column="2" Command="{Binding SendCommand}"
                                Width="44" Height="44" Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="22" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00B4D8" Offset="0"/>
                                    <GradientStop Color="#0077B6" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <TextBlock Text="➤" FontSize="18" Foreground="White" Margin="2,0,0,0"/>
                        </Button>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>