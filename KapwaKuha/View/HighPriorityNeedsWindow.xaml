<Window x:Class="KapwaKuha.View.HighPriorityNeedsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — High-Priority Needs"
          Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.05" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="LightSkyBlue">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🚨 " FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="HIGH-PRIORITY NEEDS" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="⟳ Refresh" Background="Transparent" BorderThickness="0"
                            Foreground="#FFB3B3" FontSize="12" Cursor="Hand" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Cards area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- REPLACE the info Border in Grid.Row="0" with: -->
                    <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16,12">
                        <Border.Effect>
                            <DropShadowEffect Color="#C0304A" BlurRadius="12" ShadowDepth="0" Opacity="0.08"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                   Text="Organizations and beneficiaries post urgent needs here. Donate an item that matches their request to help fulfill it."
                   FontSize="12" Foreground="#5E7A8A" TextWrapping="Wrap"
                   VerticalAlignment="Center"/>

                            <!-- Urgency filter — sorted by severity: High > Medium > Low -->
                            <Border Grid.Column="1" CornerRadius="8" BorderBrush="#90E0EF"
                BorderThickness="1.5" Background="#F0F8FF" Margin="16,0,0,0">
                                <ComboBox SelectedValue="{Binding FilterUrgency}"
          SelectedValuePath="Tag"
          Width="160" Height="34" Background="Transparent"
          BorderThickness="0" FontSize="12" Padding="10,0">
                                    <ComboBoxItem Tag="All"    Content="All"/>
                                    <ComboBoxItem Tag="High"   Content="🔴 High (Urgent)"/>
                                    <ComboBoxItem Tag="Medium" Content="🟡 Medium"/>
                                    <ComboBoxItem Tag="Low"    Content="🟢 Low"/>
                                </ComboBox>
                            </Border>
                        </Grid>
                    </Border>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding NeedsPosts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.DonateToNeedCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
            CommandParameter="{Binding}" Width="260" Margin="0,0,14,14"
            BorderThickness="0" Padding="0" Background="Transparent" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="16" Background="White" x:Name="CardBorder">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="0" Opacity="0.08"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                    <Border Height="5" CornerRadius="16,16,0,0" Background="{Binding UrgencyTextColor}"/>

                                                    <Border Height="160" ClipToBounds="True">
                                                        <Grid>
                                                            <Border>
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                        <GradientStop Color="#FFF0F0" Offset="0"/>
                                                                        <GradientStop Color="#FFE4E4" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                            </Border>
                                                            <TextBlock Text="🆘" FontSize="54" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <Image Source="{Binding ImagePath}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                            <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,8,0" CornerRadius="6" Padding="8,3" Background="{Binding UrgencyColor}">
                                                                <TextBlock Text="{Binding Urgency}" FontSize="10" FontWeight="Bold" Foreground="{Binding UrgencyTextColor}"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Margin="14,10,14,14">
                                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" Foreground="#03045E" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="40" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding Org_Name}" FontSize="11" Foreground="#0077B6" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" MaxHeight="36" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                                        <TextBlock Text="{Binding PostDateDisplay}" FontSize="10" Foreground="#AAAAAA" Margin="0,0,0,10"/>

                                                        <Border CornerRadius="8" Padding="0,8">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#00B4D8" Offset="0"/>
                                                                    <GradientStop Color="#0077B6" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <TextBlock Text="🤲  Donate for This Need" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#00B4D8"/>
                                                    <Setter TargetName="CardBorder" Property="BorderThickness" Value="1.5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>