<Window x:Class="KapwaKuha.View.BeneficiaryProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Beneficiary Profile"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.07" Width="1980"
        HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back to Dashboard" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="14" FontWeight="SemiBold" Cursor="Hand" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="KAPWAKUHA  /  Beneficiary Settings"
                               FontSize="14" FontWeight="Bold" Foreground="#BAE6FD"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="16" Margin="40,30" Padding="40" 
                    BorderBrush="#E2E8F0" BorderThickness="1" MaxWidth="1000">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" BlurRadius="20" ShadowDepth="4" Opacity="0.05"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Border Width="140" Height="140" CornerRadius="70" ClipToBounds="True"
                                    Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="2"
                                    Margin="0,0,0,16" Cursor="Hand" ToolTip="Click to change photo">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding BrowsePictureCommand}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <TextBlock Text="👤" FontSize="60" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Ellipse>
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding PicturePath}" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>
                            </Border>

                            <Button Command="{Binding BrowsePictureCommand}" Height="36" Width="140"
                                    Background="#F0F8FF" BorderBrush="#0077B6" BorderThickness="1.5"
                                    Foreground="#0077B6" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E0F2FE"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="📷 Change Photo"/>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,0,0,10">
                            <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,0,0,20"/>
                            <TextBlock Text="Danger Zone" FontSize="12" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <Button Command="{Binding DeactivateCommand}" Height="40"
                                    Background="Transparent" BorderBrush="#EF4444" BorderThickness="1.5"
                                    Foreground="#EF4444" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FEF2F2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠ " FontSize="14"/>
                                    <TextBlock Text="Deactivate Account"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Column="1" BorderBrush="#F1F5F9" BorderThickness="2,0,0,0" HorizontalAlignment="Center" Margin="0,10"/>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="Beneficiary Information" FontSize="22" FontWeight="Bold"
               Foreground="#0F172A" Margin="0,0,0,30"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Full Name" Style="{StaticResource HCILabel}"/>
                                <Border Style="{StaticResource HCIReadOnlyInput}">
                                    <TextBox Text="{Binding FullName}" Height="42" Background="Transparent"
                     BorderThickness="0" FontSize="14" IsReadOnly="True"
                     Foreground="#64748B" VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Contact Number" Style="{StaticResource HCILabel}"/>
                                <Border Style="{StaticResource HCIReadOnlyInput}">
                                    <TextBox Text="{Binding Contact}" Height="42" Background="Transparent"
                     BorderThickness="0" FontSize="14" IsReadOnly="True"
                     Foreground="#64748B" VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Grid.ColumnSpan" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsIndependent}" Value="True">
                                                <Setter Property="Grid.ColumnSpan" Value="3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Email" Style="{StaticResource HCILabel}"/>
                                <Border Style="{StaticResource HCIReadOnlyInput}">
                                    <TextBox Text="{Binding Email}" Height="42" Background="Transparent"
                     BorderThickness="0" FontSize="14" IsReadOnly="True"
                     Foreground="#64748B" VerticalContentAlignment="Center"
                     ToolTip="Email cannot be changed here."/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsIndependent}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Organization Name" Style="{StaticResource HCILabel}"/>
                                <Border Style="{StaticResource HCIReadOnlyInput}">
                                    <TextBox Text="{Binding OrganizationName, Mode=OneWay}" Height="42"
                     Background="Transparent" BorderThickness="0" FontSize="14"
                     IsReadOnly="True" Foreground="#64748B" VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Username" Style="{StaticResource HCILabel}"/>
                                <Border Style="{StaticResource HCIInput}">
                                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Height="42" Background="Transparent" BorderThickness="0"
                     FontSize="14" Foreground="#0F172A" VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsIndependent}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Address" Style="{StaticResource HCILabel}"/>
                                <Border Style="{StaticResource HCIInput}">
                                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                     Height="42" Background="Transparent" BorderThickness="0"
                     FontSize="14" Foreground="#0F172A" VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Button Command="{Binding SaveCommand}" Height="48" Margin="0,20,0,0"
            FontSize="15" FontWeight="Bold" Foreground="White"
            BorderThickness="0" Cursor="Hand" Width="220" HorizontalAlignment="Right">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00B4D8" Offset="0"/>
                                    <GradientStop Color="#0077B6" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <TextBlock Text="💾  Save Changes"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>