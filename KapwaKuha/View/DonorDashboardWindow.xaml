<Window x:Class="KapwaKuha.View.DonorDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:DonorDashboardDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Donor Dashboard"
        Height="640" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" ResizeMode="CanResize">
    <Grid>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.05" Stretch="UniformToFill"/>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Ellipse Width="380" Height="380" Opacity="0.13" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.05" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="0" Style="{StaticResource AnimatedSidebarStyle}"
                    BorderThickness="0,0,1.5,0">

                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="#4D0077B6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,24,20,16">

                        <StackPanel Orientation="Horizontal">
                            <Grid Width="38" Height="38" Margin="0,0,4,0">
                                <Image Source="https://i.imgur.com/FHFRQxB.png" 
                                       Width="60" Height="60" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                                <Run Foreground="#FF03045E" Text="Kapwa"/><Run Foreground="#FF00B4D8" Text="Kuha"/>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="Donor Portal" FontSize="11" FontWeight="SemiBold" Foreground="#0077B6" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding UserLabel}" FontSize="11" Foreground="#5E7A8A" Margin="0,4,0,0"/>

                        <Rectangle Height="1.2" Margin="0,16,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#330077B6" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="12,0">

                        <Button Command="{Binding PostItemCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12" Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🤲" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Post an Item" Foreground="#03045E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding ActiveListingsCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12" Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Active Listings" Foreground="#03045E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding MyImpactCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12" Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💙" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="My Impact" Foreground="#03045E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding HighPriorityNeedsCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12" Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚨" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Priority Needs" Foreground="#03045E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding ClaimTrackerCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12" Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Claim Tracker" Foreground="#03045E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding ChatCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12" Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💬" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Messages" Foreground="#03045E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="12,0,12,24">

                        <Rectangle Height="1.2" Margin="8,0,8,16">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A0077B6" Offset="0"/>
                                    <GradientStop Color="#330077B6" Offset="0.5"/>
                                    <GradientStop Color="#1A0077B6" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <Button Command="{Binding LogoutCommand}" Style="{StaticResource CardHoverBtn}" Padding="0">
                            <Border CornerRadius="12" Padding="12,12" Background="#1AC0304A">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬅" Margin="0,0,12,0" Foreground="#C0304A" FontSize="14"/>
                                    <TextBlock Text="Log Out" Foreground="#C0304A" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#AAFFFFFF">
                    <Border.Effect>
                        <DropShadowEffect Color="#0077B6" BlurRadius="10" ShadowDepth="0" Opacity="0.10"/>
                    </Border.Effect>
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding HamburgerCommand}"
                                Content="☰" Foreground="#03045E" Background="Transparent"
                                BorderThickness="0" FontSize="22" Cursor="Hand" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding WelcomeText}"
                                   Foreground="#03045E" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="14,0,0,0"/>

                        <!-- Replace the Ellipse + account Border in the top bar Grid.Column="2": -->
                        <Border Grid.Column="2" CornerRadius="20" Padding="4,4,12,4" VerticalAlignment="Center"
        Background="#E6FFFFFF" BorderBrush="#B390E0EF" BorderThickness="1" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding MyAccountCommand}"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal">

                                <!-- Circular profile picture — top-right of both dashboards -->
                                <Border Width="36" Height="36" CornerRadius="18" ClipToBounds="True" Cursor="Hand" Margin="0,0,8,0">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding MyAccountCommand}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Border Background="#EBF7FB" CornerRadius="18"/>

                                        <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Image Source="{Binding ProfilePicturePath}" Stretch="UniformToFill">

                                            <Image.Clip>
                                                <EllipseGeometry RadiusX="18" RadiusY="18" Center="18,18" />
                                            </Image.Clip>

                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Grid>
                                </Border>

                                <TextBlock Text="{Binding UserLabel}" FontSize="12" Foreground="#03045E" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text=" ▼" FontSize="9" Foreground="#5E7A8A" VerticalAlignment="Center" Margin="6,2,0,0"/>

                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,28,28,0">
                    <StackPanel>
                        <TextBlock Text="What would you like to do today?"
                                   FontSize="20" FontWeight="Bold" Foreground="#03045E" Margin="0,0,0,6"/>
                        <TextBlock Text="Post items, track impact, or respond to community needs."
                                   FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,24"/>

                        <UniformGrid Rows="2" Columns="3" HorizontalAlignment="Stretch" Margin="0,0,0,28">
                            <Button Command="{Binding PostItemCommand}" Style="{StaticResource CardHoverBtn}" Margin="0,0,14,14">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="🤲" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Post an Item" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Donate directly or to the public" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding MyImpactCommand}" Style="{StaticResource CardHoverBtn}" Margin="0,0,14,14">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="💙" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="My Impact Dashboard" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="See your community contribution" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding ChatCommand}" Style="{StaticResource CardHoverBtn}" Margin="0,0,0,14">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="💬" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Messages" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Chat with beneficiaries" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding HighPriorityNeedsCommand}" Style="{StaticResource CardHoverBtn}" Margin="0,0,14,0">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="🚨" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="High-Priority Needs" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Respond to urgent community requests" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding ActiveListingsCommand}" Style="{StaticResource CardHoverBtn}" Margin="0,0,14,0">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="📋" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Active Listings" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="View and manage your posted items" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding ClaimTrackerCommand}" Style="{StaticResource CardHoverBtn}">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="📦" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Claim Tracker" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Track and advance item handoffs" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </UniformGrid>

                        <Border CornerRadius="16" Margin="0,0,0,28" BorderThickness="1.5" MinHeight="250">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#33FFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="20,16,20,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋 " FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Transaction History" FontSize="16" FontWeight="Bold"
                                                   Foreground="#03045E" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TransactionStatus}"
                                               FontSize="11" Foreground="#5E7A8A" Margin="0,3,0,0"/>
                                </StackPanel>

                                <Grid Grid.Row="1">

                                    <DataGrid x:Name="TransactionsGrid" ItemsSource="{Binding Transactions}"
                                              AutoGenerateColumns="False" CanUserAddRows="False"
                                              CanUserDeleteRows="False" CanUserResizeRows="False"
                                              IsReadOnly="True" SelectionMode="Single"
                                              Background="Transparent" BorderThickness="0"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#EBF7FB"
                                              RowBackground="White" AlternatingRowBackground="#F7FBFD"
                                              ColumnHeaderHeight="36" RowHeight="60" FontSize="12"
                                              MaxHeight="320" Margin="0,0,0,8">

                                        <DataGrid.Style>
                                            <Style TargetType="DataGrid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Style>

                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#EBF7FB"/>
                                                <Setter Property="Foreground" Value="#0077B6"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="12,0"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>

                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Photo" Width="60" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Width="44" Height="44" CornerRadius="6"
                                                                ClipToBounds="True" Margin="4,4">
                                                            <Grid>
                                                                <Border Background="#EBF7FB"/>
                                                                <TextBlock Text="📦" FontSize="20"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <Image Source="{Binding Item_ImagePath}" Stretch="UniformToFill">
                                                                    <Image.Style>
                                                                        <Style TargetType="Image">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Image.Style>
                                                                </Image>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="Item" Binding="{Binding Item_Name}"
                                                                Width="*" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Category" Binding="{Binding Category_Name}"
                                                                Width="100" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="Foreground" Value="#0077B6"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Recipient" Binding="{Binding Beneficiary_Name}"
                                                                Width="130" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="FontSize" Value="12"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Organisation" Binding="{Binding Organization_Name}"
                                                                Width="140" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="Foreground" Value="#5E7A8A"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Handoff" Binding="{Binding Handoff_Type}"
                                                                Width="100" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Completed" Binding="{Binding ClaimDateDisplay}"
                                                                Width="155" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="Foreground" Value="#5E7A8A"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTemplateColumn Header="Status" Width="100" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="10" Padding="10,4"
                                                                HorizontalAlignment="Left" Margin="4,0"
                                                                Background="#E6F7EE">
                                                            <TextBlock Text="✅ Released" FontSize="10"
                                                                       FontWeight="SemiBold" Foreground="#2E7D52"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30,0,50">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Items.Count, ElementName=TransactionsGrid}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <TextBlock Text="📭" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.8"/>
                                        <TextBlock Text="You have no active or completed transactions yet." FontSize="14" Foreground="#03045E" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="When you claim or post an item, its history will appear here." FontSize="12" Foreground="#5E7A8A" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>

                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>