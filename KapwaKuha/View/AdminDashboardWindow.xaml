<Window x:Class="KapwaKuha.View.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Admin Dashboard"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ TOPBAR ══ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0A2540" Offset="0"/>
                    <GradientStop Color="#0077B6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡" FontSize="22" Foreground="White" Margin="0,0,10,0"/>
                    <TextBlock Text="KapwaKuha Admin" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding WelcomeText}"
                           Foreground="#CCFFFFff" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource LinkBtn}"
                            Foreground="White" Content="🔄 Refresh" Margin="0,0,16,0"/>
                    <Button Command="{Binding LogoutCommand}"
                            Style="{StaticResource OutlineBtn}"
                            Foreground="White" BorderBrush="SkyBlue"
                            Content="Logout" Height="34" Padding="16,0" Width="56" Background="LightBlue"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ BODY ══ -->
        <Grid Grid.Row="1">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F0F8FF" Offset="0"/>
                    <GradientStop Color="#E8F4FD" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT SIDEBAR — KPIs ══ -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,24,16,16">
                        <TextBlock Text="PLATFORM KPIs" FontSize="11" FontWeight="Bold"
                                   Foreground="#9CA3AF" Margin="0,0,0,16"/>

                        <Border Style="{StaticResource GlassCard}" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="📦 Total Donated" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Text="{Binding TotalDonated}" FontSize="26" FontWeight="Bold" Foreground="#0077B6"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource GlassCard}" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="✅ Total Claimed" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Text="{Binding TotalClaimed}" FontSize="26" FontWeight="Bold" Foreground="#059669"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource GlassCard}" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="🟢 Active Items" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Text="{Binding ActiveItems}" FontSize="26" FontWeight="Bold" Foreground="#0077B6"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource GlassCard}" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="❤️ Fulfilled Needs" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Text="{Binding FulfilledNeeds}" FontSize="26" FontWeight="Bold" Foreground="#7C3AED"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource GlassCard}" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="🏢 Inst. Beneficiaries" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Text="{Binding ActiveInstBenes}" FontSize="26" FontWeight="Bold" Foreground="#0077B6"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource GlassCard}" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="👤 Indep. Beneficiaries" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Text="{Binding ActiveIndepBenes}" FontSize="26" FontWeight="Bold" Foreground="#0077B6"/>
                            </StackPanel>
                        </Border>

                        <Separator Margin="0,8,0,16" Background="#E5E7EB"/>
                        <TextBlock Text="PENDING ACTIONS" FontSize="11" FontWeight="Bold"
                                   Foreground="#9CA3AF" Margin="0,0,0,12"/>

                        <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,8"
                                Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="⏳ Pending Items" FontSize="11" Foreground="#92400E"/>
                                <TextBlock Text="{Binding PendingItems}" FontSize="26" FontWeight="Bold" Foreground="#D97706"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,8"
                                Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="👥 Pending Benes" FontSize="11" Foreground="#92400E"/>
                                <TextBlock Text="{Binding PendingBeneficiaries}" FontSize="26" FontWeight="Bold" Foreground="#D97706"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,8"
                                Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="📋 Pending Needs Posts" FontSize="11" Foreground="#92400E"/>
                                <TextBlock Text="{Binding PendingNeedsPosts}" FontSize="26" FontWeight="Bold" Foreground="#D97706"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,12"
                                Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="🚨 Open Reports" FontSize="11" Foreground="#991B1B"/>
                                <TextBlock Text="{Binding OpenReports}" FontSize="26" FontWeight="Bold" Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ══ RIGHT CONTENT — ALL QUEUES ══ -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,20">

                    <!-- ── 1. PENDING ITEM APPROVALS ── -->
                    <Border Style="{StaticResource GlassCard}" CornerRadius="16" Padding="20,16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📦 Pending Item Approvals" FontSize="16" FontWeight="Bold"
                                           Foreground="#0A2540" VerticalAlignment="Center"/>
                                <Border Background="#FEF3C7" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding PendingItems}" FontSize="12" FontWeight="Bold" Foreground="#D97706"/>
                                </Border>
                            </StackPanel>
                            <Grid Grid.Row="1">
                                <TextBlock Text="Loading..." FontSize="13" Foreground="#9CA3AF"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding IsLoadingItems, Converter={StaticResource BoolToVis}}"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPendingItems}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="✅" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No pending items — all clear!" FontSize="13"
                                               Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <ListView ItemsSource="{Binding PendingItemsList}"
                                          Background="Transparent" BorderThickness="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" MaxHeight="320">
                                    <ListView.Style>
                                        <Style TargetType="ListView">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPendingItems}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.Style>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="0,4"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="12"
                                                    BorderBrush="#E5E7EB" BorderThickness="1" Padding="14,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="124"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Item image -->
                                           
                                                    <Border Grid.Column="0" Width="110" Height="110"
                                             CornerRadius="10" ClipToBounds="True"
                                Background="#EBF7FB" VerticalAlignment="Top"
                                 Cursor="Hand"
                             MouseLeftButtonUp="ItemImage_Click"
                                Tag="{Binding Item_ImagePath}">
                                                        <Grid>
                                                            <TextBlock Text="📦" FontSize="38"
                                     HorizontalAlignment="Center"
                                VerticalAlignment="Center" Opacity="0.5">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <Image Source="{Binding Item_ImagePath}" Stretch="UniformToFill">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Item details -->
                                                    <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding Item_Name}"
                                                                   FontWeight="Bold" FontSize="15"
                                                                   Foreground="#0A2540" TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <Border CornerRadius="6" Background="#E0F2FE" Padding="7,2" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding Category_Name}" FontSize="10"
                                                                           FontWeight="SemiBold" Foreground="#0077B6"/>
                                                            </Border>
                                                            <Border CornerRadius="6" Background="#F0FFF4" Padding="7,2" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding Item_Condition}" FontSize="10"
                                                                           FontWeight="SemiBold" Foreground="#059669"/>
                                                            </Border>
                                                            <Border CornerRadius="6" Background="#F3F4F6" Padding="7,2">
                                                                <TextBlock Text="{Binding PostType}" FontSize="10"
                                                                           FontWeight="SemiBold" Foreground="#374151"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Item_Description}"
                                                                   FontSize="12" Foreground="#4B5563"
                                                                   TextWrapping="Wrap" MaxHeight="48"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,6,0,6"/>
                                                        <TextBlock FontSize="11" Foreground="#9CA3AF">
                                                            <Run Text="Donor: "/>
                                                            <Run Text="{Binding Donor_ID, Mode=OneWay}" FontWeight="SemiBold" Foreground="#6B7280"/>
                                                            <Run Text="  ·  "/>
                                                            <Run Text="{Binding StorageInfo, Mode=OneWay}" Foreground="#6B7280"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Approve / Reject buttons -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Width="116">
                                                        <Button Command="{Binding DataContext.ApproveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Content="✅ Approve"
                                                                Style="{StaticResource GradientButton}"
                                                                Height="34" Padding="0,0" Margin="0,0,0,6" FontSize="12"/>
                                                        <Button Command="{Binding DataContext.RejectItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Content="❌ Reject"
                                                                Style="{StaticResource OutlineBtn}"
                                                                Height="34" Padding="0,0" FontSize="12"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── 2. PENDING BENEFICIARY APPROVALS ── -->
                    <Border Style="{StaticResource GlassCard}" CornerRadius="16" Padding="20,16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="👥 Pending Beneficiary Approvals" FontSize="16" FontWeight="Bold"
                                           Foreground="#0A2540" VerticalAlignment="Center"/>
                                <Border Background="#FEF3C7" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding PendingBeneficiaries}" FontSize="12" FontWeight="Bold" Foreground="#D97706"/>
                                </Border>
                            </StackPanel>
                            <Grid Grid.Row="1">
                                <TextBlock Text="Loading..." FontSize="13" Foreground="#9CA3AF"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding IsLoadingBenes, Converter={StaticResource BoolToVis}}"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPendingBeneficiaries}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="✅" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No pending beneficiaries — all clear!" FontSize="13"
                                               Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <ListView ItemsSource="{Binding PendingBenesList}"
                                          Background="Transparent" BorderThickness="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" MaxHeight="260">
                                    <ListView.Style>
                                        <Style TargetType="ListView">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPendingBeneficiaries}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.Style>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="0,4"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="10"
                                                    BorderBrush="#E5E7EB" BorderThickness="1" Padding="14,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Beneficiary_FullName}" FontWeight="SemiBold" FontSize="14" Foreground="#0A2540"/>
                                                        <TextBlock Foreground="#6B7280" FontSize="12" Margin="0,2,0,0">
                                                            <Run Text="{Binding Organization_Name, Mode=OneWay}"/>
                                                            <Run Text=" • "/>
                                                            <Run Text="{Binding Beneficiary_ID, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Command="{Binding DataContext.ApproveBeneficiaryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Content="✅ Approve"
                                                            Style="{StaticResource GradientButton}"
                                                            Height="32" Padding="14,0" Margin="0,0,8,0" FontSize="12"/>
                                                    <Button Grid.Column="2"
                                                            Command="{Binding DataContext.RejectBeneficiaryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Content="❌ Reject"
                                                            Style="{StaticResource OutlineBtn}"
                                                            Height="32" Padding="14,0" FontSize="12"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── 3. PENDING NEEDS POSTS ── -->
                    <Border Style="{StaticResource GlassCard}" CornerRadius="16" Padding="20,16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📋 Pending Needs Posts" FontSize="16" FontWeight="Bold"
                                           Foreground="#0A2540" VerticalAlignment="Center"/>
                                <Border Background="#FEF3C7" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding PendingNeedsPosts}" FontSize="12" FontWeight="Bold" Foreground="#D97706"/>
                                </Border>
                            </StackPanel>
                            <Grid Grid.Row="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPendingNeedsPosts}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="📭" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No pending needs posts — all clear!" FontSize="13"
                                               Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <ListView ItemsSource="{Binding PendingNeedsPostsList}"
                                          Background="Transparent" BorderThickness="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" MaxHeight="400">
                                    <ListView.Style>
                                        <Style TargetType="ListView">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPendingNeedsPosts}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.Style>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="0,4"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" BorderThickness="1" Padding="14,12" Margin="0,0,0,6">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEdit}" Value="True">
                                                                <Setter Property="Background" Value="#FFFDF0"/>
                                                                <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>

                                                    <!-- Top row: info + buttons -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">

                                                            <!-- EDITED / RESUBMITTED badge -->
                                                            <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,5">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsEdit}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="✏️" FontSize="11" Margin="0,0,4,0"/>
                                                                    <TextBlock Text="EDITED / RESUBMITTED — Review changes below"
                                                                               FontSize="10" FontWeight="Bold" Foreground="#92400E"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <TextBlock Text="{Binding Title}" FontSize="14"
                                                                       FontWeight="SemiBold" Foreground="#0A2540"/>

                                                            <!-- Org · date · urgency pill row -->
                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                <TextBlock Foreground="#6B7280" FontSize="12">
                                                                    <Run Text="{Binding Org_Name, Mode=OneWay}"/>
                                                                    <Run Text=" · "/>
                                                                    <Run Text="{Binding PostDateDisplay, Mode=OneWay}" Foreground="#9CA3AF"/>
                                                                </TextBlock>
                                                                <Border CornerRadius="6" Padding="8,2" Margin="8,0,0,0"
                                                                        Background="{Binding UrgencyColor}">
                                                                    <TextBlock FontSize="11" FontWeight="Bold"
                                                                               Foreground="{Binding UrgencyTextColor}">
                                                                        <Run Text="{Binding Urgency, Mode=OneWay}"/>
                                                                        <Run Text=" Urgency"/>
                                                                    </TextBlock>
                                                                </Border>
                                                            </StackPanel>

                                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                                       Foreground="#6B7280" TextTrimming="CharacterEllipsis"
                                                                       Margin="0,4,0,0" MaxWidth="500"/>
                                                        </StackPanel>

                                                        <!-- Approve / Reject buttons -->
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                    VerticalAlignment="Top" Margin="12,0,0,0">
                                                            <Button Content="✅ Approve + Set Urgency"
                                                                    Command="{Binding DataContext.ApproveNeedsPostCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource GradientButton}"
                                                                    Height="32" Padding="14,0" Margin="0,0,8,0" FontSize="12"/>
                                                            <Button Content="❌ Reject"
                                                                    Command="{Binding DataContext.RejectNeedsPostCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource OutlineBtn}"
                                                                    Height="32" Padding="14,0" FontSize="12"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Needs Post image (zoomable) -->
                                                    <Border Margin="0,8,0,0" CornerRadius="8" ClipToBounds="True"
        Cursor="Hand" Height="140"
        Tag="{Binding ImagePath}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                      Command="{Binding DataContext.ZoomImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding ImagePath}"/>
                                                        </Border.InputBindings>
                                                        <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                                    </Border>

                                                    <!-- Before / After diff panel -->
                                                    <Border Margin="0,10,0,0" CornerRadius="8"
        Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
        Padding="12,10">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEdit}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="28"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- BEFORE (old snapshot = PreviousTitle/PreviousDescription) -->
                                                            <Border Grid.Column="0" Background="#FEF2F2" CornerRadius="6" Padding="10,8">
                                                                <StackPanel>
                                                                    <TextBlock Text="BEFORE" FontSize="9" FontWeight="Bold"
                           Foreground="#EF4444" Margin="0,0,0,5"/>
                                                                    <TextBlock Text="{Binding PreviousTitle}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#7F1D1D" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding PreviousDescription}"
                           FontSize="11" Foreground="#991B1B"
                           TextWrapping="Wrap" Margin="0,3,0,4"
                           MaxHeight="50" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock FontSize="11" Foreground="#B91C1C">
                    <Run Text="Urgency: "/>
                    <Run Text="{Binding PreviousUrgency, Mode=OneWay}" FontWeight="Bold"/>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- Arrow -->
                                                            <TextBlock Grid.Column="1" Text="→" FontSize="18" FontWeight="Bold"
                   Foreground="#92400E" VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>

                                                            <!-- AFTER (new edit = current Title/Description) -->
                                                            <Border Grid.Column="2" Background="#F0FFF4" CornerRadius="6" Padding="10,8">
                                                                <StackPanel>
                                                                    <TextBlock Text="AFTER" FontSize="9" FontWeight="Bold"
                           Foreground="#16A34A" Margin="0,0,0,5"/>
                                                                    <TextBlock Text="{Binding Title}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#14532D" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding Description}"
                           FontSize="11" Foreground="#166534"
                           TextWrapping="Wrap" Margin="0,3,0,4"
                           MaxHeight="50" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock FontSize="11" Foreground="#15803D">
                    <Run Text="Urgency: "/>
                    <Run Text="{Binding Urgency, Mode=OneWay}" FontWeight="Bold"/>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </Border>

                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── 4. OPEN USER REPORTS ── -->
                    <Border Style="{StaticResource GlassCard}" CornerRadius="16" Padding="20,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="🚨 Open User Reports" FontSize="16" FontWeight="Bold"
                                           Foreground="#0A2540" VerticalAlignment="Center"/>
                                <Border Background="#FEE2E2" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding OpenReports}" FontSize="12" FontWeight="Bold" Foreground="#DC2626"/>
                                </Border>
                            </StackPanel>
                            <Grid Grid.Row="1">
                                <TextBlock Text="Loading..." FontSize="13" Foreground="#9CA3AF"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding IsLoadingReports, Converter={StaticResource BoolToVis}}"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasOpenReports}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="🟢" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No open reports — platform is clean!" FontSize="13"
                                               Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <ListView ItemsSource="{Binding OpenReportsList}"
                                          Background="Transparent" BorderThickness="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" MaxHeight="300">
                                    <ListView.Style>
                                        <Style TargetType="ListView">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasOpenReports}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.Style>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="0,4"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="10"
                                                    BorderBrush="#FECACA" BorderThickness="1" Padding="14,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Proof image thumbnail -->
                                                    <Border Grid.Column="0" Width="70" Height="70"
                                                            CornerRadius="8" ClipToBounds="True"
                                                            Background="#F3F4F6" Margin="0,0,12,0"
                                                            Cursor="Hand"
                                                            MouseLeftButtonUp="ReportImage_Click"
                                                            Tag="{Binding ProofImagePath}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasProofImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Image Source="{Binding ProofImagePath}" Stretch="UniformToFill"/>
                                                            <Border VerticalAlignment="Bottom" Background="#88000000" Padding="4,2">
                                                                <TextBlock Text="🔍 View" FontSize="9" Foreground="White"
                                                                           HorizontalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Foreground="#0A2540" FontWeight="SemiBold" FontSize="14">
                                                            <Run Text="{Binding ReportType, Mode=OneWay}"/>
                                                            <Run Text=" — "/>
                                                            <Run Text="{Binding ReportedName, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="#6B7280" FontSize="12"
                                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                        <TextBlock Foreground="#9CA3AF" FontSize="11" Margin="0,4,0,0">
                                                            <Run Text="Filed by: "/>
                                                            <Run Text="{Binding ReporterName, Mode=OneWay}"/>
                                                            <Run Text="  •  "/>
                                                            <Run Text="{Binding FiledAtDisplay, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                Margin="12,0,4,0" VerticalAlignment="Center">
                                                        <Button Content="⚡ Strike"
                                                                Command="{Binding DataContext.ProcessReportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Height="30" Margin="0,0,6,0" FontSize="11"
                                                                Foreground="White" BorderThickness="0" Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border CornerRadius="6" Background="#F59E0B" x:Name="bg" Padding="10,0">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="bg" Property="Background" Value="#D97706"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Button Content="🚫 Ban"
                                                                Command="{Binding DataContext.AdminBanUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Height="30" FontSize="11"
                                                                Foreground="White" BorderThickness="0" Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border CornerRadius="6" Background="#DC2626" x:Name="bg" Padding="10,0">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="bg" Property="Background" Value="#B91C1C"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── 6. ADMIN SUPPORT INBOX ── -->
                    <Border Style="{StaticResource GlassCard}" CornerRadius="16" Padding="20,16" Margin="0,16,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="💬 Support Inbox" FontSize="16" FontWeight="Bold"
                       Foreground="#0A2540" VerticalAlignment="Center"/>
                                <Border Background="#DBEAFE" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding SupportThreadCount}" FontSize="12"
                           FontWeight="Bold" Foreground="#1D4ED8"/>
                                </Border>
                            </StackPanel>
                            <ListView Grid.Row="1" ItemsSource="{Binding SupportThreads}"
                  Background="Transparent" BorderThickness="0" MaxHeight="260"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" CornerRadius="8" Margin="0,2"
                            Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#0A2540"/>
                                                    <TextBlock Text="{Binding LastMessage}" FontSize="11"
                                           Foreground="#6B7280" TextTrimming="CharacterEllipsis"
                                           MaxWidth="320"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                    Command="{Binding DataContext.OpenSupportThreadCommand,
                                        RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"
                                    Content="Reply" Height="30" Padding="12,0"
                                    FontSize="11" FontWeight="Bold"
                                    Foreground="White" BorderThickness="0" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border CornerRadius="8" Background="#0077B6">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                </StackPanel>
                
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>