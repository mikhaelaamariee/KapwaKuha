<Window x:Class="KapwaKuha.View.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Admin Dashboard"
        Height="750" Width="1300"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        

        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F0F9FF"/>
                                <Setter Property="Foreground" Value="#0077B6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionCardContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="ActionButtonPrimaryStyle" TargetType="Button">
            <Setter Property="Background" Value="#0077B6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ActionButtonSuccessStyle" TargetType="Button">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ActionButtonDangerStyle" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="MetricsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="6,0"/>
        </Style>

        <Style x:Key="MetricsCardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>

        <Style x:Key="MetricsCardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0A2540"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOPBAR -->
        <Border Grid.Row="0" Panel.ZIndex="10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0A2540" Offset="0"/>
                    <GradientStop Color="#0077B6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#0A2540" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡" FontSize="24" Foreground="White" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="KapwaKuha Admin" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding WelcomeText}"
                           Foreground="#E2E8F0" FontSize="14" FontWeight="Medium"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}"
                            Content="🔄 Refresh" Foreground="White" FontWeight="SemiBold" FontSize="13"
                            Padding="14,8" Margin="0,0,12,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="#38BDF8"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Style.Resources>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="LogoutBtn" Click="LogoutBtn_Click"
                            Content="Logout" Foreground="White" FontWeight="SemiBold" FontSize="13"
                            Padding="16,8" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#EF4444"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Style.Resources>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                <Grid Margin="16,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="NAVIGATION MENU" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="8,0,0,16"/>
                    <StackPanel Grid.Row="1">
                        <RadioButton x:Name="TabOverview"   Content="📊 Dashboard Overview"  IsChecked="True" Style="{StaticResource SidebarTabStyle}" Margin="0,0,0,6"/>
                        <RadioButton x:Name="TabItems"      Content="📦 Item Approvals"                       Style="{StaticResource SidebarTabStyle}" Margin="0,0,0,6"/>
                        <RadioButton x:Name="TabNeeds"      Content="📋 Needs Approvals"                      Style="{StaticResource SidebarTabStyle}" Margin="0,0,0,6"/>
                        <RadioButton x:Name="TabBenes"      Content="👥 Beneficiary Approvals"                Style="{StaticResource SidebarTabStyle}" Margin="0,0,0,6"/>
                        <RadioButton x:Name="TabReports"    Content="🚨 User Reports"                         Style="{StaticResource SidebarTabStyle}" Margin="0,0,0,6"/>
                        <RadioButton x:Name="TabSupport"    Content="💬 Support Inbox"                        Style="{StaticResource SidebarTabStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN CONTENT AREA -->
            <Grid Grid.Column="1" Margin="28">

                <!-- ══ TAB: OVERVIEW ══ -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
              Visibility="{Binding IsChecked, ElementName=TabOverview, Converter={StaticResource BoolToVis}}">
                    <Grid Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,24">
                            <TextBlock Text="System Overview" FontSize="26" FontWeight="Bold" Foreground="#0A2540"/>
                            <TextBlock Text="Real-time application statistics and key metrics summary." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="1" Columns="4" Rows="1" Margin="0,0,0,16">
                            <Border Style="{StaticResource MetricsCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Total Donated" Style="{StaticResource MetricsCardTitleStyle}"/>
                                    <TextBlock Text="{Binding TotalDonated}" Style="{StaticResource MetricsCardValueStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricsCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Pending Items" Style="{StaticResource MetricsCardTitleStyle}" Foreground="#0077B6"/>
                                    <TextBlock Text="{Binding PendingItems}" Style="{StaticResource MetricsCardValueStyle}" Foreground="#0077B6"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricsCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Pending Needs Posts" Style="{StaticResource MetricsCardTitleStyle}" Foreground="#D97706"/>
                                    <TextBlock Text="{Binding PendingNeedsPosts}" Style="{StaticResource MetricsCardValueStyle}" Foreground="#D97706"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricsCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Support Threads" Style="{StaticResource MetricsCardTitleStyle}" Foreground="#059669"/>
                                    <TextBlock Text="{Binding SupportThreadCount}" Style="{StaticResource MetricsCardValueStyle}" Foreground="#059669"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <UniformGrid Grid.Row="2" Columns="4" Rows="1" Margin="0,0,0,28">
                            <Border Style="{StaticResource MetricsCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Total Claimed" Style="{StaticResource MetricsCardTitleStyle}"/>
                                    <TextBlock Text="{Binding TotalClaimed}" Style="{StaticResource MetricsCardValueStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricsCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Active Items" Style="{StaticResource MetricsCardTitleStyle}" Foreground="#0077B6"/>
                                    <TextBlock Text="{Binding ActiveItems}" Style="{StaticResource MetricsCardValueStyle}" Foreground="#0077B6"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricsCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Pending Beneficiaries" Style="{StaticResource MetricsCardTitleStyle}" Foreground="#D97706"/>
                                    <TextBlock Text="{Binding PendingBeneficiaries}" Style="{StaticResource MetricsCardValueStyle}" Foreground="#D97706"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricsCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Open Reports" Style="{StaticResource MetricsCardTitleStyle}" Foreground="#DC2626"/>
                                    <TextBlock Text="{Binding OpenReports}" Style="{StaticResource MetricsCardValueStyle}" Foreground="#DC2626"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20" Margin="0,0,10,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                        <TextBlock Text="Donations by Category" FontSize="16" FontWeight="Bold" Foreground="#0A2540"/>
                                        <TextBlock Text="Distribution of all approved platform items." FontSize="12" Foreground="#64748B"/>
                                    </StackPanel>

                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CategoryStats}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding CategoryName}" FontSize="12" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                                    <Border Grid.Column="1" Height="10" Background="#F1F5F9" CornerRadius="5" Margin="10,0" VerticalAlignment="Center">
                                                        <Border HorizontalAlignment="Left" CornerRadius="5" Background="{Binding BarColor}" Width="{Binding BarWidth}"/>
                                                    </Border>

                                                    <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="12" FontWeight="Bold" Foreground="#0A2540" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20" Margin="10,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,24">
                                        <TextBlock Text="7-Day Platform Activity" FontSize="16" FontWeight="Bold" Foreground="#0A2540"/>
                                        <TextBlock Text="New users and successful claims over the last week." FontSize="12" Foreground="#64748B"/>
                                    </StackPanel>

                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TimelineStats}" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="12,0" VerticalAlignment="Bottom">
                                                    <Grid Height="140" VerticalAlignment="Bottom" Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding Value}" FontSize="10" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-16,0,0"/>
                                                        <Border Width="24" Background="#0077B6" CornerRadius="4,4,0,0" Height="{Binding BarHeight}" VerticalAlignment="Bottom"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding DayLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                        </Grid>
                    </Grid>
                </ScrollViewer>

                
                <!-- ══ TAB: ITEM APPROVALS ══ -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
              Visibility="{Binding IsChecked, ElementName=TabItems, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Item Approval Queue" FontSize="26" FontWeight="Bold" Foreground="#0A2540"/>
                            <TextBlock Text="Review and approve newly submitted donation items before they go public." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Filter Row -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Height="36">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                   Text="🔍" 
                   FontSize="13" 
                   Foreground="#9CA3AF" 
                   Margin="10,0,4,0" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"/>

                                    <TextBox x:Name="ItemSearchTextBox"
                 Grid.Column="1"
                 Text="{Binding ItemSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                 BorderThickness="0" 
                 FontSize="13" 
                 Foreground="#374151"
                 VerticalContentAlignment="Center" 
                 Background="Transparent"
                 Padding="4,0,10,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Resources>
                                                    <VisualBrush x:Key="Hint" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Search by item name or donor..." 
                                           FontSize="13" 
                                           Foreground="#9CA3AF"
                                           Margin="4,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Style.Resources>

                                                <Setter Property="Background" Value="Transparent"/>

                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Text, ElementName=ItemSearchTextBox}" Value=""/>
                                                            <Condition Binding="{Binding IsFocused, ElementName=ItemSearchTextBox}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{StaticResource Hint}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White">
                                <ComboBox SelectedValue="{Binding ItemCategoryFilter}" SelectedValuePath="Content"
                          Height="36" BorderThickness="0" Background="Transparent"
                          Padding="10,0" FontSize="13" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="All Categories" IsSelected="True"/>
                                    <ComboBoxItem Content="Clothing"/>
                                    <ComboBoxItem Content="Food"/>
                                    <ComboBoxItem Content="Electronics"/>
                                    <ComboBoxItem Content="Medicine"/>
                                    <ComboBoxItem Content="School Supplies"/>
                                    <ComboBoxItem Content="Others"/>
                                </ComboBox>
                            </Border>
                            <Border Grid.Column="4" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White">
                                <ComboBox SelectedValue="{Binding ItemConditionFilter}" SelectedValuePath="Content"
                          Height="36" BorderThickness="0" Background="Transparent"
                          Padding="10,0" FontSize="13" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="All Conditions" IsSelected="True"/>
                                    <ComboBoxItem Content="New"/>
                                    <ComboBoxItem Content="Good"/>
                                    <ComboBoxItem Content="Fair"/>
                                    <ComboBoxItem Content="Poor"/>
                                </ComboBox>
                            </Border>
                        </Grid>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingItems}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="✅" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="No pending items — all clear!" FontSize="15" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding FilteredItemsList}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingItems}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16,14" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="106" Height="106" CornerRadius="10"
                                    ClipToBounds="True" Background="#EBF7FB"
                                    VerticalAlignment="Top" Cursor="Hand"
                                    MouseLeftButtonUp="ItemImage_Click"
                                    Tag="{Binding Item_ImagePath}">
                                                <Grid>
                                                    <TextBlock Text="📦" FontSize="38" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <Grid>
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Image Source="{Binding Item_ImagePath}" Stretch="UniformToFill"/>
                                                        <Border CornerRadius="6" Background="#80000000"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                Margin="0,0,6,6" Padding="6,3">
                                                            <TextBlock Text="🔍 Zoom" FontSize="10" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="16,0,16,0" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Item_Name}" FontWeight="Bold" FontSize="15" Foreground="#0A2540" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <Border CornerRadius="6" Background="#E0F2FE" Padding="8,3" Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding Category_Name}" FontSize="11" FontWeight="SemiBold" Foreground="#0077B6"/>
                                                    </Border>
                                                    <Border CornerRadius="6" Background="#F0FFF4" Padding="8,3" Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding Item_Condition}" FontSize="11" FontWeight="SemiBold" Foreground="#059669"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Item_Description}" FontSize="12" Foreground="#4B5563"
                                           TextWrapping="Wrap" MaxHeight="50" TextTrimming="CharacterEllipsis" Margin="0,6,0,6"/>
                                                <TextBlock FontSize="11" Foreground="#9CA3AF">
                                    <Run Text="Donor: "/>
                                    <Run Text="{Binding Donor_ID, Mode=OneWay}" FontWeight="SemiBold" Foreground="#6B7280"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.ApproveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="✅ Approve"
                                        Style="{StaticResource ActionButtonSuccessStyle}"
                                        Margin="0,0,0,8"/>
                                                <Button Command="{Binding DataContext.RejectItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="❌ Reject"
                                        Style="{StaticResource ActionButtonDangerStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ TAB: NEEDS APPROVALS ══ -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
              Visibility="{Binding IsChecked, ElementName=TabNeeds, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Needs Post Approval Queue" FontSize="26" FontWeight="Bold" Foreground="#0A2540"/>
                            <TextBlock Text="Verify and approve needs posts submitted by beneficiaries." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Filter Row -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Height="36">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                   Text="🔍" 
                   FontSize="13" 
                   Foreground="#9CA3AF" 
                   Margin="10,0,4,0" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"/>

                                    <TextBox x:Name="NeedsSearchTextBox"
                 Grid.Column="1"
                 Text="{Binding NeedsSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                 BorderThickness="0" 
                 FontSize="13" 
                 Foreground="#374151"
                 VerticalContentAlignment="Center" 
                 Background="Transparent"
                 Padding="4,0,10,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Resources>
                                                    <VisualBrush x:Key="Hint" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Search by title or organization..." 
                                           FontSize="13" 
                                           Foreground="#9CA3AF"
                                           Margin="4,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Style.Resources>

                                                <Setter Property="Background" Value="Transparent"/>

                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Text, ElementName=NeedsSearchTextBox}" Value=""/>
                                                            <Condition Binding="{Binding IsFocused, ElementName=NeedsSearchTextBox}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{StaticResource Hint}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White">
                                <ComboBox SelectedValue="{Binding NeedsUrgencyFilter}" SelectedValuePath="Content"
                          Height="36" BorderThickness="0" Background="Transparent"
                          Padding="10,0" FontSize="13" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="All Urgency" IsSelected="True"/>
                                    <ComboBoxItem Content="High"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="Low"/>
                                </ComboBox>
                            </Border>
                        </Grid>

                        <!-- NOTE: If only a photo was changed (no text fields edited), the post still goes to Pending for admin review. -->

                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingNeedsPosts}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="No pending needs posts — all clear!" FontSize="15" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding FilteredNeedsPostsList}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingNeedsPosts}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" BorderThickness="1" Padding="16,14" Margin="0,0,0,12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEdit}" Value="True">
                                                        <Setter Property="Background" Value="#FFFDF0"/>
                                                        <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Top" CornerRadius="8"
                                    Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                                <Border Width="160" Height="120" CornerRadius="8" Cursor="Hand"
                                        Tag="{Binding ImagePath}"
                                        MouseLeftButtonDown="NeedsImage_Click"
                                        ToolTip="Click to enlarge">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding ImagePath}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                    <Border CornerRadius="6" Background="#80000000"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,6,6" Padding="6,3">
                                                        <TextBlock Text="🔍 Zoom" FontSize="10" Foreground="White"/>
                                                    </Border>
                                                </Border>
                                            </Border>

                                            <StackPanel Grid.Column="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,6">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEdit}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="✏️ EDITED / RESUBMITTED — Review changes below"
                                                       FontSize="10" FontWeight="Bold" Foreground="#92400E"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="#0A2540"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock Foreground="#6B7280" FontSize="12" VerticalAlignment="Center">
                                                <Run Text="{Binding Org_Name, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding PostDateDisplay, Mode=OneWay}" Foreground="#9CA3AF"/>
                                                            </TextBlock>
                                                            <Border CornerRadius="6" Padding="8,2" Margin="8,0,0,0" Background="{Binding UrgencyColor}">
                                                                <TextBlock FontSize="11" FontWeight="Bold" Foreground="{Binding UrgencyTextColor}">
                                                    <Run Text="{Binding Urgency, Mode=OneWay}"/>
                                                    <Run Text=" Urgency"/>
                                                                </TextBlock>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#6B7280"
                                                   TextWrapping="Wrap" Margin="0,8,0,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="12,0,0,0">
                                                        <Button Content="✅ Approve + Set Urgency"
                                                Command="{Binding DataContext.ApproveNeedsPostCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ActionButtonSuccessStyle}"
                                                Padding="14,0" Margin="0,0,8,0" FontSize="12"/>
                                                        <Button Content="❌ Reject"
                                                Command="{Binding DataContext.RejectNeedsPostCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ActionButtonDangerStyle}"
                                                Padding="14,0" FontSize="12"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Border Margin="-180,35,0,0" CornerRadius="8"
                                        Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1" Padding="12,10">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEdit}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="28"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="#FEF2F2" CornerRadius="6" Padding="10,8">
                                                            <StackPanel>
                                                                <TextBlock Text="BEFORE" FontSize="9" FontWeight="Bold" Foreground="#EF4444" Margin="0,0,0,5"/>
                                                                <TextBlock Text="{Binding PreviousTitle}" FontSize="12" FontWeight="SemiBold" Foreground="#7F1D1D" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding PreviousDescription}" FontSize="11" Foreground="#991B1B" TextWrapping="Wrap" Margin="0,3,0,4" MaxHeight="50" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock FontSize="11" Foreground="#B91C1C">
                                                    <Run Text="Urgency: "/>
                                                    <Run Text="{Binding PreviousUrgency, Mode=OneWay}" FontWeight="Bold"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="→" FontSize="18" FontWeight="Bold"
                                                   Foreground="#92400E" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                        <Border Grid.Column="2" Background="#F0FFF4" CornerRadius="6" Padding="10,8">
                                                            <StackPanel>
                                                                <TextBlock Text="AFTER" FontSize="9" FontWeight="Bold" Foreground="#16A34A" Margin="0,0,0,5"/>
                                                                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="#14532D" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#166534" TextWrapping="Wrap" Margin="0,3,0,4" MaxHeight="50" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock FontSize="11" Foreground="#15803D">
                                                    <Run Text="Urgency: "/>
                                                    <Run Text="{Binding Urgency, Mode=OneWay}" FontWeight="Bold"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ TAB: BENEFICIARY APPROVALS ══ -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsChecked, ElementName=TabBenes, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Beneficiary Approval Queue" FontSize="26" FontWeight="Bold" Foreground="#0A2540"/>
                            <TextBlock Text="Approve or reject pending beneficiary account registrations." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingBeneficiaries}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="✅" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="No pending beneficiaries — all clear!" FontSize="15" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding PendingBenesList}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingBeneficiaries}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16,14" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Beneficiary_FullName}" FontWeight="Bold" FontSize="15" Foreground="#0A2540"/>
                                                <TextBlock Foreground="#6B7280" FontSize="12" Margin="0,3,0,0">
                                                    <Run Text="{Binding Organization_Name, Mode=OneWay}"/>
                                                    <Run Text=" • "/>
                                                    <Run Text="{Binding Beneficiary_ID, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Command="{Binding DataContext.ApproveBeneficiaryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Content="✅ Approve"
                                                    Style="{StaticResource ActionButtonSuccessStyle}"
                                                    Padding="16,0" Margin="0,0,8,0"/>
                                            <Button Grid.Column="2"
                                                    Command="{Binding DataContext.RejectBeneficiaryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Content="❌ Reject"
                                                    Style="{StaticResource ActionButtonDangerStyle}"
                                                    Padding="16,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ TAB: USER REPORTS ══ -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
              Visibility="{Binding IsChecked, ElementName=TabReports, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Open User Reports" FontSize="26" FontWeight="Bold" Foreground="#0A2540"/>
                            <TextBlock Text="Review filed reports and take action against violating users." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Filter Row -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Padding="10,0">
                                <Grid Width="250" Height="36">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
               Text="🔍" 
               FontSize="13" 
               Foreground="#9CA3AF" 
               Margin="-178,0,4,0" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Center"
               IsHitTestVisible="False"/>

                                    <TextBox x:Name="SearchTextBox"
             Grid.Column="1"
             Text="{Binding ReportSearchQuery, UpdateSourceTrigger=PropertyChanged}" 
             BorderThickness="0" 
             FontSize="13" 
             Foreground="#374151" 
             VerticalContentAlignment="Center" 
             Background="Transparent"
             Padding="-155,0,10,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Resources>
                                                    <VisualBrush x:Key="HintBrush" TileMode="None" Opacity="1" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Search by user or description..." 
                                       FontSize="13" 
                                       Foreground="#9CA3AF" 
                                       Margin="4,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Style.Resources>

                                                <Setter Property="Background" Value="Transparent"/>

                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Text, ElementName=SearchTextBox}" Value=""/>
                                                            <Condition Binding="{Binding IsFocused, ElementName=SearchTextBox}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White">
                                <ComboBox SelectedValue="{Binding ReportTypeFilter}" SelectedValuePath="Content"
                          Height="36" BorderThickness="0" Background="Transparent"
                          Padding="10,0" FontSize="13" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="All Types" IsSelected="True"/>
                                    <ComboBoxItem Content="FakeItem"/>
                                    <ComboBoxItem Content="Fraud"/>
                                    <ComboBoxItem Content="Spam"/>
                                    <ComboBoxItem Content="Inappropriate"/>
                                </ComboBox>
                            </Border>
                        </Grid>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasOpenReports}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="🟢" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="No open reports — platform is clean!" FontSize="15"
                       Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding FilteredReportsList}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasOpenReports}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="12" BorderBrush="#FECACA"
                            BorderThickness="1" Padding="16,14" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Proof image thumbnail — zoomable, only shown when present -->
                                            <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True"
                                    Width="90" Height="90"
                                    Margin="0,0,16,0" VerticalAlignment="Top"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ReportImage_Click"
                                    Tag="{Binding ProofImagePath}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasProofImage}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Image Source="{Binding ProofImagePath}" Stretch="UniformToFill"/>
                                                    <!-- Zoom hint overlay -->
                                                    <Border Background="#CC000000" VerticalAlignment="Bottom" Padding="6,4">
                                                        <TextBlock Text="🔍 Zoom" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White" HorizontalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- No-image placeholder — shown when no proof image -->
                                            <Border Grid.Column="0" Width="90" Height="90" CornerRadius="10"
                                    Background="#F1F5F9" Margin="0,0,16,0" VerticalAlignment="Top">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasProofImage}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="📋" FontSize="28"
                                               HorizontalAlignment="Center" Opacity="0.4"/>
                                                    <TextBlock Text="No photo" FontSize="9"
                                               Foreground="#9CA3AF" HorizontalAlignment="Center"
                                               Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Report details -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <!-- Report type + reported user -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <Border CornerRadius="5" Background="#FEE2E2" Padding="7,3" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding ReportType, Mode=OneWay}"
                                                   FontSize="11" FontWeight="Bold" Foreground="#DC2626"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding ReportedName, Mode=OneWay}"
                                               FontSize="14" FontWeight="Bold" Foreground="#0A2540"
                                               VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Description -->
                                                <TextBlock Text="{Binding Description}" Foreground="#6B7280"
                                           FontSize="12" Margin="0,2,0,0"
                                           TextWrapping="Wrap" MaxHeight="38"
                                           TextTrimming="CharacterEllipsis"/>

                                                <!-- Filed by + date -->
                                                <TextBlock Foreground="#9CA3AF" FontSize="11" Margin="0,6,0,0">
                                    <Run Text="Filed by: "/>
                                    <Run Text="{Binding ReporterName, Mode=OneWay}"
                                         FontWeight="SemiBold" Foreground="#64748B"/>
                                    <Run Text="  •  "/>
                                    <Run Text="{Binding FiledAtDisplay, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Action buttons -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="12,0,0,0">
                                                <Button Content="⚡ Strike"
                                        Command="{Binding DataContext.ProcessReportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Height="34" Padding="14,0" Margin="0,0,8,0" FontSize="12"
                                        Foreground="White" BorderThickness="0" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border CornerRadius="6" Background="#F59E0B" x:Name="bg" Padding="10,0">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#D97706"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Content="🚫 Ban"
                                        Command="{Binding DataContext.AdminBanUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Height="34" Padding="14,0" FontSize="12"
                                        Foreground="White" BorderThickness="0" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border CornerRadius="6" Background="#DC2626" x:Name="bg" Padding="10,0">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#B91C1C"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>


                <!-- ══ TAB: SUPPORT INBOX ══ -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
              Visibility="{Binding IsChecked, ElementName=TabSupport, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20">
                            <!-- Filter Row -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Height="36">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                   Text="🔍" 
                   FontSize="13" 
                   Foreground="#9CA3AF" 
                   Margin="10,0,4,0" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"/>

                                        <TextBox x:Name="SupportSearchTextBox"
                 Grid.Column="1"
                 Text="{Binding SupportSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                 BorderThickness="0" 
                 FontSize="13" 
                 Foreground="#374151"
                 VerticalContentAlignment="Center" 
                 Background="Transparent"
                 Padding="4,0,10,0">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Resources>
                                                        <VisualBrush x:Key="Hint" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="Search by name or message..." 
                                           FontSize="13" 
                                           Foreground="#9CA3AF"
                                           Margin="4,0,0,0"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Style.Resources>

                                                    <Setter Property="Background" Value="Transparent"/>

                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Text, ElementName=SupportSearchTextBox}" Value=""/>
                                                                <Condition Binding="{Binding IsFocused, ElementName=SupportSearchTextBox}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="{StaticResource Hint}"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="2" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White">
                                    <ComboBox SelectedValue="{Binding SupportStatusFilter}" SelectedValuePath="Content"
                  Height="36" BorderThickness="0" Background="Transparent"
                  Padding="10,0" FontSize="13" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="All Users" IsSelected="True"/>
                                        <ComboBoxItem Content="Has Strikes"/>
                                        <ComboBoxItem Content="No Strikes"/>
                                        <ComboBoxItem Content="Banned"/>
                                    </ComboBox>
                                </Border>
                            </Grid>
                            <TextBlock Text="Support Inbox" FontSize="26" FontWeight="Bold" Foreground="#0A2540"/>
                            <TextBlock Text="Manage and respond to active support threads from users." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Donor threads -->
                        <TextBlock Text="🧑‍💼  Donor Messages" FontSize="12" FontWeight="Bold" Foreground="#64748B"
                   Margin="0,0,0,8" Visibility="{Binding HasDonorThreads, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding DonorThreadsFiltered}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14,12" CornerRadius="10" Margin="0,0,0,8"
                            Background="{Binding BackgroundColor}"
                            BorderBrush="{Binding BorderColor}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="#0A2540"/>
                                                    <!-- Ban badge -->
                                                    <Border CornerRadius="4" Padding="6,1" Margin="6,0,0,0" Background="#FEE2E2"
                                            Visibility="{Binding IsBanned, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="🚫 BANNED" FontSize="10" FontWeight="Bold" Foreground="#991B1B"/>
                                                    </Border>
                                                    <!-- Strike badge -->
                                                    <Border CornerRadius="4" Padding="6,1" Margin="6,0,0,0" Background="#FEF3C7"
                                            Visibility="{Binding HasStrikes, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding StrikeBadge}" FontSize="10" FontWeight="Bold" Foreground="#92400E"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding LastMessage}" FontSize="12" Foreground="#6B7280"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                    Command="{Binding DataContext.OpenSupportThreadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Content="💬 Reply" Height="34" Padding="14,0"
                                    Style="{StaticResource ActionButtonPrimaryStyle}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Institutional Beneficiary threads -->
                        <TextBlock Text="🏢  Institutional Beneficiary Messages" FontSize="12" FontWeight="Bold" Foreground="#64748B"
                   Margin="0,0,0,8" Visibility="{Binding HasInstBeneThreads, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding InstBeneThreadsFiltered}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14,12" CornerRadius="10" Margin="0,0,0,8"
                            Background="{Binding BackgroundColor}"
                            BorderBrush="{Binding BorderColor}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="#0A2540"/>
                                                    <Border CornerRadius="4" Padding="6,1" Margin="6,0,0,0" Background="#FEE2E2"
                                            Visibility="{Binding IsBanned, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="🚫 BANNED" FontSize="10" FontWeight="Bold" Foreground="#991B1B"/>
                                                    </Border>
                                                    <Border CornerRadius="4" Padding="6,1" Margin="6,0,0,0" Background="#FEF3C7"
                                            Visibility="{Binding HasStrikes, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding StrikeBadge}" FontSize="10" FontWeight="Bold" Foreground="#92400E"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding LastMessage}" FontSize="12" Foreground="#6B7280"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                    Command="{Binding DataContext.OpenSupportThreadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Content="💬 Reply" Height="34" Padding="14,0"
                                    Style="{StaticResource ActionButtonSuccessStyle}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Independent Beneficiary threads -->
                        <TextBlock Text="👤  Independent Beneficiary Messages" FontSize="12" FontWeight="Bold" Foreground="#64748B"
                   Margin="0,0,0,8" Visibility="{Binding HasIndepBeneThreads, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding IndepBeneThreadsFiltered}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14,12" CornerRadius="10" Margin="0,0,0,8"
                            Background="{Binding BackgroundColor}"
                            BorderBrush="{Binding BorderColor}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="#0A2540"/>
                                                    <Border CornerRadius="4" Padding="6,1" Margin="6,0,0,0" Background="#FEE2E2"
                                            Visibility="{Binding IsBanned, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="🚫 BANNED" FontSize="10" FontWeight="Bold" Foreground="#991B1B"/>
                                                    </Border>
                                                    <Border CornerRadius="4" Padding="6,1" Margin="6,0,0,0" Background="#FEF3C7"
                                            Visibility="{Binding HasStrikes, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding StrikeBadge}" FontSize="10" FontWeight="Bold" Foreground="#92400E"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding LastMessage}" FontSize="12" Foreground="#6B7280"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                    Command="{Binding DataContext.OpenSupportThreadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Content="💬 Reply" Height="34" Padding="14,0"
                                    Style="{StaticResource ActionButtonDangerStyle}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state — only show when ALL three lists are empty -->
                        <TextBlock Text="No support messages yet." FontSize="13" Foreground="#94A3B8"
                   HorizontalAlignment="Center" Margin="0,40,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasDonorThreads}"   Value="False"/>
                                                <Condition Binding="{Binding HasInstBeneThreads}" Value="False"/>
                                                <Condition Binding="{Binding HasIndepBeneThreads}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>