<Window x:Class="KapwaKuha.View.PostItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                                         xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
 mc:Ignorable="d"
d:DataContext="{d:DesignInstance Type=vm:PostItemDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Post Item"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
    
        FontFamily="Segoe UI">
    

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
     
      
    </Window.Resources>

    <Grid>
        <!-- Background gradient -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.10"
               Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center"
               Height="2808" RenderTransformOrigin="0.5,0.5"/>

        <Ellipse Width="450" Height="450" Opacity="0.15"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0077B6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="400" Height="400" Opacity="0.12"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-100,0,0,-100">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA" FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="  /  Post Item" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding DonorLabel}"
                               Foreground="#CAF0F8" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="24,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Form -->
                <Border Grid.Column="0" Background="#AAFFFFFF" BorderBrush="#88FFFFFF"
                        BorderThickness="1.5" CornerRadius="20" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect Color="#0077B6" BlurRadius="24" ShadowDepth="4" Opacity="0.12"/>
                    </Border.Effect>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Post a Donation Item" FontSize="18" FontWeight="Bold"
                                       Foreground="#0A2540" Margin="0,0,0,4"/>
                            <TextBlock Text="Choose how you'd like to donate."
                                       FontSize="13" Foreground="#5E7A8A" Margin="0,0,0,20"/>

                            <!-- Error banner -->
                            <Border Background="#44FF4D4D" BorderBrush="#66FF0000" BorderThickness="1"
                                    CornerRadius="10" Padding="12,10" Margin="0,0,0,16"
                                    Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#B30000"
                                           FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <!-- Post type toggle -->
                            <TextBlock Text="Post Type" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0A2540" Margin="4,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border CornerRadius="10" Padding="14,10" Margin="0,0,12,0" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#6600B4D8"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGeneralPost}" Value="True">
                                                    <Setter Property="Background" Value="#00B4D8"/>
                                                    <Setter Property="BorderBrush" Value="#00B4D8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SetGeneralPostCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🌐  " FontSize="14"/>
                                        <TextBlock Text="General Post" FontSize="14" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#0077B6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsGeneralPost}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="10" Padding="14,10" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#6600B4D8"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDirectTarget}" Value="True">
                                                    <Setter Property="Background" Value="#0077B6"/>
                                                    <Setter Property="BorderBrush" Value="#0077B6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SetDirectTargetCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎯  " FontSize="14"/>
                                        <TextBlock Text="Direct Target" FontSize="14" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#0077B6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectTarget}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Item Name -->
                            <TextBlock Text="Item Name" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0A2540" Margin="4,0,0,8"/>
                            <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                    Padding="12,0" Background="White" Margin="0,0,0,16">
                                <TextBox Text="{Binding ItemName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="40" Background="Transparent" BorderThickness="0"
                                         Foreground="#0A2540" FontSize="14" VerticalContentAlignment="Center"
                                         MaxLength="100"/>
                            </Border>

                            <!-- Description -->
                            <TextBlock Text="Description / Caption" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0A2540" Margin="4,0,0,8"/>
                            <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                    Padding="12,8" Background="White" Margin="0,0,0,16">
                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         Height="64" Background="Transparent" BorderThickness="0"
                                         Foreground="#0A2540" FontSize="13" TextWrapping="Wrap"
                                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                         MaxLength="500"/>
                            </Border>

                            <!-- Item Photo browse row -->
                            <TextBlock Text="Item Photo (required)" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0A2540" Margin="4,0,0,8"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="10" BorderBrush="#6600B4D8"
                                        BorderThickness="1" Padding="12,0" Background="White">
                                    <TextBox Text="{Binding ImagePath}" Height="40"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="#5E7A8A" FontSize="12"
                                             IsReadOnly="True" VerticalContentAlignment="Center"/>
                                </Border>
                                <Button Grid.Column="2" Command="{Binding BrowseImageCommand}"
                                        Height="40" Padding="14,0" BorderThickness="0" Cursor="Hand" Width="70">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="10" Background="#0077B6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="📷 Browse" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                </Button>
                            </Grid>

                            <!-- Category + Condition -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Category" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#0A2540" Margin="4,0,0,8"/>
                                    <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                            Background="White">
                                        <ComboBox ItemsSource="{Binding Categories}"
                                                  SelectedItem="{Binding SelectedCategory}"
                                                  Height="40" Background="Transparent" BorderThickness="0"
                                                  Foreground="#0A2540" FontSize="13" Padding="10,0"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Condition" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#0A2540" Margin="4,0,0,8"/>
                                    <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                            Background="White">
                                        <ComboBox ItemsSource="{Binding Conditions}"
                                                  SelectedItem="{Binding SelectedCondition}"
                                                  Height="40" Background="Transparent" BorderThickness="0"
                                                  Foreground="#0A2540" FontSize="13" Padding="10,0"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Direct Target beneficiary picker -->
                            <!-- Direct Target beneficiary picker — smart swap -->
                            <StackPanel Margin="0,0,0,20"
            Visibility="{Binding IsDirectTarget, Converter={StaticResource BoolToVis}}">

                                <TextBlock Text="Target Beneficiary" FontSize="13" FontWeight="SemiBold"
               Foreground="#0A2540" Margin="4,0,0,8"/>

                                <!-- READ-ONLY TextBox: shown when called from HighPriorityNeeds (mode is locked) -->
                                <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
            Background="#F0F8FB">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsModeLocked}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" Margin="12,0">
                                        <TextBlock Text="🎯 " FontSize="15" VerticalAlignment="Center"
                       Foreground="#0077B6"/>
                                        <TextBox Text="{Binding LockedBeneficiaryDisplay, Mode=OneWay}"
                     Height="40" Background="Transparent" BorderThickness="0"
                     FontSize="13" FontWeight="SemiBold" Foreground="#0077B6"
                     IsReadOnly="True" IsTabStop="False"
                     VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- COMBOBOX: shown for free selection when NOT locked -->
                                <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
            Background="White">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsModeLocked}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <ComboBox ItemsSource="{Binding Beneficiaries}"
                  SelectedItem="{Binding SelectedBeneficiary}"
                  DisplayMemberPath="DisplayName"
                  Height="40" Background="Transparent" BorderThickness="0"
                  Foreground="#0A2540" FontSize="13" Padding="10,0"/>
                                </Border>
                            </StackPanel>

                            <!-- Submit button -->
                            <Button Command="{Binding SaveCommand}" Height="48"
                                    FontSize="14" FontWeight="Bold" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" Margin="0,8,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="12" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#AABBBCCC"/>
                                                <Setter Property="Foreground" Value="#777777"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00B4D8" Offset="0"/>
                                        <GradientStop Color="#0077B6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="🤲  Post Item"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Text" Value="Posting..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Right: Preview panel -->
                <Border Grid.Column="2" Background="#AAFFFFFF" BorderBrush="#88FFFFFF"
                        BorderThickness="1.5" CornerRadius="20" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#0077B6" BlurRadius="24" ShadowDepth="4" Opacity="0.12"/>
                    </Border.Effect>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="📷 Photo Preview" FontSize="15" FontWeight="Bold"
                                       Foreground="#0A2540" Margin="0,0,0,12"/>

                            <!-- Rectangle image preview — same pattern as Car Rentals -->
                            <Border CornerRadius="12" Height="170" ClipToBounds="True"
                                    Margin="0,0,0,20">
                                <Grid>
                                    <!-- Placeholder shown when no image selected -->
                                    <Border>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#EBF7FB" Offset="0"/>
                                                <GradientStop Color="#CAF0F8" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="No photo selected" FontSize="11"
                                                   Foreground="#78909C" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <!-- Actual image — WPF handles local file path string directly -->
                                    <Image Source="{Binding ImagePath}" Stretch="UniformToFill"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </Border>

                            <!-- How it works info cards -->
                            <TextBlock Text="📘 How It Works" FontSize="15" FontWeight="Bold"
                                       Foreground="#0A2540" Margin="0,0,0,16"/>

                            <Border Background="#66EBF7FB" BorderBrush="#4400B4D8" BorderThickness="1"
                                    CornerRadius="12" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🌐  General Post" FontSize="13" FontWeight="Bold"
                                               Foreground="#0077B6" Margin="0,0,0,6"/>
                                    <TextBlock Text="Your item goes to the public marketplace. Any beneficiary can browse and claim it."
                                               FontSize="12" Foreground="#0A2540" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#66F0F8FF" BorderBrush="#440077B6" BorderThickness="1"
                                    CornerRadius="12" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎯  Direct Target" FontSize="13" FontWeight="Bold"
                                               Foreground="#03045E" Margin="0,0,0,6"/>
                                    <TextBlock Text="Select a specific beneficiary. The item goes straight to their Claim Tracker."
                                               FontSize="12" Foreground="#0A2540" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#66F0FFF4" BorderBrush="#442E7D52" BorderThickness="1"
                                    CornerRadius="12" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="💙 Kapwa Spirit" FontSize="13" FontWeight="Bold"
                                               Foreground="#2E7D52" Margin="0,0,0,6"/>
                                    <TextBlock Text="Every item you post is a connection. Donating is something they await."
                                               FontSize="12" Foreground="#1B5E20" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Grid>
            </ScrollViewer>
    </Grid>
</Window>