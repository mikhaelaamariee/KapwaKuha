<Window x:Class="KapwaKuha.View.EditNeedsPostUrgencyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Edit My Needs Posts"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.05"
               Width="1980" Height="2808"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand"
                            VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Edit My Need Posts" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="⟳ Refresh" Background="Transparent" BorderThickness="0"
                            Foreground="#CAF0F8" FontSize="12" Cursor="Hand"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,14,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="16" BorderThickness="1.5" Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CCFFFFFF" Offset="0"/>
                            <GradientStop Color="#66FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="#33FFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="20,16,20,12">
                            <TextBlock Text="📋 My Need Posts" FontSize="15"
                                       FontWeight="Bold" Foreground="#03045E"/>
                            <TextBlock Text="Click a post to select it, then edit or delete it."
                                       FontSize="11" Foreground="#5E7A8A" Margin="0,3,0,0"/>
                        </StackPanel>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding MyPosts}"
                                 SelectedItem="{Binding SelectedPost}"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EBF7FB"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F0F8FB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,12" BorderBrush="#EBF7FB"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#03045E"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11" Foreground="#5E7A8A"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="8"
                                                    Padding="8,3" VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F0FFF4"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Urgency}" Value="High">
                                                                <Setter Property="Background" Value="#FFF0F0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Urgency}" Value="Medium">
                                                                <Setter Property="Background" Value="#FFFCE6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Urgency}" FontSize="11"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#2E7D52"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Urgency}" Value="High">
                                                                    <Setter Property="Foreground" Value="#C0304A"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Urgency}" Value="Medium">
                                                                    <Setter Property="Foreground" Value="#B8860B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="2" CornerRadius="16" BorderThickness="1.5" Padding="24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CCFFFFFF" Offset="0"/>
                            <GradientStop Color="#66FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="#33FFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="✏️ Edit Selected Post" FontSize="15"
                                   FontWeight="Bold" Foreground="#03045E" Margin="0,0,0,6"/>
                        <TextBlock Text="Select a post on the left to edit it."
                                   FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,24"/>

                        <TextBlock Text="← Select a post to begin editing"
                                   FontSize="13" Foreground="#90A4AE"
                                   HorizontalAlignment="Center" Margin="0,40,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">

                            <TextBlock Text="Title" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0A2540" Margin="4,0,0,8"/>
                            <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                    Padding="12,0" Background="White" Margin="0,0,0,16">
                                <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                         Height="40" Background="Transparent" BorderThickness="0"
                                         FontSize="14" Foreground="#0A2540" VerticalContentAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Photo" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0A2540" Margin="4,0,0,8"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="10" BorderBrush="#6600B4D8"
                                        BorderThickness="1" Padding="12,0" Background="White">
                                    <TextBox Text="{Binding EditImagePath}" Height="40"
                                             Background="Transparent" BorderThickness="0"
                                             FontSize="12" Foreground="#5E7A8A" IsReadOnly="True"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                                <Button Grid.Column="2" Command="{Binding BrowseImageCommand}"
                                        Height="40" Padding="14,0" BorderThickness="0" Cursor="Hand" Width="69.6">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="10" Background="#0077B6" Padding="0,0,0,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="📷 Browse" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                </Button>
                            </Grid>

                            <Border CornerRadius="10" ClipToBounds="True" Height="140" Margin="0,0,0,16">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEditImage}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Image Source="{Binding EditImagePath}" Stretch="UniformToFill"/>
                            </Border>

                            <TextBlock Text="Urgency Level" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0A2540" Margin="4,0,0,8"/>
                            <Border CornerRadius="10" BorderBrush="#6600B4D8"
                                    BorderThickness="1" Background="White"
                                    Margin="0,0,0,8">
                                <ComboBox SelectedValue="{Binding SelectedUrgency}"
                                          SelectedValuePath="Content"
                                          Height="42" Background="Transparent"
                                          BorderThickness="0" Padding="12,0"
                                          FontSize="13" FontWeight="SemiBold">
                                    <ComboBoxItem Content="Low"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="High"/>
                                </ComboBox>
                            </Border>

                            <TextBlock FontSize="11" Foreground="#5E7A8A"
                                       Margin="0,0,0,24" TextWrapping="Wrap">
                                <Run Text="🟢 Low"/>
                                <Run Text=" — not urgent  "/>
                                <Run Text="🟡 Medium"/>
                                <Run Text=" — soon  "/>
                                <Run Text="🔴 High"/>
                                <Run Text=" — urgent"/>
                            </TextBlock>

                            <Button Command="{Binding SaveUrgencyCommand}"
                                    Height="44" FontSize="13" FontWeight="Bold"
                                    Foreground="White" BorderThickness="0"
                                    Cursor="Hand" Margin="0,0,0,12">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="10"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00B4D8" Offset="0"/>
                                        <GradientStop Color="#0077B6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <TextBlock Text="💾  Save Changes"/>
                            </Button>

                            <Button Command="{Binding DeletePostCommand}"
                                    Height="44" FontSize="13" FontWeight="Bold"
                                    Foreground="White" Background="#C0304A"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="10"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="🗑️  Delete This Post"/>
                            </Button>

                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>