<!-- FILE: View/DonorClaimTrackerWindow.xaml -->
<Window x:Class="KapwaKuha.View.DonorClaimTrackerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
 mc:Ignorable="d"
d:DataContext="{d:DesignInstance Type=vm:ClaimTrackerDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Claim Tracker (Donor)"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        
        >

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.06"
               Width="1980" Height="2808"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            
            
            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Claim Tracker" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="⟳ Refresh" Background="Transparent" BorderThickness="0"
                            Foreground="#CAF0F8" FontSize="12" Cursor="Hand" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            
            

            <!-- Main content -->
            <Border Grid.Row="1" CornerRadius="16" Margin="20,14,20,20" BorderThickness="1.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="#33FFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,16,20,10">
                        <TextBlock Text="📦 My Claim Tracker" FontSize="16" FontWeight="Bold"
                                   Foreground="#03045E"/>
                        <TextBlock Text="Overview of claims on items you have donated — read only view."
                                   FontSize="11" Foreground="#5E7A8A" Margin="0,3,0,0"/>

                        <!-- Add AFTER the subtitle TextBlock inside the StackPanel Grid.Row="0": -->
                        <Border CornerRadius="8" BorderBrush="#90E0EF" BorderThickness="1.5"
        Background="White" Padding="10,0" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center"
                   Margin="0,0,6,0" Foreground="#5E7A8A"/>
                                <TextBox Grid.Column="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Height="34" Background="Transparent" BorderThickness="0"
                 FontSize="12" Foreground="#03045E" VerticalContentAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                    
                    

                    <!-- READ-ONLY DataGrid — no Action column whatsoever -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Claims}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" CanUserResizeRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single" Background="Transparent"
                              BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EBF7FB"
                              RowBackground="White" AlternatingRowBackground="#F7FBFD"
                              ColumnHeaderHeight="38" RowHeight="68" FontSize="13"
                              Margin="0,0,0,8">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#EBF7FB"/>
                                <Setter Property="Foreground" Value="#0077B6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="14,0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <!-- Photo thumbnail -->
                            <DataGridTemplateColumn Header="Photo" Width="70" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="52" Height="52" CornerRadius="8"
                                                ClipToBounds="True" Margin="6,4">
                                            <Grid>
                                                <Border Background="#EBF7FB"/>
                                                <TextBlock Text="📦" FontSize="24"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Image Source="{Binding Item_ImagePath}"
                                                       Stretch="UniformToFill">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Claim ID" Binding="{Binding Claim_ID}"
                                                Width="90" IsReadOnly="True"/>

                            <DataGridTextColumn Header="Item Name" Binding="{Binding Item_Name}"
                                                Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Beneficiary"
                                                Binding="{Binding Beneficiary_Name}"
                                                Width="140" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Foreground" Value="#03045E"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Handoff"
                                                Binding="{Binding Handoff_Type}"
                                                Width="110" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Claim Date"
                                                Binding="{Binding ClaimDateDisplay}"
                                                Width="160" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Foreground" Value="#5E7A8A"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Status badge — read-only display only -->
                            <DataGridTemplateColumn Header="Status" Width="120" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="12,5"
                                                HorizontalAlignment="Left" Margin="6,0"
                                                Background="{Binding StatusBadgeBackground}">
                                            <TextBlock Text="{Binding Claim_Status}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding StatusBadgeColor}"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- NO Action column in Donor view -->

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            
            

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#03045E" Padding="20,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#90E0EF" FontSize="11" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>