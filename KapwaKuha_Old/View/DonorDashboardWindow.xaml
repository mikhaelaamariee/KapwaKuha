<Window x:Class="KapwaKuha.View.DonorDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:DonorDashboardDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Donor Dashboard"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" ResizeMode="CanResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <!-- Background -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.05"
               Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center"
               Height="2808" RenderTransformOrigin="0.5,0.5"/>
        <Ellipse Width="380" Height="380" Opacity="0.13"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Root layout: Sidebar | Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Style="{StaticResource AnimatedSidebarStyle}"
                    BorderThickness="0,0,1.5,0">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="#4D0077B6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Brand header -->
                    <StackPanel Grid.Row="0" Margin="20,24,20,16">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="38" Height="38" Margin="0,0,4,0">
                                <Image Source="https://i.imgur.com/FHFRQxB.png"
                                       Width="60" Height="60"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                                <Run Foreground="#FF03045E" Text="Kapwa"/><Run Foreground="#FF00B4D8" Text="Kuha"/>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="Donor Portal" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#0077B6" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding UserLabel}" FontSize="11"
                                   Foreground="#5E7A8A" Margin="0,4,0,0"/>
                        <Rectangle Height="1.2" Margin="0,16,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#330077B6" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>

                    <!-- Nav buttons -->
                    <StackPanel Grid.Row="1" Margin="12,0">
                        <Button Command="{Binding NavigateDashboardCommand}" Style="{StaticResource CardHoverBtn}"
                                Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏠" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Dashboard" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding PostItemCommand}" Style="{StaticResource CardHoverBtn}"
                                Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🤲" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Post an Item" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding ActiveListingsCommand}" Style="{StaticResource CardHoverBtn}"
                                Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Active Listings" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding HighPriorityNeedsCommand}" Style="{StaticResource CardHoverBtn}"
                                Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚨" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Priority Needs" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding ChatCommand}" Style="{StaticResource CardHoverBtn}"
                                Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12"
                                    Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💬" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Messages" Foreground="#03045E"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>

                    <!-- Logout -->
                    <StackPanel Grid.Row="2" Margin="12,0,12,24">
                        <Rectangle Height="1.2" Margin="8,0,8,16">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A0077B6" Offset="0"/>
                                    <GradientStop Color="#330077B6" Offset="0.5"/>
                                    <GradientStop Color="#1A0077B6" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Button Command="{Binding LogoutCommand}" Style="{StaticResource CardHoverBtn}" Padding="0">
                            <Border CornerRadius="12" Padding="12,12" Background="#1AC0304A">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬅" Margin="0,0,12,0" Foreground="#C0304A" FontSize="14"/>
                                    <TextBlock Text="Log Out" Foreground="#C0304A"
                                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN CONTENT AREA -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top bar -->
                <Border Grid.Row="0" Background="#AAFFFFFF">
                    <Border.Effect>
                        <DropShadowEffect Color="#0077B6" BlurRadius="10" ShadowDepth="0" Opacity="0.10"/>
                    </Border.Effect>
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding HamburgerCommand}"
                                Content="☰" Foreground="#03045E" Background="Transparent"
                                BorderThickness="0" FontSize="22" Cursor="Hand" VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1" Text="{Binding WelcomeText}"
                                   Foreground="#03045E" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="14,0,0,0"/>

                        <!-- Profile chip -->
                        <Border Grid.Column="2" CornerRadius="20" Padding="4,4,12,4"
                                VerticalAlignment="Center"
                                Background="#E6FFFFFF" BorderBrush="#B390E0EF" BorderThickness="1" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding MyAccountCommand}"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="18" ClipToBounds="True"
                                        Cursor="Hand" Margin="0,0,8,0">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding MyAccountCommand}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Border Background="#EBF7FB" CornerRadius="18"/>
                                        <TextBlock Text="👤" FontSize="20"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Image Source="{Binding ProfilePicturePath}" Stretch="UniformToFill">
                                            <Image.Clip>
                                                <EllipseGeometry RadiusX="18" RadiusY="18" Center="18,18"/>
                                            </Image.Clip>
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding UserLabel}" FontSize="12"
                                           Foreground="#03045E" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text=" ▼" FontSize="9" Foreground="#5E7A8A"
                                           VerticalAlignment="Center" Margin="6,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Scrollable body -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,24,0,0">
                    <StackPanel>

                        <!-- Two-column row: My Impact + Messages -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="{Binding MessagesColumnWidth}"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── LEFT COLUMN: Hero + My Impact ── -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">

                                <!-- Hero banner -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="What would you like to do today?"
                                                   FontSize="20" FontWeight="Bold" Foreground="#03045E"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="Post items, track impact, or respond to community needs."
                                                   FontSize="12" Foreground="#5E7A8A"/>
                                    </StackPanel>

                                    <Border Grid.Column="2" Background="#EBF7FB" CornerRadius="14"
                                            Padding="18,12" VerticalAlignment="Center" MaxWidth="340">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#00B4D8" BlurRadius="10" ShadowDepth="0" Opacity="0.10"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Text="💙 Kapwa Impact" FontSize="13" FontWeight="Bold"
                                                       Foreground="#0077B6" Margin="0,0,0,4"/>
                                            <TextBlock FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap"
                                                       Text="Every item you donate is a connection. You're not just giving things — you're giving hope and dignity to your community."/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- ── MY IMPACT ── -->
                                <Border CornerRadius="16" Margin="0,0,0,20" BorderThickness="1.5" Padding="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                            <GradientStop Color="#66FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="White" Offset="0"/>
                                            <GradientStop Color="#33FFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="My Impact" FontSize="15" FontWeight="Bold"
                                                   Foreground="#03045E" Margin="20,16,20,14"/>
                                        <UniformGrid Rows="1" Columns="4" Margin="12,0,12,16">

                                            <!-- Total Donated -->
                                            <Border Margin="6,0" CornerRadius="14" BorderThickness="1.5" Padding="16,20">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#90E0EF" Offset="0"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#F0FAFF" Offset="0"/>
                                                        <GradientStop Color="#E8F7FC" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <TextBlock Text="🤲" FontSize="22" Margin="0,0,0,8"/>
                                                    <TextBlock Text="Total Donated" FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding TotalDonated}" FontSize="28" FontWeight="Bold" Foreground="#00B4D8"/>
                                                    <TextBlock Text="items posted" FontSize="11" Foreground="#5E7A8A"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Successfully Claimed -->
                                            <Border Margin="6,0" CornerRadius="14" BorderThickness="1.5" Padding="16,20">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#B7EFC5" Offset="0"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#F0FFF5" Offset="0"/>
                                                        <GradientStop Color="#E6F9EE" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <TextBlock Text="✅" FontSize="22" Margin="0,0,0,8"/>
                                                    <TextBlock Text="Successfully Claimed" FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding TotalClaimed}" FontSize="28" FontWeight="Bold" Foreground="#2DC653"/>
                                                    <TextBlock Text="items received" FontSize="11" Foreground="#5E7A8A"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Still Available -->
                                            <Border Margin="6,0" CornerRadius="14" BorderThickness="1.5" Padding="16,20">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#90CAF9" Offset="0"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#F0F4FF" Offset="0"/>
                                                        <GradientStop Color="#EAF0FF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <TextBlock Text="📦" FontSize="22" Margin="0,0,0,8"/>
                                                    <TextBlock Text="Still Available" FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding ActiveItems}" FontSize="28" FontWeight="Bold" Foreground="#0077B6"/>
                                                    <TextBlock Text="awaiting claim" FontSize="11" Foreground="#5E7A8A"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Needs Fulfilled -->
                                            <Border Margin="6,0" CornerRadius="14" BorderThickness="1.5" Padding="16,20">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#F4A7B9" Offset="0"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FFF0F4" Offset="0"/>
                                                        <GradientStop Color="#FFE6EC" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <TextBlock Text="🏷" FontSize="22" Margin="0,0,0,8"/>
                                                    <TextBlock Text="Needs Fulfilled" FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding FulfilledNeeds}" FontSize="28" FontWeight="Bold" Foreground="#C0304A"/>
                                                    <TextBlock Text="priority needs resolved" FontSize="11" Foreground="#5E7A8A"/>
                                                </StackPanel>
                                            </Border>

                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                                <!-- ── END MY IMPACT ── -->

                            </StackPanel>

                            <!-- ── RIGHT COLUMN — MESSAGES ── -->
                            <Border Grid.Column="1" CornerRadius="16" BorderThickness="1.5"
                                    VerticalAlignment="Top" MinHeight="300" Margin="0,0,0,24">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="White" Offset="0"/>
                                        <GradientStop Color="#33FFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.Effect>
                                    <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                                </Border.Effect>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <StackPanel Grid.Row="0" Margin="16,14,16,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Messages" FontSize="14" FontWeight="Bold"
                                                       Foreground="#03045E" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Command="{Binding ChatCommand}"
                                                    Content="View all" Background="Transparent"
                                                    BorderThickness="0" Foreground="#0077B6" FontSize="11"
                                                    Cursor="Hand" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Height="1" Margin="0,10,0,0">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#33CAF0F8" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                    </StackPanel>

                                    <!-- Chat user list -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="340">
                                        <ItemsControl ItemsSource="{Binding RecentChats}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="14,10" Cursor="Hand" Background="Transparent">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.OpenChatWithCommand,
                                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#0F00B4D8"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="42"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="38" Height="38" CornerRadius="19"
                                                                    ClipToBounds="True" Background="#EBF7FB">
                                                                <Grid>
                                                                    <TextBlock Text="👤" FontSize="18"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>

                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,8,0">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontSize="13" FontWeight="SemiBold"
                                                                           Foreground="#03045E"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding LastMessage}"
                                                                           FontSize="11" Foreground="#5E7A8A"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,2,0,0"/>
                                                            </StackPanel>

                                                            <Border Grid.Column="2" CornerRadius="10"
                                                                    Background="#00B4D8" Padding="6,2"
                                                                    VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasUnread}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding UnreadCount}"
                                                                           FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Empty state -->
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Margin="16,20">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasNoChats}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="💬" FontSize="32" HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8"/>
                                        <TextBlock Text="No messages yet" FontSize="12" Foreground="#5E7A8A" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Open Messages button -->
                                    <Button Grid.Row="2" Command="{Binding ChatCommand}"
                                            Margin="14,8,14,14" Height="36"
                                            BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="10" Background="#EBF7FB">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="Open Messages" FontSize="12" FontWeight="SemiBold" Foreground="#0077B6"/>
                                    </Button>

                                </Grid>
                            </Border>

                        </Grid>
                        <!-- ── END two-column row ── -->

                        <!-- ── MY POSTS — full width ── -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="My Posts" FontSize="16" FontWeight="Bold"
                                       Foreground="#03045E" Margin="0,0,0,14"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left arrow -->
                                <Button Grid.Column="0"
                                        Command="{Binding CarouselLeftCommand}"
                                        Width="36" Height="36" Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="18" Background="#CCF0FAFF"
                                                    BorderBrush="#9090E0EF" BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="‹" FontSize="20" FontWeight="Bold"
                                               Foreground="#0077B6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>

                                <!-- Carousel scroll host -->
                                <ScrollViewer Grid.Column="1"
                                              x:Name="PostsCarouselScroller"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Disabled">
                                    <StackPanel Orientation="Horizontal">

                                        <ItemsControl ItemsSource="{Binding MyPosts}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="220" Margin="0,0,14,0" CornerRadius="16"
                                                            ClipToBounds="True" BorderThickness="1">
                                                        <Border.BorderBrush>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="White" Offset="0"/>
                                                                <GradientStop Color="#33FFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.BorderBrush>
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                                                <GradientStop Color="#AAFFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#00B4D8" BlurRadius="12" ShadowDepth="0" Opacity="0.12"/>
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <Border Height="140" ClipToBounds="True">
                                                                <Grid>
                                                                    <Border Background="#EBF7FB"/>
                                                                    <TextBlock Text="📦" FontSize="40"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Opacity="0.5">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <Image Source="{Binding Item_ImagePath}" Stretch="UniformToFill">
                                                                        <Image.Style>
                                                                            <Style TargetType="Image">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Image.Style>
                                                                    </Image>
                                                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                            Margin="0,8,8,0" CornerRadius="8" Padding="8,3"
                                                                            Background="{Binding StatusBadgeBackground}">
                                                                        <TextBlock Text="{Binding Item_Status}"
                                                                                   FontSize="10" FontWeight="SemiBold"
                                                                                   Foreground="{Binding StatusBadgeColor}"/>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>

                                                            <StackPanel Margin="14,10,14,14">
                                                                <TextBlock Text="{Binding Item_Name}"
                                                                           FontSize="13" FontWeight="Bold"
                                                                           Foreground="#03045E"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Category_Name}"
                                                                           FontSize="11" Foreground="#0077B6"
                                                                           Margin="0,2,0,6"/>

                                                                <!-- Sidebar OPEN: View Description -->
                                                                <Button Command="{Binding DataContext.ViewDescriptionCommand,
                                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Height="34" BorderThickness="0" Cursor="Hand"
                                                                        FontSize="12" FontWeight="SemiBold"
                                                                        Foreground="#0077B6">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Setter Property="Background" Value="#EBF7FB"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter Property="Opacity" Value="0.85"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding DataContext.IsSidebarOpen,
                                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                             Value="False">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <TextBlock Text="View Description"/>
                                                                </Button>

                                                                <!-- Sidebar CLOSED: Edit Post -->
                                                                <Button Command="{Binding DataContext.EditPostCommand,
                                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Height="34" BorderThickness="0" Cursor="Hand"
                                                                        FontSize="12" FontWeight="SemiBold"
                                                                        Foreground="White">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border CornerRadius="10">
                                                                                            <Border.Background>
                                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                                    <GradientStop Color="#00B4D8" Offset="0"/>
                                                                                                    <GradientStop Color="#0077B6" Offset="1"/>
                                                                                                </LinearGradientBrush>
                                                                                            </Border.Background>
                                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter Property="Opacity" Value="0.85"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding DataContext.IsSidebarOpen,
                                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                             Value="False">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <TextBlock Text="Edit Post"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Add post button -->
                                        <Button Command="{Binding PostItemCommand}"
                                                Width="220" Margin="0,0,0,0"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="16" Background="#18CAF0F8"
                                                            BorderBrush="#7090E0EF" BorderThickness="2">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.9"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="+" FontSize="42" FontWeight="Light"
                                                           Foreground="#0077B6" HorizontalAlignment="Center" Opacity="0.7"/>
                                                <TextBlock Text="Add Post" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#0077B6" HorizontalAlignment="Center"
                                                           Opacity="0.8" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Button>

                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Right arrow -->
                                <Button Grid.Column="2"
                                        Command="{Binding CarouselRightCommand}"
                                        Width="36" Height="36" Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="18" Background="#CCF0FAFF"
                                                    BorderBrush="#9090E0EF" BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="›" FontSize="20" FontWeight="Bold"
                                               Foreground="#0077B6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>

                            </Grid>
                        </StackPanel>
                        <!-- ── END MY POSTS ── -->

                        <!-- ── TRANSACTION HISTORY — full width, bottom ── -->
                        <Border CornerRadius="16" Margin="0,0,0,24" BorderThickness="1.5" Padding="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#33FFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="20,16,20,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="📜 Transaction History" FontSize="15" FontWeight="Bold"
                                               Foreground="#03045E" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TransactionStatus}"
                                               FontSize="11" Foreground="#5E7A8A" VerticalAlignment="Center"/>
                                </Grid>
                                <Rectangle Height="1" Margin="20,0,20,12">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#33CAF0F8" Offset="0"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <!-- Loading indicator -->
                                <TextBlock Text="Loading transaction history…"
                                           FontSize="12" Foreground="#5E7A8A"
                                           HorizontalAlignment="Center" Margin="0,20,0,20">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoadingTransactions}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Table header -->
                                <Border Background="#F0FAFF" Margin="12,0,12,0" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Item" FontSize="11" FontWeight="Bold" Foreground="#0077B6"/>
                                        <TextBlock Grid.Column="1" Text="Beneficiary" FontSize="11" FontWeight="Bold" Foreground="#0077B6"/>
                                        <TextBlock Grid.Column="2" Text="Organization" FontSize="11" FontWeight="Bold" Foreground="#0077B6"/>
                                        <TextBlock Grid.Column="3" Text="Handoff" FontSize="11" FontWeight="Bold" Foreground="#0077B6"/>
                                        <TextBlock Grid.Column="4" Text="Date" FontSize="11" FontWeight="Bold" Foreground="#0077B6" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <!-- Transaction rows -->
                                <ItemsControl ItemsSource="{Binding Transactions}" Margin="12,0,12,12">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,10" BorderBrush="#EBF7FB" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Item_Name}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#03045E" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Category_Name}" FontSize="11" Foreground="#0077B6"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Beneficiary_Name}"
                                                               FontSize="12" Foreground="#03045E" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Organization_Name}"
                                                               FontSize="12" Foreground="#5E7A8A" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Handoff_Type}"
                                                               FontSize="12" Foreground="#5E7A8A" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding Claim_Date, StringFormat='MMM d, yyyy'}"
                                                               FontSize="11" Foreground="#5E7A8A" VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty state -->
                                <StackPanel HorizontalAlignment="Center" Margin="16,20,16,20">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasNoTransactions}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="📜" FontSize="28" HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8"/>
                                    <TextBlock Text="No completed donations yet." FontSize="12"
                                               Foreground="#5E7A8A" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- ── END TRANSACTION HISTORY ── -->

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>