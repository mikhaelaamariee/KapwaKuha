<Window x:Class="KapwaKuha.View.BeneficiaryClaimTrackerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — My Claims"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.06"
               Width="1980" Height="2808"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="My Claims" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="⟳ Refresh" Background="Transparent" BorderThickness="0"
                            Foreground="#CAF0F8" FontSize="12" Cursor="Hand" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" CornerRadius="16" Margin="20,14,20,20" BorderThickness="1.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="#33FFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,16,20,10">
                        <TextBlock Text="📦 My Claims" FontSize="16" FontWeight="Bold" Foreground="#03045E"/>
                        <TextBlock Text="Items claimed from the marketplace or donated directly to you."
                                   FontSize="11" Foreground="#5E7A8A" Margin="0,3,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Claims}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" CanUserResizeRows="False"
                              SelectionMode="Single" Background="Transparent"
                              BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EBF7FB"
                              RowBackground="White" AlternatingRowBackground="#F7FBFD"
                              ColumnHeaderHeight="38" RowHeight="72" FontSize="13"
                              Margin="0,0,0,8">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#EBF7FB"/>
                                <Setter Property="Foreground" Value="#0077B6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="14,0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <DataGridTemplateColumn Header="Photo" Width="70" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="52" Height="52" CornerRadius="8" ClipToBounds="True" Margin="6,4">
                                            <Grid>
                                                <Border Background="#EBF7FB"/>
                                                <TextBlock Text="📦" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Image Source="{Binding Item_ImagePath}" Stretch="UniformToFill">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasItemImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Claim ID" Binding="{Binding Claim_ID}" Width="90" IsReadOnly="True"/>

                            <DataGridTextColumn Header="Item Name" Binding="{Binding Item_Name}" Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Handoff" Binding="{Binding Handoff_Type}" Width="110" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Claim Date" Binding="{Binding ClaimDateDisplay}" Width="160" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Foreground" Value="#5E7A8A"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Status" Width="120" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="12,5" HorizontalAlignment="Left" Margin="6,0" Background="{Binding StatusBadgeBackground}">
                                            <TextBlock Text="{Binding Claim_Status}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding StatusBadgeColor}" VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- REPLACE the Action DataGridTemplateColumn with: -->
                            <DataGridTemplateColumn Header="Action" Width="180" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="6"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status ComboBox — options: Pending, Released/Received, Cancelled -->
                                            <Border Grid.Column="0" CornerRadius="6" BorderBrush="#90E0EF"
                        BorderThickness="1" Background="White">
                                                <ComboBox x:Name="StatusCombo"
                              SelectedValue="{Binding SelectedStatusOption, Mode=TwoWay}"
                              SelectedValuePath="Content"
                              Background="Transparent" BorderThickness="0"
                              FontSize="11" Padding="6,0" Height="30">
                                                    <ComboBoxItem Content="Pending"/>
                                                    <ComboBoxItem Content="Released/Received"/>
                                                    <ComboBoxItem Content="Cancelled"/>
                                                </ComboBox>
                                            </Border>

                                            <!-- Apply button -->
                                            <Button Grid.Column="2" Height="30" Width="32" Padding="0"
                        ToolTip="Apply status change"
                        Command="{Binding DataContext.UpdateClaimStatusCommand,
                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding}"
                        BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="6" Background="#0077B6">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <TextBlock Text="✔" FontSize="12" Foreground="White"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="#03045E" Padding="20,0">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#90E0EF" FontSize="11" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>