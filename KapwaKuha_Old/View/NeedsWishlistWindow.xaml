<Window x:Class="KapwaKuha.View.NeedsWishlistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 mc:Ignorable="d"
d:DataContext="{d:DesignInstance Type=vm:NeedsWishlistDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Needs Wishlist"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.06" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black" Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Needs Wishlist" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#44FF4D4D" BorderBrush="#66FF0000" BorderThickness="1" 
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,16" MaxWidth="800"
                            Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#B30000" FontWeight="SemiBold"
                                   FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="0.8*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#EEFFFFFF" BorderBrush="#88FFFFFF" BorderThickness="1.5" 
                                CornerRadius="20" Padding="32" Margin="0,0,16,0" VerticalAlignment="Stretch">
                            <Border.Effect>
                                <DropShadowEffect Color="#0077B6" BlurRadius="20" ShadowDepth="4" Opacity="0.08"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="20" FontWeight="Bold" Foreground="#0A2540" Margin="0,0,0,4">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="📝 Post a New Need"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Text" Value="✏️ Edit Your Post"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="Fill out the details of what your organization urgently needs."
                                                       FontSize="13" Foreground="#5E7A8A"/>
                                        </StackPanel>

                                        <Button Grid.Column="1" Command="{Binding ClearSelectionCommand}" Height="34" Padding="16,0"
                                                FontSize="12" FontWeight="SemiBold" Foreground="#0077B6"
                                                BorderBrush="#0077B6" BorderThickness="1.5" Background="Transparent" Cursor="Hand"
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="✕ Cancel Edit"/>
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="Request Title" FontSize="13" FontWeight="SemiBold" Foreground="#0A2540" Margin="4,0,0,8"/>
                                    <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                            Padding="12,0" Background="White" Margin="0,0,0,20">
                                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="44" Background="Transparent" BorderThickness="0"
                                                 Foreground="#0A2540" FontSize="15" VerticalContentAlignment="Center" MaxLength="200"/>
                                    </Border>

                                    <TextBlock Text="Description (What is needed and why?)" FontSize="13" FontWeight="SemiBold" Foreground="#0A2540" Margin="4,0,0,8"/>
                                    <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                            Padding="12,12" Background="White" Margin="0,0,0,24">
                                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="160" Background="Transparent" BorderThickness="0"
                                                 Foreground="#0A2540" FontSize="14" TextWrapping="Wrap"
                                                 AcceptsReturn="True" VerticalContentAlignment="Top" MaxLength="1000"/>
                                    </Border>

                                    <TextBlock Text="Urgency Level" FontSize="13" FontWeight="SemiBold" Foreground="#0A2540" Margin="4,0,0,12"/>
                                    <Border Background="#FAFDFF" BorderBrush="#CAF0F8" BorderThickness="1" CornerRadius="12" Padding="16">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <RadioButton Content="Low" GroupName="Urgency" IsChecked="{Binding IsLow}"
                                                         Foreground="#185FA5" FontWeight="SemiBold" FontSize="14" Margin="0,0,40,0"/>
                                            <RadioButton Content="Medium" GroupName="Urgency" IsChecked="{Binding IsMedium}"
                                                         Foreground="#B8860B" FontWeight="SemiBold" FontSize="14" Margin="0,0,40,0"/>
                                            <RadioButton Content="High" GroupName="Urgency" IsChecked="{Binding IsHigh}"
                                                         Foreground="#C0304A" FontWeight="SemiBold" FontSize="14"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Border Background="#0A0077B6" BorderBrush="#2200B4D8" BorderThickness="1" 
                                        CornerRadius="12" Padding="20" Margin="0,503,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="200" Grid.RowSpan="2" Width="600">
                                    <StackPanel>
                                        <TextBlock Text="&quot;The best way to find yourself is to lose yourself in the service of others.&quot;" 
                                                   FontSize="15" FontStyle="Italic" FontWeight="SemiBold" Foreground="#005A8C" 
                                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,60,0,0"/>
                                        <TextBlock Text="— Mahatma Gandhi" FontSize="13" FontWeight="SemiBold" Foreground="#5E7A8A" 
                                                   TextAlignment="Center" Margin="0,8,0,-15"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Top">

                            <Border Background="#EEFFFFFF" BorderBrush="#88FFFFFF" BorderThickness="1.5" 
                                    CornerRadius="20" Padding="28" Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#0077B6" BlurRadius="20" ShadowDepth="4" Opacity="0.08"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Attach a Photo (Optional)" FontSize="15" FontWeight="Bold" Foreground="#0A2540" Margin="0,0,0,16"/>

                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1" Padding="12,0" Background="White">
                                            <TextBox Text="{Binding ImagePath}" Height="40" Background="Transparent" BorderThickness="0"
                                                     Foreground="#5E7A8A" FontSize="12" IsReadOnly="True" VerticalContentAlignment="Center"/>
                                        </Border>

                                        <Button Grid.Column="2" Command="{Binding BrowseImageCommand}" Height="40" Padding="16,0" BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="10" Background="#0077B6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.85"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="📷 Browse" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                        </Button>
                                    </Grid>

                                    <Border CornerRadius="12" Background="#FAFDFF" BorderBrush="#CAF0F8" BorderThickness="2"
                                            Padding="6" MinHeight="150" HorizontalAlignment="Stretch"
                                            Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                        <Border CornerRadius="8" ClipToBounds="True">
                                            <Image Source="{Binding ImagePath}" Stretch="Uniform" MaxHeight="220" />
                                        </Border>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Background="#2200B4D8" BorderBrush="#4400B4D8" BorderThickness="1" CornerRadius="14" Padding="20" Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Text="💙 How It Reaches Donors" FontSize="13" FontWeight="Bold" Foreground="#005A8C" Margin="0,0,0,6"/>
                                    <TextBlock Text="Your post will appear in the Donor's Needs section, sorted by urgency. Donors can tap 'Donate for This Need' to fulfill it directly."
                                               FontSize="12" Foreground="#0A2540" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Margin="0,0,0,24">
                                <Button Command="{Binding PostNeedCommand}" Height="54"
                                        FontSize="15" FontWeight="Bold" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Visibility="{Binding IsCreating, Converter={StaticResource BoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="14" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00A8E8" Offset="0"/>
                                            <GradientStop Color="#0077B6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="📬  Post This Need"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Text" Value="Posting..."/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>

                                <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                </Grid>
                            </StackPanel>

                            <Border Background="#F9FDFF" BorderBrush="#BDE0FE" BorderThickness="1.5" CornerRadius="16" Padding="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#0077B6" BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                                </Border.Effect>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="💡" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Pro Tip for Organizations" FontSize="14" FontWeight="Bold" Foreground="#0077B6" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Needs with clear, specific descriptions and high-quality photos get fulfilled up to 3x faster by our KapwaKuha donor community."
                                               FontSize="12" Foreground="#5E7A8A" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>