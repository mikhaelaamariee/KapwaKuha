<Window x:Class="KapwaKuha.View.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
        Title="KapwaKuha — Forgot Password"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized" 
        FontFamily="Segoe UI">

    <Grid>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.07" Stretch="UniformToFill"/>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.05" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />

        <Ellipse Width="400" Height="400" Opacity="0.12" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-100,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="300" Height="300" Opacity="0.10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-80,0,0,-80">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0077B6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="900" Height="500" CornerRadius="28" Padding="1"
                Background="#AAFFFFFF" BorderBrush="#88FFFFFF" BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect Color="#0077B6" BlurRadius="40" ShadowDepth="6" Opacity="0.12"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="50,40"/>

                <Grid Grid.Column="1" Margin="40,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#44FF4D4D" BorderBrush="#66FF0000" BorderThickness="1" 
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,16"
                            Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#B30000" FontWeight="SemiBold"
                                   FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Username / User ID" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#0A2540" Margin="4,0,0,8"/>
                                <Border CornerRadius="12" BorderBrush="#6600B4D8" BorderThickness="1"
                                        Padding="14,0" Background="#66FFFFFF" Margin="0,0,0,28">
                                    <Grid>
                                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="42" Background="Transparent" BorderThickness="0"
                                                 Foreground="#0A2540" FontSize="14" VerticalContentAlignment="Center"/>
                                        <TextBlock Text="👤" Foreground="#6600B4D8" FontSize="18"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                    </Grid>
                                </Border>

                                <Button Command="{Binding FindAccountCommand}"
                                        Height="50" FontSize="15" FontWeight="Bold"
                                        Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,20">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="14" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00A8E8" Offset="0"/>
                                            <GradientStop Color="#0077B6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <TextBlock Text="Find My Account"/>
                                </Button>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}">
                                <Border Background="#4400B4D8" BorderBrush="#3300B4D8" BorderThickness="1" 
                                        CornerRadius="12" Padding="16,14" Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock Text="SECURITY QUESTION" FontSize="11" Foreground="#0077B6"
                                                   FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding SecurityQuestion}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#0A2540" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Your Answer" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#0A2540" Margin="4,0,0,8"/>
                                <Border CornerRadius="12" BorderBrush="#6600B4D8" BorderThickness="1"
                                        Padding="14,0" Background="#66FFFFFF" Margin="0,0,0,16">
                                    <Grid>
                                        <TextBox Text="{Binding SecurityAnswer, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="42" Background="Transparent" BorderThickness="0"
                                                 Foreground="#0A2540" FontSize="14" VerticalContentAlignment="Center"/>
                                        <TextBlock Text="🖱" Foreground="#6600B4D8" FontSize="18"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                    </Grid>
                                </Border>

                                <TextBlock Text="New Password (min 6 chars)" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#0A2540" Margin="4,0,0,8"/>
                                <Border CornerRadius="12" BorderBrush="#6600B4D8" BorderThickness="1"
                                        Padding="14,0" Background="#66FFFFFF" Margin="0,0,0,16">
                                    <Grid>
                                        <PasswordBox x:Name="NewPwBox" Height="42" Background="Transparent"
                                                     BorderThickness="0" Foreground="#0A2540"
                                                     FontSize="14" Padding="0,10,0,0"/>
                                        <TextBlock Text="🔒" Foreground="#6600B4D8" FontSize="18"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                    </Grid>
                                </Border>

                                <TextBlock Text="Confirm New Password" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#0A2540" Margin="4,0,0,8"/>
                                <Border CornerRadius="12" BorderBrush="#6600B4D8" BorderThickness="1"
                                        Padding="14,0" Background="#66FFFFFF" Margin="0,0,0,28">
                                    <Grid>
                                        <PasswordBox x:Name="ConfirmPwBox" Height="42" Background="Transparent"
                                                     BorderThickness="0" Foreground="#0A2540"
                                                     FontSize="14" Padding="0,10,0,0"/>
                                        <TextBlock Text="🔒" Foreground="#6600B4D8" FontSize="18"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                    </Grid>
                                </Border>

                                <Button x:Name="ResetBtn" Height="50" FontSize="15" FontWeight="Bold"
                                        Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,20"
                                        Click="ResetBtn_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="14" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00A8E8" Offset="0"/>
                                            <GradientStop Color="#0077B6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <TextBlock Text="Reset Password ✓"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2" Command="{Binding BackCommand}" Margin="0,10,0,0"
                            HorizontalAlignment="Center" Background="Transparent"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <Button Command="{Binding BackCommand}" HorizontalAlignment="Left"
Background="Transparent" BorderThickness="0"
Foreground="#0077B6" FontSize="12" Cursor="Hand"
Margin="18,20,0,448">
                    <TextBlock Text="← Back to Login" TextDecorations="Underline" RenderTransformOrigin="0.564,-12.87"
                               Margin=" 0,0,0,0"/>
                </Button>

                <Image Source="https://i.imgur.com/FHFRQxB.png" 
Width="146" Height="168" 
HorizontalAlignment="Left" 
VerticalAlignment="Top" Margin="157,66,0,0" RenderTransformOrigin="1.465,0.725"/>
                <TextBlock FontSize="32" FontWeight="Bold" Margin="139,178,91,275"><Run Foreground="#FF0A2540" Text="Kapwa"/><Run Foreground="#FF00A8E8" Text="Kuha"/></TextBlock>
                <TextBlock Text="Forgot Password" FontSize="26" FontWeight="Bold"
                               Foreground="#0A2540" Margin="128,247,79,213"/>
                <TextBlock Text="We'll verify your identity first."
                               FontSize="14" Foreground="#5E7A8A" Margin="139,291,90,185" RenderTransformOrigin="0.64,0.526"/>
            </Grid>
        </Border>
    </Grid>
</Window>