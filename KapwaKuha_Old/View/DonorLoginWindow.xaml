<Window x:Class="KapwaKuha.View.DonorLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Donor Login"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FontFamily="Segoe UI">
    <!-- NO Window.Resources — BoolToVis, KapwaBtn, OutlineBtn, LinkBtn all in App.xaml -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <!-- Left — form -->
        <Grid Grid.Column="0" Background="White">
            <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.02"
                   Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Height="2808" RenderTransformOrigin="0.5,0.5"/>

            <Button Command="{Binding BackCommand}"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Style="{StaticResource LinkBtn}"
                    Content="← Back" Margin="40,40,0,0" FontSize="14"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Width="400" Margin="20,0">
                <TextBlock Text="DONOR LOGIN" FontSize="36" FontWeight="Black"
                           Foreground="#8FD9FB" HorizontalAlignment="Center"/>
                <TextBlock Text="Sign in to your KapwaKuha Donor Portal."
                           FontSize="14" Foreground="#6B7280"
                           HorizontalAlignment="Center" Margin="0,8,0,40"/>

                <!-- Username input -->
                <Border Background="#F4F6F8" CornerRadius="12" Height="50" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="👤" Foreground="#9CA3AF" FontSize="16"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="UserEntry"
             Text="{Binding CurrentUser.UserID, UpdateSourceTrigger=PropertyChanged}"
             BorderThickness="0" Background="Transparent"
             VerticalContentAlignment="Center" FontSize="14" Padding="0,0,15,0"
             Panel.ZIndex="1"/>

                            <TextBlock IsHitTestVisible="False"
               Text="Enter your username"
               VerticalAlignment="Center"
               HorizontalAlignment="Left"
               Padding="5,0,0,0"
               Foreground="Gray"
               FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=UserEntry}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Password input -->
                <Border Background="#F4F6F8" CornerRadius="12" Height="50" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔒" Foreground="#9CA3AF" FontSize="16"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBlock x:Name="PlaceholderText"
               Text="Enter your password"
               VerticalAlignment="Center"
               Foreground="Gray"
               FontSize="14"
               Margin="5,0,0,0"
               IsHitTestVisible="False"
               Visibility="Visible"/>

                            <PasswordBox x:Name="PwBox" 
                 PasswordChanged="PwBox_PasswordChanged"
                 BorderThickness="0" 
                 Background="Transparent"
                 VerticalContentAlignment="Center" 
                 FontSize="14" 
                 Padding="0,0,15,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Error banner -->
                <Border Background="#FEE2E2" CornerRadius="8" Padding="12,10" Margin="0,0,0,12"
                        Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                               FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </Border>

                <!-- Login button — uses GradientButton from App.xaml -->
                <Button Content="Login Now"
                        Style="{StaticResource GradientButton}"
                        Margin="0,10,0,30" Height="50"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PwBox}"/>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Separator Grid.Column="0" Background="#E5E7EB" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="1" Text="Account Actions"
                               FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    <Separator Grid.Column="2" Background="#E5E7EB" Margin="12,0,0,0"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource OutlineBtn}"
                            Command="{Binding ForgotPasswordCommand}" Height="45">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔑" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Forgot Password" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource OutlineBtn}"
                            Command="{Binding SignUpCommand}" Height="45">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✨" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Create Account" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <TextBlock Text="Default: juandc / donor123"
                           FontSize="11" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" Margin="0,24,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Right — decorative panel -->
        <Border Grid.Column="1" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#00A8E8" Offset="0"/>
                    <GradientStop Color="SkyBlue"  Offset="0.5"/>
                    <GradientStop Color="#0A2540"  Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Ellipse Width="600" Height="600" Fill="#1AFFFFFF"
                         Margin="-200,-200,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <Ellipse Width="800" Height="800" Fill="#0DFFFFFF"
                         Margin="0,0,-300,-300" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                <Border Width="420" Height="550" CornerRadius="24"
                        Background="#1AFFFFFF" BorderBrush="#4DFFFFFF" BorderThickness="1.5"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.25" ShadowDepth="10"/>
                    </Border.Effect>
                    <Border CornerRadius="20" Margin="-20,-46,-20,-2" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="-1.789"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Border.Background>
                            <ImageBrush ImageSource="https://i.imgur.com/3TkOWO9.png" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                </Border>
                <Border Width="60" Height="60" Background="White" CornerRadius="30"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-450,200,0,0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.15" ShadowDepth="5"/>
                    </Border.Effect>
                    <TextBlock Text="🤲" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>