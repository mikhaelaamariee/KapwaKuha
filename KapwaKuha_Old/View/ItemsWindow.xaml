<Window x:Class="KapwaKuha.View.ItemsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
      
        Title="KapwaKuha — All Items"
        Height="680" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" ResizeMode="CanResize">
    <Grid>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.07" Stretch="UniformToFill"/>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.08" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#AAFFFFFF">
                <Border.Effect>
                    <DropShadowEffect Color="#0077B6" BlurRadius="10" ShadowDepth="0" Opacity="0.10"/>
                </Border.Effect>
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}" Style="{StaticResource LinkBtn}"
                            Content="← Back" FontSize="13" Foreground="#03045E"/>
                    <TextBlock Grid.Column="1" Text="All Items" FontSize="18" FontWeight="Bold"
                               Foreground="#03045E" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}" Style="{StaticResource LinkBtn}"
                            Content="⟳ Refresh" FontSize="12"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Items list -->
                <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Filter bar -->
                        <Grid Grid.Row="0" Margin="16,14,16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource GlassInputBorder}" Grid.Column="0" Margin="0,0,10,0">
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent" Height="32"
                                         VerticalContentAlignment="Center" Foreground="#03045E" FontSize="12"/>
                            </Border>
                            <Border Style="{StaticResource GlassInputBorder}" Grid.Column="1" Margin="0,0,10,0">
                                <ComboBox ItemsSource="{Binding StatusFilters}"
                                          SelectedItem="{Binding SelectedStatusFilter}"
                                          Background="Transparent" BorderThickness="0" Height="32"
                                          VerticalContentAlignment="Center" FontSize="12"/>
                            </Border>
                            <Border Style="{StaticResource GlassInputBorder}" Grid.Column="2" Margin="0">
                                <ComboBox ItemsSource="{Binding CategoryFilters}"
                                          SelectedItem="{Binding SelectedCategoryFilter}"
                                          Background="Transparent" BorderThickness="0" Height="32"
                                          VerticalContentAlignment="Center" FontSize="12"/>
                            </Border>
                        </Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding FilteredItems}"
                                  SelectedItem="{Binding SelectedItem}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  BorderThickness="0" Background="Transparent"
                                  RowBackground="Transparent" AlternatingRowBackground="#11CAF0F8"
                                  GridLinesVisibility="Horizontal"
                           
                                  RowHeight="42" ColumnHeaderHeight="36"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item ID" Binding="{Binding Item_ID}" Width="90"/>
                                <DataGridTextColumn Header="Item Name" Binding="{Binding Item_Name}" Width="*"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category_Name}" Width="110"/>
                                <DataGridTextColumn Header="Condition" Binding="{Binding Item_Condition}" Width="90"/>
                                <DataGridTemplateColumn Header="Status" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3"
                                                    Background="{Binding StatusColor}"
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Item_Status}"
                                                           Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Storage" Binding="{Binding StorageDaysDisplay}" Width="120"/>
                                <DataGridTextColumn Header="Donor" Binding="{Binding Donor_Name}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Detail panel -->
                <Border Grid.Column="2" Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <TextBlock Text="Item Detail" FontSize="15" FontWeight="Bold"
                                   Foreground="#03045E" Margin="0,0,0,4"/>
                        <TextBlock Text="Select an item to view details"
                                   FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,16"/>

                        <!-- Empty state -->
                        <TextBlock Text="No item selected"
                                   HorizontalAlignment="Center" Foreground="#5E7A8A"
                                   FontSize="12" Margin="0,30,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsItemSelected}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Detail content -->
                        <StackPanel Visibility="{Binding IsItemSelected, Converter={StaticResource BoolToVis}}">
                            <Border CornerRadius="12" Padding="14" Margin="0,0,0,14"
                                    Background="#4DFFFFFF" BorderBrush="#B390E0EF" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedItem.Item_Name}"
                                               FontSize="16" FontWeight="Bold" Foreground="#03045E"/>
                                    <TextBlock Text="{Binding SelectedItem.Item_ID}"
                                               FontSize="11" Foreground="#5E7A8A" Margin="0,2,0,8"/>
                                    <TextBlock Text="{Binding SelectedItem.StorageDaysDisplay}"
                                               FontSize="12" Foreground="#0077B6" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Update Status" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,6"/>
                          
                                <ComboBox ItemsSource="{Binding StatusOptions}"
                                          SelectedItem="{Binding NewStatus}"
                                          Background="Transparent" BorderThickness="0"
                                          Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                         

                            <Button Command="{Binding UpdateStatusCommand}"
                                    Style="{StaticResource GradientButton}"
                                    Margin="0,30,0,0">
                                <TextBlock Text="Update Status →"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>